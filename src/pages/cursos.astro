---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
import { getCollection } from 'astro:content';
import { getRelativePath } from '../utils/paths';

const allCourses = await getCollection('courses');
const allChapters = await getCollection('chapters');

const difficultyConfig: Record<string, { label: string; color: string; border: string; bg: string }> = {
	Beginner: { label: 'Noob', color: 'text-primary', border: 'border-primary/20', bg: 'bg-primary/10' },
	Intermediate: { label: 'Dev', color: 'text-accent-blue', border: 'border-accent-blue/20', bg: 'bg-accent-blue/10' },
	Advanced: { label: 'Ninja', color: 'text-purple-400', border: 'border-purple-500/20', bg: 'bg-purple-500/10' },
};

const coursesWithChapters = allCourses.map((course) => {
	const courseSlug = course.id.replace('/index', '');
	const chapters = allChapters
		.filter((ch) => ch.id.startsWith(courseSlug + '/'))
		.sort((a, b) => a.id.localeCompare(b.id));
	return { ...course, slug: courseSlug, chapterCount: chapters.length };
});
---

<Layout title="Cursos - Programierds | Elige tu camino (sin olores raros)">
	<div class="relative flex min-h-screen flex-col overflow-x-hidden">
		<Header />

		<main class="flex-1 px-4 lg:px-20 py-12">
			<div class="mx-auto max-w-7xl">
				<div class="mb-12">
					<h1 class="text-4xl lg:text-6xl font-black text-slate-900 dark:text-white mb-4">Cursos</h1>
					<p class="text-xl text-slate-600 dark:text-slate-400">Elige tu camino <span class="text-primary font-bold italic">(sin olores raros)</span></p>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
					{coursesWithChapters.map((course) => {
						const config = difficultyConfig[course.data.difficulty];
						const iconName = course.data.technology.toLowerCase();
						return (
							<a href={getRelativePath(`/cursos/${course.slug}`)} class="group flex flex-col rounded-2xl border border-primary/10 bg-background-light dark:bg-background-dark p-6 hover:border-primary/50 transition-all hover:shadow-[0_0_30px_-5px_rgba(13,242,89,0.15)]">
								<div class="flex justify-between items-start mb-6">
									<div class={`size-14 flex items-center justify-center rounded-xl ${config.bg} ${config.color}`}>
										<Icon name={iconName} class="w-9 h-9" />
									</div>
									<span class={`px-3 py-1 text-[10px] font-black uppercase tracking-widest ${config.bg} ${config.color} rounded-full border ${config.border}`}>
										{config.label}
									</span>
								</div>
								<h3 class="text-2xl font-bold text-slate-900 dark:text-white mb-3">{course.data.technology}</h3>
								<p class="text-slate-600 dark:text-slate-400 leading-relaxed mb-6 flex-1">
									{course.data.description}
								</p>
								<div class="flex items-center justify-between pt-6 border-t border-primary/10">
									<div class="flex items-center gap-2 text-slate-500">
										<Icon name="menu_book" class="w-4 h-4 text-primary" />
										<span class="text-sm font-medium">{course.chapterCount} lecciones</span>
									</div>
									<span class="px-6 py-2 rounded-lg bg-primary text-background-dark font-bold text-sm group-hover:scale-105 transition-transform">
										Ver curso
									</span>
								</div>
							</a>
						);
					})}
				</div>
			</div>
		</main>

		<Footer />
	</div>
</Layout>
