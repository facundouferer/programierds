---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import '@fontsource/fira-code/400.css';
import '@fontsource/fira-code/500.css';
---

<Layout title="Playground - Programierds | Rompe cosas con código">
	<style>
		.code-font {
			font-family: 'Fira Code', monospace;
		}
		.custom-scrollbar::-webkit-scrollbar {
			width: 8px;
			height: 8px;
		}
		.custom-scrollbar::-webkit-scrollbar-track {
			background: #0a140d;
		}
		.custom-scrollbar::-webkit-scrollbar-thumb {
			background: #0df25933;
			border-radius: 10px;
		}
		.custom-scrollbar::-webkit-scrollbar-thumb:hover {
			background: #0df25966;
		}
		/* CodeMirror overrides para que ocupe todo el espacio */
		#code-editor-container .cm-editor {
			height: 100%;
			font-family: 'Fira Code', monospace;
			font-size: 0.875rem;
		}
		#code-editor-container .cm-scroller {
			overflow: auto;
		}
		#code-editor-container .cm-gutters {
			border-right: 1px solid rgba(13, 242, 89, 0.05);
		}
	</style>
	<style is:global>
		#code-editor-container .cm-line.cm-step-highlight {
			background-color: rgba(13, 242, 89, 0.15) !important;
			border-left: 3px solid #0df259;
			transition: background-color 0.2s ease;
		}
	</style>

	<div class="relative flex h-screen flex-col overflow-hidden">

		<div class="flex items-center justify-between px-4 lg:px-8 py-2 bg-background-dark border-b border-primary/5">
			<div class="flex items-center gap-4">
				<div class="relative" id="lang-dropdown">
					<button id="lang-toggle" class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-primary/5 border border-primary/20 hover:border-primary/40 transition-colors text-xs font-bold text-slate-300">
						<span id="lang-label">JavaScript</span>
						<Icon name="expand_more" class="w-4 h-4 text-primary" />
					</button>
					<div id="lang-menu" class="hidden absolute top-full left-0 mt-1 w-44 rounded-lg bg-background-dark border border-primary/20 shadow-lg shadow-black/50 overflow-hidden z-50">
						<button data-lang="javascript" data-file="main.js" class="lang-option w-full flex items-center gap-3 px-4 py-2.5 text-xs font-medium text-slate-300 hover:bg-primary/10 hover:text-primary transition-colors">
							<Icon name="javascript" class="w-4 h-4" />
							JavaScript
						</button>
						<button data-lang="java" data-file="Main.java" class="lang-option w-full flex items-center gap-3 px-4 py-2.5 text-xs font-medium text-slate-300 hover:bg-primary/10 hover:text-primary transition-colors">
							<Icon name="code" class="w-4 h-4" />
							Java
						</button>
						<button data-lang="c" data-file="main.c" class="lang-option w-full flex items-center gap-3 px-4 py-2.5 text-xs font-medium text-slate-300 hover:bg-primary/10 hover:text-primary transition-colors">
							<Icon name="code" class="w-4 h-4" />
							C
						</button>
						<button data-lang="python" data-file="main.py" class="lang-option w-full flex items-center gap-3 px-4 py-2.5 text-xs font-medium text-slate-300 hover:bg-primary/10 hover:text-primary transition-colors">
							<Icon name="code" class="w-4 h-4" />
							Python
						</button>
					</div>
				</div>
				<div class="h-4 w-px bg-primary/10"></div>
				<div class="flex items-center gap-2 text-xs font-mono text-slate-400">
					<Icon name="description" class="w-4 h-4" />
					<span id="file-name">main.js</span>
				</div>
				<div class="h-4 w-px bg-primary/10"></div>
				<div class="flex items-center gap-1">
					<button class="p-1.5 hover:bg-white/5 rounded transition-colors text-slate-400 hover:text-white">
						<Icon name="save" class="w-5 h-5" />
					</button>
					<button class="p-1.5 hover:bg-white/5 rounded transition-colors text-slate-400 hover:text-white">
						<Icon name="settings" class="w-5 h-5" />
					</button>
				</div>
			</div>
			<div class="flex items-center gap-3">
				<button id="run-btn" class="flex items-center gap-2 px-6 py-2 rounded-lg bg-primary text-background-dark font-black text-sm uppercase tracking-wider hover:brightness-110 active:scale-95 transition-all shadow-[0_0_20px_-5px_rgba(13,242,89,0.4)]">
					<Icon name="play_arrow" class="w-5 h-5" />
					RUN
				</button>
				<button id="debug-btn" class="flex items-center gap-2 px-6 py-2 rounded-lg bg-accent-blue text-white font-black text-sm uppercase tracking-wider hover:brightness-110 active:scale-95 transition-all shadow-[0_0_20px_-5px_rgba(59,130,246,0.4)]">
					<Icon name="bug_report" class="w-5 h-5" />
					DEBUG
				</button>
			</div>
		</div>

		<main class="flex-1 flex overflow-hidden">
			<div id="code-editor-container" class="flex-1 flex flex-col border-r border-primary/10">
			</div>

			<div class="w-1/3 min-w-[350px] flex flex-col bg-terminal-bg">
				<div id="step-controls" class="hidden px-4 py-2 border-b border-primary/10 flex items-center justify-between bg-accent-blue/10">
					<div class="flex items-center gap-3">
						<button id="step-reset-btn" class="flex items-center gap-1 px-3 py-1.5 rounded-lg bg-red-500/20 border border-red-500/40 text-red-400 text-xs font-bold hover:bg-red-500/30 transition-colors">
							<Icon name="sync" class="w-4 h-4" />
							Reset
						</button>
						<button id="step-next-btn" class="flex items-center gap-1 px-4 py-1.5 rounded-lg bg-primary/20 border border-primary/40 text-primary text-xs font-bold hover:bg-primary/30 transition-colors">
							<Icon name="arrow_forward" class="w-4 h-4" />
							Siguiente
						</button>
					</div>
					<span id="step-counter" class="text-xs font-mono text-slate-400">Paso 0 / 0</span>
				</div>
				<div id="stdin-panel" class="hidden border-b border-primary/10">
					<div class="px-4 py-2 border-b border-primary/5 flex items-center gap-2">
						<Icon name="terminal" class="w-3 h-3 text-yellow-400" />
						<span class="text-[10px] font-bold uppercase tracking-widest text-yellow-400">Stdin (entrada de datos)</span>
					</div>
					<textarea
						id="stdin-input"
						class="w-full bg-terminal-bg text-slate-400 p-3 code-font text-xs leading-relaxed focus:outline-none resize-none custom-scrollbar h-20"
						spellcheck="false"
						placeholder="Escribe aquí los datos de entrada (uno por línea)..."
					></textarea>
				</div>
				<div class="px-4 py-2 border-b border-primary/10 flex items-center justify-between bg-terminal-bg">
					<div class="flex items-center gap-2">
						<Icon name="terminal" class="w-4 h-4 text-primary" />
						<span class="text-xs font-bold uppercase tracking-widest text-slate-400">Terminal Output</span>
					</div>
					<button id="clear-btn" class="text-slate-500 hover:text-white transition-colors">
						<Icon name="delete_sweep" class="w-4 h-4" />
					</button>
				</div>
				<div id="terminal-output" class="flex-1 p-4 code-font text-sm custom-scrollbar overflow-y-auto">
					<div class="text-slate-500 italic text-xs">// Esperando ejecución...</div>
				</div>
			</div>
		</main>

		<footer class="h-8 border-t border-primary/10 bg-background-dark px-4 flex items-center justify-between text-[10px] text-slate-500 font-mono">
			<div class="flex items-center gap-4">
				<div class="flex items-center gap-1">
					<Icon name="fork_right" class="w-3 h-3" />
					<span>main*</span>
				</div>
				<div class="flex items-center gap-1">
					<Icon name="sync" class="w-3 h-3" />
					<a href="https://www.facundouferer.ar/" target="_blank" rel="noopener noreferrer" class="hover:text-primary transition-colors">desarrollado por Facundo Uferer</a>
				</div>
			</div>
			<div class="flex items-center gap-4">
				<span id="footer-position">Ln 1, Col 1</span>
				<span>UTF-8</span>
				<span id="footer-lang" class="text-primary font-bold">JavaScript</span>
			</div>
		</footer>
	</div>

	<script>
		import { EditorView, basicSetup } from 'codemirror';
		import { EditorState, Compartment, StateEffect, StateField } from '@codemirror/state';
		import { javascript } from '@codemirror/lang-javascript';
		import { java } from '@codemirror/lang-java';
		import { cpp } from '@codemirror/lang-cpp';
		import { python } from '@codemirror/lang-python';
		import { oneDark } from '@codemirror/theme-one-dark';
		import { keymap, Decoration } from '@codemirror/view';
		import { indentWithTab } from '@codemirror/commands';

		// Step mode: line highlight
		const setHighlightLine = StateEffect.define<number | null>();
		const highlightLineField = StateField.define({
			create() { return Decoration.none; },
			update(decorations, tr) {
				for (const effect of tr.effects) {
					if (effect.is(setHighlightLine)) {
						if (effect.value === null) return Decoration.none;
						const line = tr.state.doc.line(effect.value);
						const deco = Decoration.line({ attributes: { class: 'cm-step-highlight' } });
						return Decoration.set([deco.range(line.from)]);
					}
				}
				return decorations;
			},
			provide: f => EditorView.decorations.from(f),
		});
		const editableCompartment = new Compartment();

		const JUDGE0_URL = 'https://ce.judge0.com';
		const LANG_IDS: Record<string, number> = {
			javascript: 102,
			java: 91,
			c: 50,
			python: 71,
		};

		const defaultCodes: Record<string, string> = {
			javascript: `// Programierds Code Playground
// Escribe tu código aquí y dale a RUN

function helloWorld() {
    const msg = "JavaScript desde el barro";
    console.log(msg);
    for (let i = 0; i < 5; i++) {
        console.log("Iteración número: " + (i + 1));
    }
    return "Listo para romper cosas.";
}

const resultado = helloWorld();
console.log(resultado);`,

			java: `// Programierds Code Playground
// Escribe tu código Java aquí y dale a RUN

public class Main {
    public static void main(String[] args) {
        String msg = "Java desde el barro";
        System.out.println(msg);
        for (int i = 0; i < 5; i++) {
            System.out.println("Iteración número: " + (i + 1));
        }
        System.out.println("Listo para romper cosas.");
    }
}`,

			c: `// Programierds Code Playground
// Escribe tu código C aquí y dale a RUN

#include <stdio.h>

int main() {
    char *msg = "C desde el barro";
    printf("%s\\n", msg);
    for (int i = 0; i < 5; i++) {
        printf("Iteración número: %d\\n", i + 1);
    }
    printf("Listo para romper cosas.\\n");
    return 0;
}`,

			python: `# Programierds Code Playground
# Escribe tu código Python aquí y dale a RUN

def hello_world():
    msg = "Python desde el barro"
    print(msg)
    for i in range(5):
        print(f"Iteración número: {i + 1}")
    return "Listo para romper cosas."

resultado = hello_world()
print(resultado)`
		};

		let currentLang = 'javascript';

		// CodeMirror setup
		const langCompartment = new Compartment();
		const editorContainer = document.getElementById('code-editor-container')!;

		const editorView = new EditorView({
			state: EditorState.create({
				doc: defaultCodes.javascript,
				extensions: [
					basicSetup,
					keymap.of([indentWithTab]),
					oneDark,
					langCompartment.of(javascript()),
					highlightLineField,
					editableCompartment.of(EditorView.editable.of(true)),
					EditorView.updateListener.of((update) => {
						if (update.docChanged) {
							onCodeChange();
						}
						if (update.selectionSet) {
							updateFooterPosition();
						}
					}),
				],
			}),
			parent: editorContainer,
		});

		// DOM refs
		const stdinInput = document.getElementById('stdin-input') as HTMLTextAreaElement;
		const stdinPanel = document.getElementById('stdin-panel')!;
		const terminal = document.getElementById('terminal-output')!;
		const runBtn = document.getElementById('run-btn')!;
		const clearBtn = document.getElementById('clear-btn')!;
		const toggle = document.getElementById('lang-toggle')!;
		const menu = document.getElementById('lang-menu')!;
		const langLabel = document.getElementById('lang-label')!;
		const fileNameEl = document.getElementById('file-name')!;
		const footerLang = document.getElementById('footer-lang')!;
		const footerPos = document.getElementById('footer-position')!;
		const debugBtn = document.getElementById('debug-btn')!;
		const stepControls = document.getElementById('step-controls')!;
		const stepNextBtn = document.getElementById('step-next-btn')!;
		const stepResetBtn = document.getElementById('step-reset-btn')!;
		const stepCounter = document.getElementById('step-counter')!;

		function getCode(): string {
			return editorView.state.doc.toString();
		}

		function setCode(code: string) {
			editorView.dispatch({
				changes: { from: 0, to: editorView.state.doc.length, insert: code }
			});
		}

		function onCodeChange() {
			const code = getCode();
			updateStdinVisibility(code);
			if (currentLang === 'java') {
				const className = extractJavaClassName(code);
				fileNameEl.textContent = `${className}.java`;
			}
		}

		function updateFooterPosition() {
			const pos = editorView.state.selection.main.head;
			const line = editorView.state.doc.lineAt(pos);
			const ln = line.number;
			const col = pos - line.from + 1;
			footerPos.textContent = `Ln ${ln}, Col ${col}`;
		}

		function detectNeedsStdin(code: string): boolean {
			if (currentLang === 'java') {
				return /Scanner|System\.in|BufferedReader|readLine/.test(code);
			}
			if (currentLang === 'javascript') {
				return /readline|process\.stdin|prompt\(/.test(code);
			}
			if (currentLang === 'c') {
				return /scanf|fgets|getchar|gets/.test(code);
			}
			if (currentLang === 'python') {
				return /input\(/.test(code);
			}
			return false;
		}

		function updateStdinVisibility(code: string) {
			stdinPanel.classList.toggle('hidden', !detectNeedsStdin(code));
		}

		function setTerminalContent(html: string) {
			terminal.innerHTML = html;
			terminal.scrollTop = terminal.scrollHeight;
		}

		function appendTerminalLine(text: string, className = 'text-slate-400') {
			const div = document.createElement('div');
			div.className = className;
			div.textContent = text;
			terminal.appendChild(div);
			terminal.scrollTop = terminal.scrollHeight;
		}

		function showPrompt() {
			const div = document.createElement('div');
			div.className = 'flex gap-2 mt-2';
			div.innerHTML = `<span class="text-primary">➜</span><span class="inline-block w-2 h-4 bg-primary/50 animate-pulse"></span>`;
			terminal.appendChild(div);
		}

		function showCommand(cmd: string) {
			const cmdDiv = document.createElement('div');
			cmdDiv.className = 'flex gap-2 mb-2';
			cmdDiv.innerHTML = `<span class="text-primary">➜</span><span class="text-slate-300">${cmd}</span>`;
			terminal.appendChild(cmdDiv);
		}

		function highlightLine(lineNumber: number | null) {
			if (lineNumber === null) {
				editorView.dispatch({ effects: setHighlightLine.of(null) });
				return;
			}
			const line = editorView.state.doc.line(lineNumber);
			editorView.dispatch({
				effects: [
					setHighlightLine.of(lineNumber),
					EditorView.scrollIntoView(line.from, { y: 'center' }),
				]
			});
		}

		function setEditorEditable(editable: boolean) {
			editorView.dispatch({ effects: editableCompartment.reconfigure(EditorView.editable.of(editable)) });
		}

		function extractJavaClassName(code: string): string {
			const match = code.match(/public\s+class\s+(\w+)/);
			return match ? match[1] : 'Main';
		}

		function prepareJavaCode(code: string): string {
			let prepared = code;
			prepared = prepared.replace(/^\s*package\s+[\w.]+\s*;\s*\n?/m, '');
			prepared = prepared.replace(/public\s+class\s+(\w+)/, 'public class Main');
			return prepared;
		}

		interface JSCaptureResult {
			outputs: string[];
			error: string | null;
			returnValue: unknown;
		}

		async function captureJavaScript(code: string): Promise<JSCaptureResult> {
			const logs: string[] = [];
			const originalLog = console.log;
			const originalError = console.error;
			const originalWarn = console.warn;

			console.log = (...args) => logs.push(args.map(String).join(' '));
			console.error = (...args) => logs.push(`[ERROR] ${args.map(String).join(' ')}`);
			console.warn = (...args) => logs.push(`[WARN] ${args.map(String).join(' ')}`);

			let result: unknown;
			let error: string | null = null;

			try {
				result = new Function(code)();
			} catch (e) {
				error = e instanceof Error ? e.message : String(e);
			} finally {
				console.log = originalLog;
				console.error = originalError;
				console.warn = originalWarn;
			}

			return { outputs: logs, error, returnValue: result };
		}

		async function runJavaScript(code: string) {
			const { outputs, error, returnValue } = await captureJavaScript(code);

			setTerminalContent('');
			showCommand('node main.js');

			for (const line of outputs) {
				if (line.startsWith('[ERROR]')) {
					appendTerminalLine(line, 'text-red-400');
				} else if (line.startsWith('[WARN]')) {
					appendTerminalLine(line, 'text-yellow-400');
				} else {
					appendTerminalLine(line, 'text-slate-300');
				}
			}

			if (error) {
				appendTerminalLine(error, 'text-red-400 font-medium');
			} else if (returnValue !== undefined) {
				appendTerminalLine(JSON.stringify(returnValue), 'text-accent-blue mt-1');
			}

			showPrompt();
		}

		function getRunCommand(lang: string, className: string): string {
			if (lang === 'java') return `javac ${className}.java && java ${className}`;
			if (lang === 'c') return 'gcc main.c -o main && ./main';
			if (lang === 'python') return 'python3 main.py';
			return 'node main.js';
		}

		interface Judge0Result {
			stdout: string;
			stderr: string;
			compileOutput: string;
			statusId: number;
			statusDesc: string;
			time: string | null;
		}

		function prepareSourceCode(code: string, lang: string): string {
			if (lang === 'java') return prepareJavaCode(code);
			return code;
		}

		async function captureJudge0(code: string, lang: string): Promise<Judge0Result> {
			const langId = LANG_IDS[lang];
			const sourceCode = prepareSourceCode(code, lang);

			const stdinValue = stdinInput.value.trim();
			const body: Record<string, unknown> = {
				language_id: langId,
				source_code: btoa(Array.from(new TextEncoder().encode(sourceCode), b => String.fromCharCode(b)).join('')),
			};
			if (stdinValue) {
				body.stdin = btoa(Array.from(new TextEncoder().encode(stdinValue), b => String.fromCharCode(b)).join(''));
			}

			const submitRes = await fetch(`${JUDGE0_URL}/submissions?base64_encoded=true&wait=true`, {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify(body)
			});

			if (!submitRes.ok) {
				throw new Error(`HTTP ${submitRes.status}: ${submitRes.statusText}`);
			}

			let data = await submitRes.json();

			while (data.status && (data.status.id === 1 || data.status.id === 2)) {
				await new Promise(r => setTimeout(r, 1000));
				const pollRes = await fetch(`${JUDGE0_URL}/submissions/${data.token}?base64_encoded=true`);
				data = await pollRes.json();
			}

			const decode = (b64: string | null) => {
				if (!b64) return '';
				try {
					return new TextDecoder().decode(Uint8Array.from(atob(b64), c => c.charCodeAt(0)));
				} catch {
					return atob(b64);
				}
			};

			return {
				stdout: decode(data.stdout),
				stderr: decode(data.stderr),
				compileOutput: decode(data.compile_output),
				statusId: data.status?.id ?? 0,
				statusDesc: data.status?.description ?? '',
				time: data.time ?? null,
			};
		}

		async function runWithJudge0(code: string, lang: string) {
			const isCompiled = lang === 'java' || lang === 'c';
			const className = lang === 'java' ? extractJavaClassName(code) : 'Main';
			const runCmd = getRunCommand(lang, className);

			setTerminalContent('');
			showCommand(runCmd);
			appendTerminalLine(isCompiled ? 'Compilando y ejecutando...' : 'Ejecutando...', 'text-yellow-400 animate-pulse');

			try {
				const result = await captureJudge0(code, lang);

				setTerminalContent('');
				showCommand(runCmd);

				if (result.compileOutput && result.statusId !== 3) {
					appendTerminalLine('Error de compilación:', 'text-red-400 font-medium mt-1');
					for (const line of result.compileOutput.split('\n')) {
						if (line.trim()) appendTerminalLine(line, 'text-red-400');
					}
				}

				if (result.stdout) {
					for (const line of result.stdout.split('\n')) {
						if (line !== '') appendTerminalLine(line, 'text-slate-300');
					}
				}

				if (result.stderr) {
					for (const line of result.stderr.split('\n')) {
						if (line.trim()) appendTerminalLine(line, 'text-red-400');
					}
				}

				if (result.statusId !== 3) {
					appendTerminalLine(`[${result.statusDesc}]`, 'text-yellow-400 mt-1');
				}

				if (result.time) {
					appendTerminalLine(`Tiempo: ${result.time}s`, 'text-slate-600 mt-1');
				}

			} catch (e) {
				setTerminalContent('');
				showCommand(runCmd);
				appendTerminalLine('Error de conexión con el servidor:', 'text-red-400 font-medium');
				appendTerminalLine(e instanceof Error ? e.message : String(e), 'text-red-400');
			}

			showPrompt();
		}

		// ── Step Mode Logic ──

		interface StepInfo {
			lineNumber: number;
			outputLines: string[];
		}

		let stepMode = false;
		let stepData: StepInfo[] = [];
		let stepIndex = -1;

		function getOutputPatterns(lang: string): string[] {
			switch (lang) {
				case 'javascript': return ['console.log', 'console.error', 'console.warn'];
				case 'java': return ['System.out.println', 'System.out.print', 'System.err'];
				case 'c': return ['printf', 'puts', 'fprintf'];
				case 'python': return ['print('];
				default: return [];
			}
		}

		function isSkippableLine(trimmed: string, lang: string): boolean {
			if (trimmed === '') return true;
			if (trimmed.startsWith('//') || trimmed.startsWith('#') || trimmed.startsWith('/*') || trimmed.startsWith('*')) return true;
			if (trimmed === '{' || trimmed === '}' || trimmed === '};') return true;
			if (trimmed.startsWith('import ') || trimmed.startsWith('#include')) return true;
			if (lang === 'java' && /^(public\s+class|package\s)/.test(trimmed)) return true;
			if (lang === 'c' && trimmed === 'return 0;') return true;
			return false;
		}

		function isLineInLoop(lineIdx: number, lines: string[], lang: string): boolean {
			if (['javascript', 'java', 'c'].includes(lang)) {
				let depth = 0;
				for (let i = lineIdx - 1; i >= 0; i--) {
					const trimmed = lines[i].trim();
					const closeBraces = (trimmed.match(/\}/g) || []).length;
					const openBraces = (trimmed.match(/\{/g) || []).length;
					depth += closeBraces - openBraces;
					if (depth < 0 && /^\s*(for|while|do)\b/.test(lines[i])) {
						return true;
					}
				}
			}
			if (lang === 'python') {
				const indent = lines[lineIdx].match(/^(\s*)/)?.[1].length ?? 0;
				for (let i = lineIdx - 1; i >= 0; i--) {
					const prevIndent = lines[i].match(/^(\s*)/)?.[1].length ?? 0;
					if (prevIndent < indent && /^\s*(for|while)\b/.test(lines[i])) {
						return true;
					}
				}
			}
			return false;
		}

		function buildStepMap(sourceCode: string, outputLines: string[], lang: string): StepInfo[] {
			const lines = sourceCode.split('\n');
			const steps: StepInfo[] = [];
			const patterns = getOutputPatterns(lang);

			// First pass: identify output-producing lines and loop status
			interface SourceLine { lineNumber: number; isOutput: boolean; inLoop: boolean; }
			const sourceLines: SourceLine[] = [];

			for (let i = 0; i < lines.length; i++) {
				const trimmed = lines[i].trim();
				if (isSkippableLine(trimmed, lang)) continue;
				const isOutput = patterns.some(p => trimmed.includes(p));
				const inLoop = isOutput ? isLineInLoop(i, lines, lang) : false;
				sourceLines.push({ lineNumber: i + 1, isOutput, inLoop });
			}

			// Calculate how many outputs each line gets
			const outputProducing = sourceLines.filter(l => l.isOutput);
			const nonLoopOutputLines = outputProducing.filter(l => !l.inLoop);
			const loopOutputLines = outputProducing.filter(l => l.inLoop);
			const loopOutputCount = Math.max(0, outputLines.length - nonLoopOutputLines.length);

			// Map: lineNumber -> how many outputs it produces
			const outputCounts = new Map<number, number>();
			for (const line of nonLoopOutputLines) {
				outputCounts.set(line.lineNumber, 1);
			}
			if (loopOutputLines.length > 0) {
				const perLoopLine = Math.floor(loopOutputCount / loopOutputLines.length);
				let remainder = loopOutputCount % loopOutputLines.length;
				for (const line of loopOutputLines) {
					const count = perLoopLine + (remainder > 0 ? 1 : 0);
					if (remainder > 0) remainder--;
					outputCounts.set(line.lineNumber, count);
				}
			}

			// Build steps: non-output lines get 1 step, output lines get N steps (one per output)
			let outIdx = 0;
			for (const src of sourceLines) {
				if (!src.isOutput) {
					steps.push({ lineNumber: src.lineNumber, outputLines: [] });
				} else {
					const count = outputCounts.get(src.lineNumber) ?? 1;
					for (let j = 0; j < count; j++) {
						const output = outIdx < outputLines.length ? [outputLines[outIdx++]] : [];
						steps.push({ lineNumber: src.lineNumber, outputLines: output });
					}
				}
			}

			return steps;
		}

		function disableButtons() {
			runBtn.classList.add('opacity-50', 'pointer-events-none');
			debugBtn.classList.add('opacity-50', 'pointer-events-none');
		}

		function enableButtons() {
			runBtn.classList.remove('opacity-50', 'pointer-events-none');
			debugBtn.classList.remove('opacity-50', 'pointer-events-none');
		}

		function showStepControls() {
			stepControls.classList.remove('hidden');
		}

		function hideStepControls() {
			stepControls.classList.add('hidden');
		}

		function exitStepMode() {
			stepMode = false;
			stepIndex = -1;
			stepData = [];
			highlightLine(null);
			setEditorEditable(true);
			hideStepControls();
			enableButtons();
			setTerminalContent('<div class="text-slate-500 italic text-xs">// Esperando ejecución...</div>');
		}

		// ── Event Handlers ──

		// RUN button
		runBtn.addEventListener('click', async () => {
			if (stepMode) return;
			disableButtons();
			runBtn.innerHTML = `<span class="inline-block w-4 h-4 border-2 border-background-dark border-t-transparent rounded-full animate-spin"></span> RUN`;

			const code = getCode();
			if (currentLang === 'javascript') {
				await runJavaScript(code);
			} else {
				await runWithJudge0(code, currentLang);
			}

			enableButtons();
			runBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M8 5v14l11-7z"/></svg> RUN`;
		});

		// DEBUG button
		debugBtn.addEventListener('click', async () => {
			if (stepMode) return;
			disableButtons();
			debugBtn.innerHTML = `<span class="inline-block w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin"></span> DEBUG`;

			const code = getCode();
			const className = currentLang === 'java' ? extractJavaClassName(code) : 'Main';
			const runCmd = getRunCommand(currentLang, className);
			let outputLines: string[] = [];
			let hasError = false;

			setTerminalContent('');
			showCommand(runCmd);
			appendTerminalLine('Ejecutando código...', 'text-yellow-400 animate-pulse');

			try {
				if (currentLang === 'javascript') {
					const result = await captureJavaScript(code);
					outputLines = result.outputs;
					if (result.error) {
						setTerminalContent('');
						showCommand(runCmd);
						appendTerminalLine(result.error, 'text-red-400 font-medium');
						showPrompt();
						hasError = true;
					}
				} else {
					const result = await captureJudge0(code, currentLang);
					if (result.statusId !== 3) {
						setTerminalContent('');
						showCommand(runCmd);
						if (result.compileOutput) {
							appendTerminalLine('Error de compilación:', 'text-red-400 font-medium mt-1');
							for (const line of result.compileOutput.split('\n')) {
								if (line.trim()) appendTerminalLine(line, 'text-red-400');
							}
						}
						if (result.stderr) {
							for (const line of result.stderr.split('\n')) {
								if (line.trim()) appendTerminalLine(line, 'text-red-400');
							}
						}
						appendTerminalLine(`[${result.statusDesc}]`, 'text-yellow-400 mt-1');
						showPrompt();
						hasError = true;
					} else {
						outputLines = result.stdout.split('\n').filter(l => l !== '');
					}
				}
			} catch (e) {
				setTerminalContent('');
				showCommand(runCmd);
				appendTerminalLine('Error de conexión con el servidor:', 'text-red-400 font-medium');
				appendTerminalLine(e instanceof Error ? e.message : String(e), 'text-red-400');
				showPrompt();
				hasError = true;
			}

			debugBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M20 8h-2.81a5.985 5.985 0 0 0-1.82-1.96L17 4.41 15.59 3l-2.17 2.17C12.96 5.06 12.49 5 12 5c-.49 0-.96.06-1.41.17L8.41 3 7 4.41l1.62 1.63C7.88 6.55 7.26 7.22 6.81 8H4v2h2.09c-.05.33-.09.66-.09 1v1H4v2h2v1c0 .34.04.67.09 1H4v2h2.81c1.04 1.79 2.97 3 5.19 3s4.15-1.21 5.19-3H20v-2h-2.09c.05-.33.09-.66.09-1v-1h2v-2h-2v-1c0-.34-.04-.67-.09-1H20V8zm-6 8h-4v-2h4v2zm0-4h-4v-2h4v2z"/></svg> DEBUG`;

			if (hasError) {
				enableButtons();
				return;
			}

			// Enter step mode
			stepData = buildStepMap(code, outputLines, currentLang);
			stepMode = true;
			stepIndex = -1;
			setEditorEditable(false);
			showStepControls();
			stepCounter.textContent = `Paso 0 / ${stepData.length}`;

			setTerminalContent('');
			showCommand(runCmd);
			appendTerminalLine('Modo paso a paso. Presioná "Siguiente" para avanzar.', 'text-accent-blue');
		});

		// Step Next
		stepNextBtn.addEventListener('click', () => {
			if (!stepMode) return;

			if (stepIndex >= stepData.length - 1) {
				appendTerminalLine('', 'text-slate-600');
				appendTerminalLine('--- Ejecución completada ---', 'text-primary font-medium');
				showPrompt();
				highlightLine(null);
				stepCounter.textContent = `Completado`;
				return;
			}

			stepIndex++;
			const step = stepData[stepIndex];
			highlightLine(step.lineNumber);
			stepCounter.textContent = `Paso ${stepIndex + 1} / ${stepData.length}`;

			for (const outputLine of step.outputLines) {
				appendTerminalLine(outputLine, 'text-slate-300');
			}
		});

		// Step Reset
		stepResetBtn.addEventListener('click', () => {
			exitStepMode();
		});

		clearBtn.addEventListener('click', () => {
			if (stepMode) return;
			setTerminalContent('<div class="text-slate-500 italic text-xs">// Esperando ejecución...</div>');
		});

		// Language switcher
		toggle.addEventListener('click', () => menu.classList.toggle('hidden'));

		document.querySelectorAll('.lang-option').forEach((option) => {
			option.addEventListener('click', () => {
				if (stepMode) exitStepMode();

				const lang = option.getAttribute('data-lang') ?? 'javascript';
				const file = option.getAttribute('data-file') ?? 'main.js';
				const labels: Record<string, string> = { javascript: 'JavaScript', java: 'Java', c: 'C', python: 'Python' };
				const label = labels[lang] ?? lang;

				currentLang = lang;
				langLabel.textContent = label;
				fileNameEl.textContent = file;
				footerLang.textContent = label;

				// Cambiar lenguaje de CodeMirror
				editorView.dispatch({
					effects: langCompartment.reconfigure(
						lang === 'java' ? java() : lang === 'c' ? cpp() : lang === 'python' ? python() : javascript()
					)
				});
				setCode(defaultCodes[lang]);
				stdinInput.value = '';
				updateStdinVisibility(defaultCodes[lang]);
				setTerminalContent('<div class="text-slate-500 italic text-xs">// Esperando ejecución...</div>');
				menu.classList.add('hidden');
			});
		});

		document.addEventListener('click', (e) => {
			const dropdown = document.getElementById('lang-dropdown');
			if (dropdown && !dropdown.contains(e.target as Node)) {
				menu.classList.add('hidden');
			}
		});
	</script>
</Layout>
