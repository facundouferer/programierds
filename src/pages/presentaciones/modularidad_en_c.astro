							<div class="code-block text-sm mb-4">
<span class="code-func">calcular</span>(<span style="border-bottom:2px solid #f59e0b; color:#fcd34d">10</span>, <span style="border-bottom:2px solid #f59e0b; color:#fcd34d">20</span>);
