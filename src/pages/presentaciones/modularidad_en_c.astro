					<div class="anim-item code-block text-xs" style="--delay: 150ms; line-height: 1.8">
<span class="code-keyword">#include</span> <span class="code-string">&lt;stdio.h&gt;</span><br><br>
<span class="code-comment">// GLOBAL: visible en todas las funciones</span><br>
<span class="code-type">int</span> <span class="code-var" style="color:#fcd34d">llamadas</span> = <span class="code-number">0</span>;<br><br>
<span class="code-comment">// FUNCIÓN: retorna el área (por valor)</span><br>
<span class="code-type">int</span> <span class="code-func">areaRectangulo</span>(<span class="code-type">int</span> <span class="code-var">base</span>, <span class="code-type">int</span> <span class="code-var">altura</span>) &lbrace;<br>
<span style="padding-left:16px"><span class="code-var" style="color:#fcd34d">llamadas</span>++;                          <span class="code-comment">// modifica global</span></span><br>
<span style="padding-left:16px"><span class="code-type">int</span> <span class="code-var">area</span> = <span class="code-var">base</span> * <span class="code-var">altura</span>; <span class="code-comment">// LOCAL</span></span><br>
<span style="padding-left:16px"><span class="code-keyword">return</span> <span class="code-var">area</span>;</span><br>
&rbrace;<br><br>
<span class="code-comment">// PROCEDIMIENTO: imprime (void, sin retorno)</span><br>
<span class="code-keyword">void</span> <span class="code-func">imprimirResultado</span>(<span class="code-type">int</span> <span class="code-var">valor</span>) &lbrace;<br>
<span style="padding-left:16px"><span class="code-func">printf</span>(<span class="code-string">"Resultado: %d\n"</span>, <span class="code-var">valor</span>);</span><br>
&rbrace;<br><br>
<span class="code-comment">// POR REFERENCIA: duplica el original</span><br>
<span class="code-keyword">void</span> <span class="code-func">duplicar</span>(<span class="code-type">int</span> *<span class="code-var" style="color:#f0abfc">p</span>) &lbrace;<br>
<span style="padding-left:16px">*<span class="code-var" style="color:#f0abfc">p</span> *= <span class="code-number">2</span>;</span><br>
&rbrace;<br><br>
<span class="code-type">int</span> <span class="code-func">main</span>() &lbrace;<br>
<span style="padding-left:16px"><span class="code-comment">// nominales: base, altura — efectivos: 5, 10</span></span><br>
<span style="padding-left:16px"><span class="code-type">int</span> <span class="code-var">area</span> = <span class="code-func">areaRectangulo</span>(<span class="code-number">5</span>, <span class="code-number">10</span>);</span><br>
<span style="padding-left:16px"><span class="code-func">imprimirResultado</span>(<span class="code-var">area</span>); <span class="code-comment">// 50</span></span><br><br>
<span style="padding-left:16px"><span class="code-func">duplicar</span>(&amp;<span class="code-var">area</span>);          <span class="code-comment">// pasa dirección — por referencia</span></span><br>
<span style="padding-left:16px"><span class="code-func">imprimirResultado</span>(<span class="code-var">area</span>); <span class="code-comment">// 100</span></span><br><br>
<span style="padding-left:16px"><span class="code-func">printf</span>(<span class="code-string">"Llamadas: %d\n"</span>, <span class="code-var" style="color:#fcd34d">llamadas</span>); <span class="code-comment">// 1</span></span><br>
<span style="padding-left:16px"><span class="code-keyword">return</span> <span class="code-number">0</span>;</span><br>
&rbrace;
					</div>

