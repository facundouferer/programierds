---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import { getRelativePath } from '../../utils/paths';
---

<Layout title="Modularización en C - Programierds Retro View">
	<style is:global>
		@import url('https://fonts.googleapis.com/css2?family=VT323&family=Space+Mono:wght@400;700&display=swap');

		:root {
			--primary: #0df259;
			--crt-black: #050a05;
			--crt-dark: #0a140a;
		}

		html {
			scroll-behavior: smooth;
		}

		.crt-wrapper {
			background: radial-gradient(circle, #0a1a0a 0%, #050a05 100%);
			position: relative;
		}

		.crt-main {
			font-family: 'Space Mono', monospace;
			color: var(--primary);
			position: relative;
		}

		.font-retro {
			font-family: 'VT323', monospace;
		}

		/* Progress bar */
		#progress-bar {
			position: fixed;
			top: 0;
			left: 0;
			height: 3px;
			width: 0%;
			background: var(--primary);
			box-shadow: 0 0 10px var(--primary), 0 0 20px var(--primary);
			z-index: 200;
			transition: width 0.1s linear;
		}

		/* Sections */
		.section {
			min-height: 100vh;
			display: flex;
			align-items: center;
			justify-content: center;
			padding: 80px 24px 40px;
			position: relative;
			z-index: 10;
		}

		.section-inner {
			width: 100%;
			max-width: 1100px;
		}

		/* Reveal animations */
		.section-hidden {
			opacity: 0;
			transform: translateY(60px);
			transition: opacity 0.8s ease, transform 0.8s ease;
		}

		.section-visible {
			opacity: 1;
			transform: translateY(0);
		}

		.anim-item {
			opacity: 0;
			transform: translateY(30px);
			transition: opacity 0.6s ease, transform 0.6s ease;
			transition-delay: var(--delay, 0ms);
		}

		.section-visible .anim-item {
			opacity: 1;
			transform: translateY(0);
		}

		/* Divider */
		.section-divider {
			border: none;
			border-top: 1px solid rgba(13, 242, 89, 0.15);
			margin: 0 24px;
		}

		/* Code block */
		.code-block {
			background: rgba(0, 0, 0, 0.5);
			border: 1px solid rgba(13, 242, 89, 0.2);
			border-radius: 4px;
			padding: 16px 20px;
			font-family: 'Space Mono', monospace;
			font-size: 0.85rem;
			line-height: 1.7;
		}

		.code-comment  { color: rgba(13, 242, 89, 0.4); font-style: italic; }
		.code-keyword  { color: #61afef; }
		.code-string   { color: #e5c07b; }
		.code-number   { color: #d19a66; }
		.code-result   { color: var(--primary); }
		.code-type     { color: #c678dd; }
		.code-func     { color: #98c379; }
		.code-var      { color: #e06c75; }

		/* Split columns */
		.split-col {
			border: 1px solid rgba(13, 242, 89, 0.2);
			border-radius: 8px;
			padding: 24px;
			background: rgba(13, 242, 89, 0.03);
		}

		.split-col-blue {
			border: 1px solid rgba(59, 130, 246, 0.3);
			border-radius: 8px;
			padding: 24px;
			background: rgba(59, 130, 246, 0.04);
		}

		.split-col-amber {
			border: 1px solid rgba(251, 191, 36, 0.35);
			border-radius: 8px;
			padding: 24px;
			background: rgba(251, 191, 36, 0.04);
		}

		.split-col-red {
			border: 1px solid rgba(239, 68, 68, 0.4);
			border-radius: 8px;
			padding: 24px;
			background: rgba(239, 68, 68, 0.05);
		}

		/* Type / info card */
		.type-card {
			border: 1px solid rgba(13, 242, 89, 0.25);
			background: rgba(13, 242, 89, 0.04);
			border-radius: 6px;
			padding: 12px 16px;
			transition: border-color 0.3s, box-shadow 0.3s;
		}

		.type-card:hover {
			border-color: var(--primary);
			box-shadow: 0 0 12px rgba(13, 242, 89, 0.2);
		}

		/* Terminal button */
		.terminal-btn {
			border: 1px solid var(--primary);
			padding: 8px 24px;
			text-transform: uppercase;
			font-size: 0.875rem;
			font-weight: 700;
			transition: all 0.3s;
			background-color: rgba(13, 242, 89, 0.05);
			color: var(--primary);
			text-decoration: none;
			display: inline-block;
			font-family: 'Space Mono', monospace;
			letter-spacing: 0.05em;
		}

		.terminal-btn:hover {
			background-color: var(--primary);
			color: black;
			box-shadow: 0 0 20px rgba(13, 242, 89, 0.5);
		}

		/* ==================== KEYFRAMES ==================== */

		@keyframes float {
			0%, 100% { transform: translateY(0px); }
			50% { transform: translateY(-12px); }
		}

		@keyframes float-slow {
			0%, 100% { transform: translateY(0px) rotate(0deg); }
			50% { transform: translateY(-18px) rotate(3deg); }
		}

		@keyframes blink-cursor {
			0%, 100% { opacity: 1; }
			50% { opacity: 0; }
		}

		@keyframes spin-slow {
			from { transform: rotate(0deg); }
			to { transform: rotate(360deg); }
		}

		@keyframes spin-reverse {
			from { transform: rotate(360deg); }
			to { transform: rotate(0deg); }
		}

		@keyframes typing-sub {
			from { width: 0; opacity: 1; }
			to { width: 100%; opacity: 1; }
		}

		@keyframes copy-fly {
			0%   { transform: translateX(0) scale(1); opacity: 1; }
			50%  { transform: translateX(80px) scale(1.2); opacity: 0.8; }
			100% { transform: translateX(160px) scale(1); opacity: 1; }
		}

		@keyframes dissolve {
			0%   { opacity: 1; transform: scale(1); }
			50%  { opacity: 0.5; transform: scale(1.05); filter: blur(2px); }
			100% { opacity: 0; transform: scale(0.8); filter: blur(6px); }
		}

		@keyframes appear {
			from { opacity: 0; transform: scale(0.7) translateY(10px); }
			to   { opacity: 1; transform: scale(1) translateY(0); }
		}

		@keyframes pulse-border-amber {
			0%, 100% { box-shadow: 0 0 8px #f59e0b, 0 0 16px #f59e0b; border-color: #f59e0b; }
			50%       { box-shadow: 0 0 20px #f59e0b, 0 0 40px #f59e0b; border-color: #fcd34d; }
		}

		@keyframes pulse-border-magenta {
			0%, 100% { box-shadow: 0 0 8px #d946ef, 0 0 16px #d946ef; border-color: #d946ef; }
			50%       { box-shadow: 0 0 20px #d946ef, 0 0 40px #d946ef; border-color: #f0abfc; }
		}

		@keyframes arrow-flow {
			0%   { opacity: 0; transform: translateX(-6px); }
			50%  { opacity: 1; }
			100% { opacity: 0; transform: translateX(6px); }
		}

		/* ==================== SECTION 1: INTRO ==================== */

		.intro-title {
			font-family: 'VT323', monospace;
			font-size: clamp(2.5rem, 7vw, 5.5rem);
			text-shadow: 0 0 15px rgba(13, 242, 89, 0.7);
			line-height: 1;
		}

		.intro-subtitle {
			font-size: clamp(0.85rem, 1.8vw, 1.1rem);
			opacity: 0;
			overflow: hidden;
			white-space: nowrap;
			border-right: 2px solid var(--primary);
		}

		.intro-subtitle.typing-active {
			animation: typing-sub 3s steps(70) 0.5s forwards, blink-cursor 0.7s step-end infinite;
			width: 0;
		}

		.gear {
			display: inline-block;
			color: var(--primary);
			opacity: 0.7;
			text-shadow: 0 0 20px rgba(13, 242, 89, 0.5);
		}

		.gear-1 { animation: spin-slow 8s linear infinite; font-size: clamp(3rem, 8vw, 6rem); }
		.gear-2 { animation: spin-reverse 5s linear infinite; font-size: clamp(2rem, 5vw, 4rem); opacity: 0.5; }
		.gear-3 { animation: spin-slow 12s linear infinite; font-size: clamp(1.5rem, 4vw, 3rem); opacity: 0.4; }

		/* ==================== SECTION 2: MODULARIZAR ==================== */

		.monolith-block {
			border: 2px solid rgba(239, 68, 68, 0.5);
			border-radius: 6px;
			padding: 16px;
			background: rgba(239, 68, 68, 0.05);
			font-family: 'Space Mono', monospace;
			font-size: 0.7rem;
			line-height: 1.6;
			color: #ef4444;
			min-height: 200px;
			display: flex;
			flex-direction: column;
			gap: 2px;
		}

		.module-piece {
			border-radius: 4px;
			padding: 8px 12px;
			font-family: 'Space Mono', monospace;
			font-size: 0.75rem;
			font-weight: 700;
			text-align: center;
			transition: transform 0.3s, box-shadow 0.3s;
		}

		.module-piece:hover { transform: scale(1.05); }

		.mod-green  { background: rgba(13, 242, 89, 0.15);  border: 1px solid rgba(13, 242, 89, 0.5);  color: #0df259; }
		.mod-blue   { background: rgba(59, 130, 246, 0.15); border: 1px solid rgba(59, 130, 246, 0.5); color: #93c5fd; }
		.mod-purple { background: rgba(168, 85, 247, 0.15); border: 1px solid rgba(168, 85, 247, 0.5); color: #c4b5fd; }
		.mod-amber  { background: rgba(251, 191, 36, 0.15); border: 1px solid rgba(251, 191, 36, 0.5); color: #fcd34d; }
		.mod-pink   { background: rgba(236, 72, 153, 0.15); border: 1px solid rgba(236, 72, 153, 0.5); color: #f9a8d4; }

		/* ==================== STACK / LOCALES ==================== */

		.stack-frame {
			border: 2px solid #06b6d4;
			border-radius: 6px;
			padding: 12px 16px;
			background: rgba(6, 182, 212, 0.05);
			margin-bottom: 8px;
			transition: all 0.5s ease;
		}

		.stack-frame-title {
			font-family: 'VT323', monospace;
			font-size: 1rem;
			color: #67e8f9;
			margin-bottom: 6px;
			letter-spacing: 0.08em;
		}

		.stack-var {
			display: inline-block;
			border: 1px solid #06b6d4;
			border-radius: 3px;
			padding: 2px 8px;
			margin: 2px;
			font-size: 0.75rem;
			color: #a5f3fc;
			background: rgba(6, 182, 212, 0.08);
		}

		/* ==================== GLOBALES ==================== */

		.global-box {
			border: 2px solid #f59e0b;
			border-radius: 8px;
			padding: 16px 20px;
			background: rgba(245, 158, 11, 0.06);
			text-align: center;
			animation: pulse-border-amber 2.5s ease-in-out infinite;
		}

		.global-arrow {
			color: #f59e0b;
			animation: arrow-flow 1.5s ease-in-out infinite;
			display: inline-block;
		}

		/* ==================== MEMORY BOXES ==================== */

		.mem-box {
			border-radius: 6px;
			padding: 12px 16px;
			font-family: 'Space Mono', monospace;
			font-size: 0.8rem;
			text-align: center;
			position: relative;
			transition: all 0.4s ease;
			min-width: 120px;
		}

		.mem-box-local {
			border: 2px solid #06b6d4;
			background: rgba(6, 182, 212, 0.08);
			color: #a5f3fc;
		}

		.mem-box-pointer {
			border: 2px solid #d946ef;
			background: rgba(217, 70, 239, 0.08);
			color: #f0abfc;
			animation: pulse-border-magenta 2s ease-in-out infinite;
		}

		.mem-address {
			font-size: 0.65rem;
			opacity: 0.6;
			margin-bottom: 4px;
			color: #fb923c;
		}

		.mem-label {
			font-weight: 700;
			font-size: 0.9rem;
		}

		.mem-value {
			font-size: 1.3rem;
			font-family: 'VT323', monospace;
			margin-top: 4px;
		}

		/* ==================== STEP INDICATORS ==================== */

		.step-indicator {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			width: 28px;
			height: 28px;
			border-radius: 50%;
			border: 1px solid rgba(13, 242, 89, 0.4);
			font-family: 'VT323', monospace;
			font-size: 1.1rem;
			color: var(--primary);
			flex-shrink: 0;
		}

		.step-active .step-indicator {
			background: var(--primary);
			color: black;
			border-color: var(--primary);
			box-shadow: 0 0 12px rgba(13, 242, 89, 0.5);
		}

		.flow-arrow {
			display: flex;
			align-items: center;
			justify-content: center;
			padding: 0 12px;
			font-size: 1.4rem;
			color: rgba(13, 242, 89, 0.5);
		}

		.step-hidden { opacity: 0.15; transition: opacity 0.5s; }
		.step-active { opacity: 1; transition: opacity 0.5s; }

		/* ==================== NOMINALES / EFECTIVOS ==================== */

		.param-badge-nominal {
			display: inline-block;
			border: 1px solid rgba(13, 242, 89, 0.5);
			background: rgba(13, 242, 89, 0.1);
			border-radius: 4px;
			padding: 4px 12px;
			font-size: 0.8rem;
			color: var(--primary);
			font-family: 'Space Mono', monospace;
			margin: 3px;
		}

		.param-badge-effective {
			display: inline-block;
			border: 1px solid rgba(251, 191, 36, 0.5);
			background: rgba(251, 191, 36, 0.1);
			border-radius: 4px;
			padding: 4px 12px;
			font-size: 0.8rem;
			color: #fcd34d;
			font-family: 'Space Mono', monospace;
			margin: 3px;
		}

		/* ==================== REGLAS ==================== */

		.rule-card {
			border: 1px solid rgba(13, 242, 89, 0.2);
			border-radius: 6px;
			padding: 16px 20px;
			background: rgba(13, 242, 89, 0.03);
			display: flex;
			align-items: flex-start;
			gap: 12px;
			transition: border-color 0.3s, box-shadow 0.3s, background 0.3s;
		}

		.rule-card:hover {
			border-color: var(--primary);
			background: rgba(13, 242, 89, 0.06);
			box-shadow: 0 0 16px rgba(13, 242, 89, 0.15);
		}

		.rule-num {
			font-family: 'VT323', monospace;
			font-size: 2rem;
			color: var(--primary);
			opacity: 0.5;
			line-height: 1;
			flex-shrink: 0;
		}

		/* Warning box */
		.warning-box {
			border: 2px solid rgba(239, 68, 68, 0.5);
			border-radius: 6px;
			padding: 14px 18px;
			background: rgba(239, 68, 68, 0.06);
			color: #fca5a5;
		}

		/* Comparison table */
		.cmp-table {
			width: 100%;
			border-collapse: separate;
			border-spacing: 0 4px;
			font-size: 0.8rem;
		}

		.cmp-table th {
			padding: 8px 12px;
			font-size: 0.7rem;
			letter-spacing: 0.1em;
			color: rgba(13, 242, 89, 0.5);
			border-bottom: 1px solid rgba(13, 242, 89, 0.15);
			text-align: left;
		}

		.cmp-table td {
			padding: 10px 12px;
			border-bottom: 1px solid rgba(13, 242, 89, 0.07);
			vertical-align: middle;
		}

		.cmp-table tr:hover td {
			background: rgba(13, 242, 89, 0.04);
		}

		/* Responsive */
		@media (max-width: 768px) {
			.split-grid { flex-direction: column !important; }
			.intro-title { font-size: 2.5rem; }
		}
	</style>

	<div class="crt-wrapper min-h-screen flex flex-col">
		<!-- Progress bar -->
		<div id="progress-bar"></div>

		<div class="relative z-[200]">
			<Header />
		</div>

		<main class="flex-1 crt-main">

			<!-- ======================== SECTION 1: INTRO ======================== -->
			<section class="section section-hidden" id="sec-intro">
				<div class="section-inner text-center">
					<div class="anim-item" style="--delay: 0ms">
						<div class="text-xs tracking-widest opacity-40 font-retro text-lg">PROGRAMIERDS_OS v1.0.4 // TOPIC: MODULARIDAD_C</div>
					</div>

					<div class="anim-item flex justify-center items-center gap-6 my-8" style="--delay: 100ms">
						<span class="gear gear-1">&#x2699;</span>
						<span class="gear gear-2">&#x2699;</span>
						<span class="gear gear-3">&#x2699;</span>
					</div>

					<div class="anim-item" style="--delay: 200ms">
						<h1 class="intro-title uppercase tracking-tight mb-2">
							Modularizaci&oacute;n
						</h1>
						<h1 class="intro-title uppercase tracking-tight mb-8" style="color: rgba(13,242,89,0.6)">
							en C
						</h1>
					</div>

					<div class="anim-item flex justify-center" style="--delay: 400ms">
						<p class="intro-subtitle" id="intro-subtitle">
							Subprogramas, Funciones, Procedimientos y el arte de dividir para conquistar.
						</p>
					</div>

					<div class="anim-item mt-12 opacity-50" style="--delay: 600ms">
						<p class="text-sm" style="animation: float 2s ease-in-out infinite">&#8595; scroll para continuar</p>
					</div>
				</div>
			</section>

			<hr class="section-divider" />

			<!-- ======================== SECTION 2: QUÉ ES MODULARIZAR ======================== -->
			<section class="section section-hidden" id="sec-modularizar">
				<div class="section-inner">
					<div class="anim-item text-center mb-10" style="--delay: 0ms">
						<h2 class="font-retro text-4xl md:text-6xl uppercase tracking-tight">
							&iquest;Qu&eacute; es Modularizar?
						</h2>
						<p class="text-sm opacity-50 mt-2">Dividir un problema grande en partes peque&ntilde;as y manejables</p>
					</div>

					<div class="flex gap-8 split-grid" style="align-items: stretch">
						<!-- Monolito -->
						<div class="flex-1 anim-item" style="--delay: 150ms">
							<h3 class="font-retro text-2xl text-center mb-4" style="color: #ef4444">&#x2718; El Monolito</h3>
							<div class="monolith-block">
								<span style="opacity:0.6"><span class="code-comment">// main.c — 500 líneas de terror</span></span>
								<span><span class="code-keyword">int</span> main() &lbrace;</span>
								<span style="padding-left:16px; color:#ef4444">// leer datos...</span>
								<span style="padding-left:16px; color:#ef4444">// validar entrada...</span>
								<span style="padding-left:16px; color:#ef4444">// calcular resultado...</span>
								<span style="padding-left:16px; color:#ef4444">// formatear salida...</span>
								<span style="padding-left:16px; color:#ef4444">// guardar en archivo...</span>
								<span style="padding-left:16px; color:#ef4444">// imprimir por pantalla...</span>
								<span style="padding-left:16px; color:#ef4444">// ... 490 líneas más</span>
								<span>&rbrace;</span>
								<div style="margin-top: 8px; font-family:'VT323',monospace; font-size:0.85rem; color: rgba(239,68,68,0.6)">
									Un solo bloque gigante. Si algo falla, todo explota.
								</div>
							</div>
						</div>

						<!-- Modular -->
						<div class="flex-1 anim-item" style="--delay: 300ms">
							<h3 class="font-retro text-2xl text-center mb-4" style="color: #0df259">&#x2714; Modularizado</h3>
							<div class="split-col" style="height: calc(100% - 44px)">
								<div class="flex flex-col gap-3">
									<div class="module-piece mod-green anim-item" style="--delay: 400ms">leerDatos()</div>
									<div class="module-piece mod-blue anim-item" style="--delay: 500ms">validarEntrada()</div>
									<div class="module-piece mod-purple anim-item" style="--delay: 600ms">calcularResultado()</div>
									<div class="module-piece mod-amber anim-item" style="--delay: 700ms">formatearSalida()</div>
									<div class="module-piece mod-pink anim-item" style="--delay: 800ms">guardarArchivo()</div>
								</div>
								<div style="margin-top: 12px; font-family:'VT323',monospace; font-size:0.85rem; color: rgba(13,242,89,0.6)">
									Piezas peque&ntilde;as, independientes, reutilizables. Como LEGO.
								</div>
							</div>
						</div>
					</div>

					<div class="anim-item mt-6 type-card" style="--delay: 900ms">
						<p class="text-xs opacity-50 mb-1">ANALOG&Iacute;A</p>
						<p class="text-sm">No esculp&iacute;s desde una roca entera &mdash; construy&eacute;s con LEGO. Cada pieza tiene forma definida, encaja con otras, y la pod&eacute;s reusar en cualquier construcci&oacute;n.</p>
					</div>
				</div>
			</section>

			<hr class="section-divider" />

			<!-- ======================== SECTION 3: SUBPROGRAMAS ======================== -->
			<section class="section section-hidden" id="sec-subprogramas">
				<div class="section-inner">
					<div class="anim-item text-center mb-10" style="--delay: 0ms">
						<h2 class="font-retro text-4xl md:text-6xl uppercase tracking-tight">Subprogramas</h2>
						<p class="text-sm opacity-50 mt-2">En C, todo subprograma es una <strong>funci&oacute;n</strong>. No hay otra cosa.</p>
					</div>

					<div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-start">
						<!-- Anatomía -->
						<div class="anim-item" style="--delay: 150ms">
							<h3 class="font-retro text-2xl mb-6 text-center">Anatom&iacute;a de una Funci&oacute;n</h3>

							<div class="mb-6 space-y-2">
								<div style="display:flex; align-items:center; gap:8px">
									<span style="width:10px; height:10px; border-radius:50%; background:#c678dd; flex-shrink:0; display:inline-block"></span>
