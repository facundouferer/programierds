<span class="code-keyword">void</span> <span class="code-func">cambiar</span>(<span class="code-type">int</span> *<span class="code-var" style="color:#f0abfc">p</span>) &lbrace;<br>
<span style="padding-left:16px">*<span class="code-var" style="color:#f0abfc">p</span> = <span class="code-number">10</span>; <span class="code-comment">// desreferencia: modifica lo que apunta</span></span><br>
&rbrace;<br><br>
<span class="code-type">int</span> <span class="code-func">main</span>() &lbrace;<br>
<span style="padding-left:16px"><span class="code-type">int</span> <span class="code-var">x</span> = <span class="code-number">5</span>;</span><br>
<span style="padding-left:16px"><span class="code-func">cambiar</span>(&amp;<span class="code-var">x</span>);        <span class="code-comment">// pasa la DIRECCIÓN de x</span></span><br>
<span style="padding-left:16px"><span class="code-func">printf</span>(<span class="code-string">"%d"</span>, <span class="code-var">x</span>); <span class="code-comment">// imprime 10 — fue modificado</span></span><br>
&rbrace;
					</div>
