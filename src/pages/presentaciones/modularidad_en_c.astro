					</div>

					<div class="anim-item code-block text-xs" style="--delay: 200ms">
<span class="code-keyword">void</span> <span class="code-func">inc</span>(<span class="code-type">int</span> <span class="code-var">n</span>) &lbrace;<br>
<span style="padding-left:16px"><span class="code-var">n</span>++; <span class="code-comment">// modifica la copia, no el original</span></span><br>
&rbrace;<br><br>
<span class="code-type">int</span> <span class="code-func">main</span>() &lbrace;<br>
<span style="padding-left:16px"><span class="code-type">int</span> <span class="code-var">x</span> = <span class="code-number">5</span>;</span><br>
<span style="padding-left:16px"><span class="code-func">inc</span>(<span class="code-var">x</span>);              <span class="code-comment">// pasa una COPIA de x</span></span><br>
<span style="padding-left:16px"><span class="code-func">printf</span>(<span class="code-string">"%d"</span>, <span class="code-var">x</span>); <span class="code-comment">// imprime 5 — sin cambios</span></span><br>
&rbrace;
					</div>
				</div>
			</section>

