<span class="code-func">calcular</span>(<span style="color:#fcd34d">10</span>, <span style="color:#fcd34d">20</span>);<br>
<span class="code-comment">// base=10, altura=20 → resultado = 200</span><br><br>
<span class="code-comment">// El orden SÍ importa en muchos casos:</span><br>
<span class="code-func">dividir</span>(<span class="code-number">10</span>, <span class="code-number">2</span>);  <span class="code-comment">// 10 / 2 = 5</span><br>
<span class="code-func">dividir</span>(<span class="code-number">2</span>, <span class="code-number">10</span>);  <span class="code-comment">// 2 / 10 = 0  (resultado MUY diferente)</span>
