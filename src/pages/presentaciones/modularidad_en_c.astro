				<div class="section-inner text-center">
					<div class="anim-item" style="--delay: 0ms">
						<div class="text-xs tracking-widest opacity-30 font-retro text-lg mb-8">EOF // END_OF_PRESENTATION</div>
					</div>

					<div class="anim-item" style="--delay: 150ms">
						<div class="font-retro" style="font-size:clamp(3rem,10vw,8rem); text-shadow: 0 0 30px rgba(13,242,89,0.6); animation: float-slow 4s ease-in-out infinite">
							&gt;_
						</div>
					</div>

					<div class="anim-item mt-4" style="--delay: 300ms">
						<h2 class="font-retro text-4xl md:text-6xl uppercase tracking-tight">SESI&Oacute;N FINALIZADA</h2>
					</div>

					<div class="anim-item mt-4 mb-10" style="--delay: 450ms">
						<p class="text-sm opacity-50">Ahora sab&eacute;s modularizar en C. Ahora pens&aacute; en m&oacute;dulos.</p>
					</div>

					<div class="anim-item" style="--delay: 600ms">
						<a href={getRelativePath('/presentaciones')} class="terminal-btn">
							&#x2190; Volver a Presentaciones
						</a>
					</div>

					<div class="anim-item mt-16 opacity-20" style="--delay: 800ms">
						<p class="font-retro text-sm tracking-widest">PROGRAMIERDS &mdash; 2026</p>
					</div>
				</div>
			</section>

		</main>
	</div>

	<script>
		// ==================== PROGRESS BAR ====================
		const progressBar = document.getElementById('progress-bar') as HTMLElement;

		function updateProgressBar(): void {
			const scrollTop = window.scrollY;
			const docHeight = document.documentElement.scrollHeight - window.innerHeight;
			const pct = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
			progressBar.style.width = `${pct}%`;
		}

		window.addEventListener('scroll', updateProgressBar, { passive: true });

		// ==================== INTRO TYPING ====================
		function initIntroTyping(): void {
			const el = document.getElementById('intro-subtitle');
			if (el) el.classList.add('typing-active');
		}

		// ==================== INTERSECTION OBSERVER ====================
		const hiddenSections = document.querySelectorAll<HTMLElement>('.section-hidden');

		let valorAnimTriggered = false;
		let refAnimTriggered   = false;

		function triggerValorAnimation(): void {
			if (valorAnimTriggered) return;
			valorAnimTriggered = true;

			const stepIds = ['valor-step-0', 'valor-step-1', 'valor-step-2', 'valor-step-3', 'valor-step-4'];

			const boxN   = document.getElementById('box-inc-n') as HTMLElement | null;
			const valN   = document.getElementById('val-inc-n') as HTMLElement | null;
			const incFrm = document.getElementById('inc-frame') as HTMLElement | null;
			const mainB  = document.getElementById('box-main-x') as HTMLElement | null;

			setTimeout(() => {
				const s = document.getElementById(stepIds[0]);
				if (s) { s.classList.remove('step-hidden'); s.classList.add('step-active'); }
			}, 300);

			setTimeout(() => {
				const s = document.getElementById(stepIds[1]);
				if (s) { s.classList.remove('step-hidden'); s.classList.add('step-active'); }
				if (boxN) boxN.style.animation = 'appear 0.6s ease forwards';
			}, 1200);

			setTimeout(() => {
				const s = document.getElementById(stepIds[2]);
				if (s) { s.classList.remove('step-hidden'); s.classList.add('step-active'); }
				if (valN) { valN.textContent = '6'; valN.style.color = '#e06c75'; }
				if (boxN) { boxN.style.borderColor = '#e06c75'; }
			}, 2200);

			setTimeout(() => {
				const s = document.getElementById(stepIds[3]);
				if (s) { s.classList.remove('step-hidden'); s.classList.add('step-active'); }
				if (incFrm) incFrm.style.animation = 'dissolve 1s ease forwards';
			}, 3200);

			setTimeout(() => {
				const s = document.getElementById(stepIds[4]);
				if (s) { s.classList.remove('step-hidden'); s.classList.add('step-active'); }
				if (mainB) {
					mainB.style.borderColor = '#0df259';
					mainB.style.boxShadow = '0 0 16px rgba(13,242,89,0.5)';
				}
			}, 4400);
		}

		function triggerRefAnimation(): void {
			if (refAnimTriggered) return;
			refAnimTriggered = true;

			const stepIds = ['ref-step-0', 'ref-step-1', 'ref-step-2', 'ref-step-3', 'ref-step-4'];

			const refX    = document.getElementById('box-ref-x') as HTMLElement | null;
			const valRefX = document.getElementById('val-ref-x') as HTMLElement | null;
			const refP    = document.getElementById('box-ref-p') as HTMLElement | null;
			const refFrm  = document.getElementById('ref-frame') as HTMLElement | null;

			setTimeout(() => {
				const s = document.getElementById(stepIds[0]);
				if (s) { s.classList.remove('step-hidden'); s.classList.add('step-active'); }
			}, 300);

			setTimeout(() => {
				const s = document.getElementById(stepIds[1]);
				if (s) { s.classList.remove('step-hidden'); s.classList.add('step-active'); }
				if (refP) refP.style.animation = 'appear 0.6s ease forwards';
			}, 1200);

			setTimeout(() => {
				const s = document.getElementById(stepIds[2]);
				if (s) { s.classList.remove('step-hidden'); s.classList.add('step-active'); }
				if (refP) refP.style.boxShadow = '0 0 20px rgba(217,70,239,0.8)';
			}, 2200);

			setTimeout(() => {
				const s = document.getElementById(stepIds[3]);
				if (s) { s.classList.remove('step-hidden'); s.classList.add('step-active'); }
				if (refFrm) refFrm.style.animation = 'dissolve 1s ease forwards';
			}, 3200);

			setTimeout(() => {
				const s = document.getElementById(stepIds[4]);
				if (s) { s.classList.remove('step-hidden'); s.classList.add('step-active'); }
				if (valRefX) { valRefX.textContent = '10'; valRefX.style.color = '#fca5a5'; }
				if (refX) {
					refX.style.borderColor = '#fca5a5';
					refX.style.boxShadow = '0 0 16px rgba(252,165,165,0.5)';
				}
			}, 4400);
		}

		function triggerSectionAnimations(sectionId: string): void {
			switch (sectionId) {
				case 'sec-intro':
					initIntroTyping();
					break;
				case 'sec-por-valor':
					setTimeout(triggerValorAnimation, 400);
					break;
				case 'sec-por-ref':
					setTimeout(triggerRefAnimation, 400);
					break;
				default:
					break;
			}
		}

		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						const section = entry.target as HTMLElement;
						section.classList.remove('section-hidden');
						section.classList.add('section-visible');
						triggerSectionAnimations(section.id);
					}
				});
			},
			{ threshold: 0.2 }
		);

		hiddenSections.forEach((section) => observer.observe(section));

		// Initial check for sections already visible on load
		hiddenSections.forEach((section) => {
			const rect = section.getBoundingClientRect();
			if (rect.top < window.innerHeight * 0.85) {
				section.classList.remove('section-hidden');
				section.classList.add('section-visible');
				triggerSectionAnimations(section.id);
			}
		});

		updateProgressBar();
	</script>
</Layout>
