---
import Layout from '../../layouts/Layout.astro';
import { getRelativePath } from '../../utils/paths';
---

<Layout title="String paso a paso - Programierds">
	<style is:global>
		@import url('https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@400;500;600;700&family=Fira+Code:wght@400;500;700&display=swap');
		.st-screen {
			--st-primary: #06b6d4;
			--st-accent: #10b981;
			--st-bg: #05141a;
			min-height: 100vh;
			font-family: 'Chakra Petch', sans-serif;
			color: #e6feff;
			background: radial-gradient(circle at 78% 18%, rgba(6, 182, 212, 0.18), transparent 40%), linear-gradient(140deg, #02090b 0%, var(--st-bg) 100%);
		}
		.st-shell { max-width: 1180px; margin: 0 auto; padding: 2.2rem 1rem 3rem; }
		.st-title { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.05; }
		.st-sub { max-width: 66ch; color: rgba(230, 254, 255, 0.84); }
		.st-grid { display: grid; grid-template-columns: repeat(12, minmax(0, 1fr)); gap: 1rem; }
		.st-card { border-radius: 1rem; border: 1px solid rgba(6, 182, 212, 0.32); background: linear-gradient(160deg, rgba(7, 30, 37, 0.9), rgba(4, 19, 24, 0.94)); padding: 1rem; }
		.st-code, .st-state, .st-console { grid-column: span 12; }
		@media (min-width: 1100px) { .st-code { grid-column: span 6; } .st-state, .st-console { grid-column: span 3; } }
		.st-head { display: flex; justify-content: space-between; align-items: center; gap: 0.7rem; margin-bottom: 0.75rem; }
		.st-badge { border: 1px solid rgba(16, 185, 129, 0.45); background: rgba(16, 185, 129, 0.15); border-radius: 999px; padding: 0.2rem 0.6rem; font-size: 0.72rem; font-family: 'Fira Code', monospace; }
		.st-panel { background: rgba(2, 10, 13, 0.88); border: 1px solid rgba(6, 182, 212, 0.28); border-radius: 0.8rem; padding: 0.75rem; }
		.st-row { display: grid; grid-template-columns: 2rem 1fr; gap: 0.8rem; padding: 0.42rem 0.5rem; border-radius: 0.55rem; font-family: 'Fira Code', monospace; font-size: 0.87rem; color: rgba(230, 254, 255, 0.9); transition: all 0.2s ease; }
		.st-row.active { background: linear-gradient(90deg, rgba(6, 182, 212, 0.3), rgba(6, 182, 212, 0.08)); outline: 1px solid rgba(6, 182, 212, 0.45); transform: translateX(3px); }
		.st-ln { color: rgba(230, 254, 255, 0.42); text-align: right; }
		.st-state-item { display: flex; justify-content: space-between; border: 1px solid rgba(16, 185, 129, 0.3); background: rgba(16, 185, 129, 0.08); border-radius: 0.65rem; padding: 0.6rem 0.7rem; margin-bottom: 0.5rem; font-family: 'Fira Code', monospace; font-size: 0.82rem; }
		.st-value { color: var(--st-primary); font-size: 0.95rem; font-weight: 700; text-align: right; }
		.st-copy { margin-top: 0.8rem; border: 1px solid rgba(6, 182, 212, 0.34); background: rgba(6, 182, 212, 0.11); border-radius: 0.7rem; padding: 0.75rem; }
		.st-controls { margin-top: 0.9rem; display: flex; gap: 0.7rem; flex-wrap: wrap; align-items: center; }
		.st-btn { border: 1px solid rgba(6, 182, 212, 0.45); background: rgba(6, 182, 212, 0.14); color: #e6feff; border-radius: 0.7rem; padding: 0.55rem 1rem; font-weight: 600; transition: all 0.2s ease; }
		.st-btn:hover:not(:disabled) { background: rgba(6, 182, 212, 0.28); transform: translateY(-1px); }
		.st-btn:disabled { opacity: 0.4; cursor: not-allowed; }
		.st-select { border: 1px solid rgba(16, 185, 129, 0.45); background: rgba(2, 10, 13, 0.92); color: #e6feff; border-radius: 0.6rem; padding: 0.45rem 0.55rem; font-family: 'Fira Code', monospace; font-size: 0.75rem; }
		.st-track { margin-top: 0.8rem; height: 0.55rem; border-radius: 999px; background: rgba(230, 254, 255, 0.14); overflow: hidden; }
		.st-fill { height: 100%; width: 0%; background: linear-gradient(90deg, var(--st-primary), var(--st-accent)); transition: width 0.25s ease; }
		.st-console-win { border: 1px solid rgba(16, 185, 129, 0.35); border-radius: 0.8rem; overflow: hidden; background: rgba(2, 10, 13, 0.88); }
		.st-console-head { display: flex; justify-content: space-between; padding: 0.5rem 0.75rem; font-family: 'Fira Code', monospace; font-size: 0.72rem; background: rgba(16, 185, 129, 0.13); border-bottom: 1px solid rgba(16, 185, 129, 0.3); }
		.st-console-body { min-height: 160px; padding: 0.75rem; font-family: 'Fira Code', monospace; font-size: 0.82rem; }
		.st-log { opacity: 0; transform: translateY(8px); animation: st-log 0.35s ease forwards; color: #d6fff3; }
		@keyframes st-log { to { opacity: 1; transform: translateY(0); } }
		.st-back { display: inline-block; margin-top: 1.4rem; color: var(--st-accent); text-decoration: none; border-bottom: 1px dashed rgba(16, 185, 129, 0.5); }
	</style>

	<div class="st-screen">
		<main class="st-shell">
			<header class="mb-6">
				<p class="st-badge">string / paso a paso</p>
				<h1 class="st-title mt-3">String en JavaScript, linea por linea</h1>
				<p class="st-sub mt-3">En este ejemplo ves <code>length</code>, <code>toUpperCase()</code> y <code>slice()</code> con el valor de cada variable en cada linea.</p>
			</header>
			<section class="st-grid" aria-live="polite">
				<article class="st-card st-code">
					<div class="st-head"><strong>1) Codigo</strong><span class="st-badge" id="st-line">Linea activa: 1</span></div>
					<div class="st-panel">
						<div class="st-row" data-line="1"><span class="st-ln">1</span><span>const texto = 'Programierds';</span></div>
						<div class="st-row" data-line="2"><span class="st-ln">2</span><span>const largo = texto.length;</span></div>
						<div class="st-row" data-line="3"><span class="st-ln">3</span><span>const mayus = texto.toUpperCase();</span></div>
						<div class="st-row" data-line="4"><span class="st-ln">4</span><span>const parte = texto.slice(0, 4);</span></div>
						<div class="st-row" data-line="5"><span class="st-ln">5</span><span>console.log(largo);</span></div>
						<div class="st-row" data-line="6"><span class="st-ln">6</span><span>console.log(mayus);</span></div>
						<div class="st-row" data-line="7"><span class="st-ln">7</span><span>console.log(parte);</span></div>
					</div>
					<div class="st-copy" id="st-copy"><strong>Paso 1:</strong> Se crea <code>texto</code> con 'Programierds'.</div>
					<div class="st-track"><div class="st-fill" id="st-fill"></div></div>
					<div class="st-controls">
						<button class="st-btn" id="st-prev" type="button">⬅ Retroceder</button>
						<button class="st-btn" id="st-next" type="button">Avanzar ➡</button>
						<button class="st-btn" id="st-auto" type="button">Auto-play ▶</button>
						<select class="st-select" id="st-level" aria-label="Nivel de detalle">
							<option value="basico" selected>Basico</option>
							<option value="intermedio">Intermedio</option>
						</select>
						<span class="st-badge" id="st-step">Paso 1 / 7</span>
					</div>
				</article>
				<article class="st-card st-state">
					<div class="st-head"><strong>2) Variables</strong></div>
					<div class="st-state-item"><span>texto</span><span id="st-texto" class="st-value">Programierds</span></div>
					<div class="st-state-item"><span>largo</span><span id="st-largo" class="st-value">-</span></div>
					<div class="st-state-item"><span>mayus</span><span id="st-mayus" class="st-value">-</span></div>
					<div class="st-state-item"><span>parte</span><span id="st-parte" class="st-value">-</span></div>
				</article>
				<article class="st-card st-console">
					<div class="st-head"><strong>3) Consola simulada</strong></div>
					<div class="st-console-win">
						<div class="st-console-head"><span>node string-demo.js</span><span>stdout</span></div>
						<div class="st-console-body" id="st-console"></div>
					</div>
				</article>
			</section>
			<a class="st-back" href={getRelativePath('/presentaciones')}>← Volver a presentaciones</a>
		</main>
	</div>

	<script>
		type Step = { line: number; message: string; texto: string; largo: string; mayus: string; parte: string; logs: string[] };
		const baseSteps: Step[] = [
			{ line: 1, message: 'Se define texto.', texto: 'Programierds', largo: '-', mayus: '-', parte: '-', logs: [] },
			{ line: 2, message: 'Calcula length: Programierds tiene 11 caracteres.', texto: 'Programierds', largo: '11', mayus: '-', parte: '-', logs: [] },
			{ line: 3, message: 'toUpperCase crea una nueva cadena en mayusculas.', texto: 'Programierds', largo: '11', mayus: 'PROGRAMIERDS', parte: '-', logs: [] },
			{ line: 4, message: 'slice(0,4) toma desde indice 0 hasta antes del 4.', texto: 'Programierds', largo: '11', mayus: 'PROGRAMIERDS', parte: 'Prog', logs: [] },
			{ line: 5, message: 'Imprime largo.', texto: 'Programierds', largo: '11', mayus: 'PROGRAMIERDS', parte: 'Prog', logs: ['11'] },
			{ line: 6, message: 'Imprime mayus.', texto: 'Programierds', largo: '11', mayus: 'PROGRAMIERDS', parte: 'Prog', logs: ['11', 'PROGRAMIERDS'] },
			{ line: 7, message: 'Imprime parte.', texto: 'Programierds', largo: '11', mayus: 'PROGRAMIERDS', parte: 'Prog', logs: ['11', 'PROGRAMIERDS', 'Prog'] },
		];

		const buildIntermediateSteps = (steps: Step[]): Step[] => {
			const enriched: Step[] = [];
			steps.forEach((stepState, index) => {
				enriched.push(stepState);
				if (index < steps.length - 1) {
					enriched.push({ ...stepState, message: `Detalle intermedio: ${stepState.message}` });
				}
			});
			return enriched;
		};

		type Level = 'basico' | 'intermedio';
		const stepSets: Record<Level, Step[]> = {
			basico: baseSteps,
			intermedio: buildIntermediateSteps(baseSteps),
		};

		let currentLevel: Level = 'basico';
		let activeSteps: Step[] = stepSets[currentLevel];

		let currentStep = 0;
		const prev = document.getElementById('st-prev') as HTMLButtonElement;
		const next = document.getElementById('st-next') as HTMLButtonElement;
		const auto = document.getElementById('st-auto') as HTMLButtonElement;
		const levelSelect = document.getElementById('st-level') as HTMLSelectElement;
		const line = document.getElementById('st-line') as HTMLElement;
		const step = document.getElementById('st-step') as HTMLElement;
		const copy = document.getElementById('st-copy') as HTMLElement;
		const texto = document.getElementById('st-texto') as HTMLElement;
		const largo = document.getElementById('st-largo') as HTMLElement;
		const mayus = document.getElementById('st-mayus') as HTMLElement;
		const parte = document.getElementById('st-parte') as HTMLElement;
		const consoleBody = document.getElementById('st-console') as HTMLElement;
		const fill = document.getElementById('st-fill') as HTMLElement;
		let autoPlayTimer: number | null = null;

		function stopAutoPlay(): void {
			if (autoPlayTimer !== null) {
				window.clearInterval(autoPlayTimer);
				autoPlayTimer = null;
			}
			auto.textContent = 'Auto-play ▶';
		}

		function toggleAutoPlay(): void {
			if (autoPlayTimer !== null) {
				stopAutoPlay();
				return;
			}
			auto.textContent = 'Pausar ⏸';
			autoPlayTimer = window.setInterval(() => {
				if (currentStep < activeSteps.length - 1) {
					currentStep += 1;
					render();
				} else {
					stopAutoPlay();
				}
			}, 1300);
		}

		function render(): void {
			const state = activeSteps[currentStep];
			document.querySelectorAll<HTMLElement>('.st-row').forEach((row) => row.classList.toggle('active', Number(row.dataset.line) === state.line));
			line.textContent = `Linea activa: ${state.line}`;
			step.textContent = `Paso ${currentStep + 1} / ${activeSteps.length}`;
			copy.innerHTML = `<strong>Paso ${currentStep + 1}:</strong> ${state.message}`;
			texto.textContent = state.texto;
			largo.textContent = state.largo;
			mayus.textContent = state.mayus;
			parte.textContent = state.parte;
			consoleBody.innerHTML = '';
			state.logs.forEach((entry, index) => {
				const el = document.createElement('div');
				el.className = 'st-log';
				el.style.animationDelay = `${index * 80}ms`;
				el.textContent = `> ${entry}`;
				consoleBody.appendChild(el);
			});
			fill.style.width = `${((currentStep + 1) / activeSteps.length) * 100}%`;
			prev.disabled = currentStep === 0;
			next.disabled = currentStep === activeSteps.length - 1;
		}

		prev.addEventListener('click', () => { if (currentStep > 0) { currentStep -= 1; render(); } });
		next.addEventListener('click', () => { if (currentStep < activeSteps.length - 1) { currentStep += 1; render(); } });
		auto.addEventListener('click', () => toggleAutoPlay());
		levelSelect.addEventListener('change', () => {
			currentLevel = levelSelect.value as Level;
			activeSteps = stepSets[currentLevel];
			currentStep = 0;
			stopAutoPlay();
			render();
		});
		document.addEventListener('keydown', (event: KeyboardEvent) => { if (event.key === 'ArrowLeft') prev.click(); if (event.key === 'ArrowRight') next.click(); });
		render();
	</script>
</Layout>
