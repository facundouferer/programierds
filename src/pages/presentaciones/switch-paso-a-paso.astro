---
import Layout from '../../layouts/Layout.astro';
import { getRelativePath } from '../../utils/paths';
---

<Layout title="Switch paso a paso - Programierds">
	<style is:global>
		@import url('https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@400;500;600;700&family=Fira+Code:wght@400;500;700&display=swap');
		.sw-screen {
			--sw-primary: #8b5cf6;
			--sw-cyan: #22d3ee;
			--sw-bg: #120b22;
			min-height: 100vh;
			font-family: 'Chakra Petch', sans-serif;
			color: #f4edff;
			background: radial-gradient(circle at 80% 18%, rgba(139, 92, 246, 0.2), transparent 40%), linear-gradient(150deg, #07040f 0%, var(--sw-bg) 100%);
		}
		.sw-shell { max-width: 1150px; margin: 0 auto; padding: 2.2rem 1rem 3rem; }
		.sw-title { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.05; }
		.sw-sub { max-width: 66ch; color: rgba(244, 237, 255, 0.84); }
		.sw-grid { display: grid; grid-template-columns: repeat(12, minmax(0, 1fr)); gap: 1rem; }
		.sw-card { border-radius: 1rem; border: 1px solid rgba(139, 92, 246, 0.3); background: linear-gradient(155deg, rgba(35, 24, 62, 0.9), rgba(18, 11, 34, 0.94)); padding: 1rem; }
		.sw-code, .sw-state, .sw-console { grid-column: span 12; }
		@media (min-width: 1100px) { .sw-code { grid-column: span 6; } .sw-state, .sw-console { grid-column: span 3; } }
		.sw-head { display: flex; justify-content: space-between; align-items: center; gap: 0.7rem; margin-bottom: 0.75rem; }
		.sw-badge { border: 1px solid rgba(34, 211, 238, 0.45); background: rgba(34, 211, 238, 0.14); border-radius: 999px; padding: 0.2rem 0.6rem; font-size: 0.72rem; font-family: 'Fira Code', monospace; }
		.sw-panel { background: rgba(9, 6, 18, 0.9); border: 1px solid rgba(139, 92, 246, 0.28); border-radius: 0.8rem; padding: 0.75rem; }
		.sw-row { display: grid; grid-template-columns: 2rem 1fr; gap: 0.8rem; padding: 0.42rem 0.5rem; border-radius: 0.55rem; font-family: 'Fira Code', monospace; font-size: 0.87rem; color: rgba(244, 237, 255, 0.9); transition: all 0.2s ease; }
		.sw-row.active { background: linear-gradient(90deg, rgba(139, 92, 246, 0.3), rgba(139, 92, 246, 0.08)); outline: 1px solid rgba(139, 92, 246, 0.45); transform: translateX(3px); }
		.sw-ln { color: rgba(244, 237, 255, 0.42); text-align: right; }
		.sw-state-item { display: flex; justify-content: space-between; border: 1px solid rgba(34, 211, 238, 0.3); background: rgba(34, 211, 238, 0.08); border-radius: 0.65rem; padding: 0.6rem 0.7rem; margin-bottom: 0.5rem; font-family: 'Fira Code', monospace; font-size: 0.84rem; }
		.sw-value { color: var(--sw-primary); font-size: 1rem; font-weight: 700; }
		.sw-copy { margin-top: 0.8rem; border: 1px solid rgba(139, 92, 246, 0.35); background: rgba(139, 92, 246, 0.12); border-radius: 0.7rem; padding: 0.75rem; }
		.sw-controls { margin-top: 0.9rem; display: flex; gap: 0.7rem; flex-wrap: wrap; align-items: center; }
		.sw-btn { border: 1px solid rgba(139, 92, 246, 0.45); background: rgba(139, 92, 246, 0.15); color: #f4edff; border-radius: 0.7rem; padding: 0.55rem 1rem; font-weight: 600; transition: all 0.2s ease; }
		.sw-btn:hover:not(:disabled) { background: rgba(139, 92, 246, 0.28); transform: translateY(-1px); }
		.sw-btn:disabled { opacity: 0.4; cursor: not-allowed; }
		.sw-select { border: 1px solid rgba(34, 211, 238, 0.45); background: rgba(9, 6, 18, 0.92); color: #f4edff; border-radius: 0.6rem; padding: 0.45rem 0.55rem; font-family: 'Fira Code', monospace; font-size: 0.75rem; }
		.sw-track { margin-top: 0.8rem; height: 0.55rem; border-radius: 999px; background: rgba(244, 237, 255, 0.14); overflow: hidden; }
		.sw-fill { height: 100%; width: 0%; background: linear-gradient(90deg, var(--sw-primary), var(--sw-cyan)); transition: width 0.25s ease; }
		.sw-console-win { border: 1px solid rgba(34, 211, 238, 0.35); border-radius: 0.8rem; overflow: hidden; background: rgba(9, 6, 18, 0.9); }
		.sw-console-head { display: flex; justify-content: space-between; padding: 0.5rem 0.75rem; font-family: 'Fira Code', monospace; font-size: 0.72rem; background: rgba(34, 211, 238, 0.12); border-bottom: 1px solid rgba(34, 211, 238, 0.3); }
		.sw-console-body { min-height: 150px; padding: 0.75rem; font-family: 'Fira Code', monospace; font-size: 0.82rem; }
		.sw-log { opacity: 0; transform: translateY(8px); animation: sw-log 0.35s ease forwards; color: #d8f2ff; }
		@keyframes sw-log { to { opacity: 1; transform: translateY(0); } }
		.sw-back { display: inline-block; margin-top: 1.4rem; color: var(--sw-cyan); text-decoration: none; border-bottom: 1px dashed rgba(34, 211, 238, 0.5); }
	</style>

	<div class="sw-screen">
		<main class="sw-shell">
			<header class="mb-6">
				<p class="sw-badge">switch / paso a paso</p>
				<h1 class="sw-title mt-3"><code>switch</code> linea por linea</h1>
				<p class="sw-sub mt-3">Aca se ve como <code>switch</code> compara casos, encuentra coincidencia y corta con <code>break</code>.</p>
			</header>
			<section class="sw-grid" aria-live="polite">
				<article class="sw-card sw-code">
					<div class="sw-head"><strong>1) Codigo</strong><span class="sw-badge" id="sw-line">Linea activa: 1</span></div>
					<div class="sw-panel">
						<div class="sw-row" data-line="1"><span class="sw-ln">1</span><span>const dia = 'martes';</span></div>
						<div class="sw-row" data-line="2"><span class="sw-ln">2</span><span>switch (dia) &#123;</span></div>
						<div class="sw-row" data-line="3"><span class="sw-ln">3</span><span>&nbsp;&nbsp;case 'lunes':</span></div>
						<div class="sw-row" data-line="4"><span class="sw-ln">4</span><span>&nbsp;&nbsp;&nbsp;&nbsp;console.log('Comienza la semana');</span></div>
						<div class="sw-row" data-line="5"><span class="sw-ln">5</span><span>&nbsp;&nbsp;&nbsp;&nbsp;break;</span></div>
						<div class="sw-row" data-line="6"><span class="sw-ln">6</span><span>&nbsp;&nbsp;case 'martes':</span></div>
						<div class="sw-row" data-line="7"><span class="sw-ln">7</span><span>&nbsp;&nbsp;&nbsp;&nbsp;console.log('Seguimos con energia');</span></div>
						<div class="sw-row" data-line="8"><span class="sw-ln">8</span><span>&nbsp;&nbsp;&nbsp;&nbsp;break;</span></div>
						<div class="sw-row" data-line="9"><span class="sw-ln">9</span><span>&nbsp;&nbsp;default:</span></div>
						<div class="sw-row" data-line="10"><span class="sw-ln">10</span><span>&nbsp;&nbsp;&nbsp;&nbsp;console.log('Dia no contemplado');</span></div>
						<div class="sw-row" data-line="11"><span class="sw-ln">11</span><span>&#125;</span></div>
						<div class="sw-row" data-line="12"><span class="sw-ln">12</span><span>console.log('Fin del switch');</span></div>
					</div>
					<div class="sw-copy" id="sw-copy"><strong>Paso 1:</strong> Se define <code>dia</code> como 'martes'.</div>
					<div class="sw-track"><div class="sw-fill" id="sw-fill"></div></div>
					<div class="sw-controls">
						<button class="sw-btn" id="sw-prev" type="button">⬅ Retroceder</button>
						<button class="sw-btn" id="sw-next" type="button">Avanzar ➡</button>
						<button class="sw-btn" id="sw-auto" type="button">Auto-play ▶</button>
						<select class="sw-select" id="sw-level" aria-label="Nivel de detalle">
							<option value="basico" selected>Basico</option>
							<option value="intermedio">Intermedio</option>
						</select>
						<span class="sw-badge" id="sw-step">Paso 1 / 8</span>
					</div>
				</article>
				<article class="sw-card sw-state">
					<div class="sw-head"><strong>2) Variables</strong></div>
					<div class="sw-state-item"><span>dia</span><span id="sw-dia" class="sw-value">martes</span></div>
					<div class="sw-state-item"><span>Case actual</span><span id="sw-case" class="sw-value">-</span></div>
				</article>
				<article class="sw-card sw-console">
					<div class="sw-head"><strong>3) Consola simulada</strong></div>
					<div class="sw-console-win">
						<div class="sw-console-head"><span>node switch-demo.js</span><span>stdout</span></div>
						<div class="sw-console-body" id="sw-console"></div>
					</div>
				</article>
			</section>
			<a class="sw-back" href={getRelativePath('/presentaciones')}>← Volver a presentaciones</a>
		</main>
	</div>

	<script>
		type Step = { line: number; message: string; dia: string; selectedCase: string; logs: string[] };
		const baseSteps: Step[] = [
			{ line: 1, message: 'Se declara dia = martes.', dia: 'martes', selectedCase: '-', logs: [] },
			{ line: 2, message: 'Comienza switch y compara contra cada case.', dia: 'martes', selectedCase: 'comparando', logs: [] },
			{ line: 3, message: 'Case lunes no coincide.', dia: 'martes', selectedCase: 'lunes (no)', logs: [] },
			{ line: 6, message: 'Case martes SI coincide.', dia: 'martes', selectedCase: 'martes (si)', logs: [] },
			{ line: 7, message: 'Ejecuta el bloque del case martes.', dia: 'martes', selectedCase: 'martes (si)', logs: ['Seguimos con energia'] },
			{ line: 8, message: 'El break corta y evita seguir al default.', dia: 'martes', selectedCase: 'break', logs: ['Seguimos con energia'] },
			{ line: 11, message: 'Cierra switch.', dia: 'martes', selectedCase: 'break', logs: ['Seguimos con energia'] },
			{ line: 12, message: 'Sigue el flujo del programa.', dia: 'martes', selectedCase: 'final', logs: ['Seguimos con energia', 'Fin del switch'] },
		];

		const buildIntermediateSteps = (steps: Step[]): Step[] => {
			const enriched: Step[] = [];
			steps.forEach((stepState, index) => {
				enriched.push(stepState);
				if (index < steps.length - 1) {
					enriched.push({ ...stepState, message: `Detalle intermedio: ${stepState.message}` });
				}
			});
			return enriched;
		};

		type Level = 'basico' | 'intermedio';
		const stepSets: Record<Level, Step[]> = {
			basico: baseSteps,
			intermedio: buildIntermediateSteps(baseSteps),
		};

		let currentLevel: Level = 'basico';
		let activeSteps: Step[] = stepSets[currentLevel];

		let currentStep = 0;
		const prev = document.getElementById('sw-prev') as HTMLButtonElement;
		const next = document.getElementById('sw-next') as HTMLButtonElement;
		const auto = document.getElementById('sw-auto') as HTMLButtonElement;
		const levelSelect = document.getElementById('sw-level') as HTMLSelectElement;
		const line = document.getElementById('sw-line') as HTMLElement;
		const step = document.getElementById('sw-step') as HTMLElement;
		const copy = document.getElementById('sw-copy') as HTMLElement;
		const dia = document.getElementById('sw-dia') as HTMLElement;
		const selected = document.getElementById('sw-case') as HTMLElement;
		const consoleBody = document.getElementById('sw-console') as HTMLElement;
		const fill = document.getElementById('sw-fill') as HTMLElement;
		let autoPlayTimer: number | null = null;

		function stopAutoPlay(): void {
			if (autoPlayTimer !== null) {
				window.clearInterval(autoPlayTimer);
				autoPlayTimer = null;
			}
			auto.textContent = 'Auto-play ▶';
		}

		function toggleAutoPlay(): void {
			if (autoPlayTimer !== null) {
				stopAutoPlay();
				return;
			}
			auto.textContent = 'Pausar ⏸';
			autoPlayTimer = window.setInterval(() => {
				if (currentStep < activeSteps.length - 1) {
					currentStep += 1;
					render();
				} else {
					stopAutoPlay();
				}
			}, 1300);
		}

		function render(): void {
			const state = activeSteps[currentStep];
			document.querySelectorAll<HTMLElement>('.sw-row').forEach((row) => row.classList.toggle('active', Number(row.dataset.line) === state.line));
			line.textContent = `Linea activa: ${state.line}`;
			step.textContent = `Paso ${currentStep + 1} / ${activeSteps.length}`;
			copy.innerHTML = `<strong>Paso ${currentStep + 1}:</strong> ${state.message}`;
			dia.textContent = state.dia;
			selected.textContent = state.selectedCase;
			consoleBody.innerHTML = '';
			state.logs.forEach((entry, index) => {
				const el = document.createElement('div');
				el.className = 'sw-log';
				el.style.animationDelay = `${index * 80}ms`;
				el.textContent = `> ${entry}`;
				consoleBody.appendChild(el);
			});
			fill.style.width = `${((currentStep + 1) / activeSteps.length) * 100}%`;
			prev.disabled = currentStep === 0;
			next.disabled = currentStep === activeSteps.length - 1;
		}

		prev.addEventListener('click', () => { if (currentStep > 0) { currentStep -= 1; render(); } });
		next.addEventListener('click', () => { if (currentStep < activeSteps.length - 1) { currentStep += 1; render(); } });
		auto.addEventListener('click', () => toggleAutoPlay());
		levelSelect.addEventListener('change', () => {
			currentLevel = levelSelect.value as Level;
			activeSteps = stepSets[currentLevel];
			currentStep = 0;
			stopAutoPlay();
			render();
		});
		document.addEventListener('keydown', (event: KeyboardEvent) => { if (event.key === 'ArrowLeft') prev.click(); if (event.key === 'ArrowRight') next.click(); });
		render();
	</script>
</Layout>
