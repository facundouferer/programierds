---
import Layout from '../../layouts/Layout.astro';
import { getRelativePath } from '../../utils/paths';
---

<Layout title="While paso a paso - Programierds">
	<style is:global>
		@import url('https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@400;500;600;700&family=Fira+Code:wght@400;500;700&display=swap');

		.while-screen {
			--while-bg: #061016;
			--while-surface: #0c1c24;
			--while-panel: #102833;
			--while-primary: #0df259;
			--while-blue: #3b82f6;
			--while-warning: #f59e0b;
			--while-danger: #ef4444;
			min-height: 100vh;
			font-family: 'Chakra Petch', sans-serif;
			background:
				radial-gradient(circle at 10% 10%, rgba(13, 242, 89, 0.12), transparent 45%),
				radial-gradient(circle at 85% 20%, rgba(59, 130, 246, 0.14), transparent 40%),
				linear-gradient(135deg, #050b11 0%, var(--while-bg) 100%);
			color: #e7fbe7;
		}

		.while-shell {
			max-width: 1200px;
			margin: 0 auto;
			padding: 2.5rem 1rem 3rem;
		}

		.while-title {
			font-size: clamp(2rem, 4vw, 3.2rem);
			line-height: 1.05;
			font-weight: 700;
			letter-spacing: 0.02em;
			text-shadow: 0 0 30px rgba(13, 242, 89, 0.28);
		}

		.while-subtitle {
			max-width: 64ch;
			font-size: 1rem;
			color: rgba(231, 251, 231, 0.82);
		}

		.while-grid {
			display: grid;
			gap: 1rem;
			grid-template-columns: repeat(12, minmax(0, 1fr));
		}

		.card {
			background: linear-gradient(160deg, rgba(16, 40, 51, 0.9), rgba(8, 20, 26, 0.86));
			border: 1px solid rgba(13, 242, 89, 0.18);
			border-radius: 1rem;
			box-shadow: 0 18px 34px rgba(0, 0, 0, 0.28);
		}

		.code-card { grid-column: span 12; padding: 1rem; }
		.data-card { grid-column: span 12; padding: 1rem; }
		.console-card { grid-column: span 12; padding: 1rem; }

		@media (min-width: 1100px) {
			.code-card { grid-column: span 6; }
			.data-card { grid-column: span 3; }
			.console-card { grid-column: span 3; }
		}

		.code-header,
		.panel-header {
			display: flex;
			justify-content: space-between;
			align-items: center;
			margin-bottom: 0.8rem;
			gap: 0.75rem;
		}

		.badge {
			display: inline-flex;
			align-items: center;
			border: 1px solid rgba(13, 242, 89, 0.25);
			background: rgba(13, 242, 89, 0.1);
			border-radius: 999px;
			padding: 0.2rem 0.6rem;
			font-size: 0.72rem;
			font-family: 'Fira Code', monospace;
			letter-spacing: 0.04em;
		}

		.code-panel {
			background: rgba(4, 10, 14, 0.85);
			border: 1px solid rgba(13, 242, 89, 0.14);
			border-radius: 0.8rem;
			padding: 0.75rem;
		}

		.code-row {
			display: grid;
			grid-template-columns: 2rem 1fr;
			gap: 0.8rem;
			padding: 0.42rem 0.5rem;
			border-radius: 0.5rem;
			font-family: 'Fira Code', monospace;
			font-size: 0.92rem;
			color: rgba(231, 251, 231, 0.84);
			transition: background-color 0.25s ease, transform 0.25s ease;
		}

		.code-row.active {
			background: linear-gradient(90deg, rgba(13, 242, 89, 0.2), rgba(13, 242, 89, 0.05));
			outline: 1px solid rgba(13, 242, 89, 0.35);
			transform: translateX(3px);
		}

		.line-number { color: rgba(231, 251, 231, 0.45); text-align: right; }

		.state-item {
			display: flex;
			justify-content: space-between;
			align-items: center;
			padding: 0.6rem 0.7rem;
			border: 1px solid rgba(13, 242, 89, 0.14);
			background: rgba(13, 242, 89, 0.05);
			border-radius: 0.65rem;
			font-family: 'Fira Code', monospace;
			font-size: 0.85rem;
			margin-bottom: 0.5rem;
		}

		.state-value {
			font-size: 1.05rem;
			font-weight: 700;
			color: var(--while-primary);
		}

		.condition-true { color: var(--while-primary); }
		.condition-false { color: var(--while-danger); }

		.console-window {
			background: rgba(4, 10, 14, 0.86);
			border: 1px solid rgba(59, 130, 246, 0.35);
			border-radius: 0.8rem;
			overflow: hidden;
		}

		.console-head {
			display: flex;
			align-items: center;
			justify-content: space-between;
			padding: 0.5rem 0.75rem;
			font-size: 0.72rem;
			font-family: 'Fira Code', monospace;
			background: rgba(59, 130, 246, 0.1);
			border-bottom: 1px solid rgba(59, 130, 246, 0.28);
		}

		.console-body {
			padding: 0.75rem;
			font-family: 'Fira Code', monospace;
			font-size: 0.83rem;
			min-height: 160px;
		}

		.console-line {
			opacity: 0;
			transform: translateY(8px);
			animation: log-in 0.45s ease forwards;
			color: #d7e9ff;
		}

		@keyframes log-in {
			to {
				opacity: 1;
				transform: translateY(0);
			}
		}

		.controls {
			margin-top: 1rem;
			display: flex;
			gap: 0.8rem;
			align-items: center;
			flex-wrap: wrap;
		}

		.btn {
			border: 1px solid rgba(13, 242, 89, 0.35);
			background: rgba(13, 242, 89, 0.1);
			color: #e7fbe7;
			padding: 0.6rem 1rem;
			border-radius: 0.7rem;
			font-weight: 600;
			letter-spacing: 0.03em;
			transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
		}

		.btn:hover:not(:disabled) {
			transform: translateY(-1px);
			box-shadow: 0 0 18px rgba(13, 242, 89, 0.25);
			background: rgba(13, 242, 89, 0.2);
		}

		.btn:disabled {
			opacity: 0.4;
			cursor: not-allowed;
		}

		.progress-track {
			height: 0.55rem;
			border-radius: 999px;
			background: rgba(231, 251, 231, 0.12);
			overflow: hidden;
			margin-top: 0.8rem;
		}

		.progress-fill {
			height: 100%;
			width: 0%;
			background: linear-gradient(90deg, var(--while-primary), var(--while-blue));
			transition: width 0.25s ease;
		}

		.step-copy {
			margin-top: 0.8rem;
			padding: 0.8rem;
			border-radius: 0.7rem;
			border: 1px solid rgba(245, 158, 11, 0.25);
			background: rgba(245, 158, 11, 0.08);
		}

		.footer-link {
			display: inline-block;
			margin-top: 1.5rem;
			color: var(--while-primary);
			text-decoration: none;
			border-bottom: 1px dashed rgba(13, 242, 89, 0.4);
		}
	</style>

	<div class="while-screen">
		<main class="while-shell">
			<header class="mb-6">
				<p class="badge">while / simulador interactivo</p>
				<h1 class="while-title mt-3">Ciclo <code>while</code> paso a paso</h1>
				<p class="while-subtitle mt-3">
					Acá vas a ver EXACTAMENTE qué línea se ejecuta, qué valor tiene la variable y qué aparece en consola.
					Tocá <strong>Avanzar</strong> o <strong>Retroceder</strong> y controlá vos cada iteración.
				</p>
			</header>

			<section class="while-grid" aria-live="polite">
				<article class="card code-card">
					<div class="code-header">
						<strong>1) Código que estamos ejecutando</strong>
						<span class="badge" id="line-badge">Línea activa: 1</span>
					</div>
					<div class="code-panel">
						<div class="code-row" data-line="1"><span class="line-number">1</span><span>let i = 1;</span></div>
						<div class="code-row" data-line="2"><span class="line-number">2</span><span>while (i &lt;= 4) &#123;</span></div>
						<div class="code-row" data-line="3"><span class="line-number">3</span><span>&nbsp;&nbsp;console.log(`Iteracion ${'{'}i{'}'}`);</span></div>
						<div class="code-row" data-line="4"><span class="line-number">4</span><span>&nbsp;&nbsp;i = i + 1;</span></div>
						<div class="code-row" data-line="5"><span class="line-number">5</span><span>&#125;</span></div>
						<div class="code-row" data-line="6"><span class="line-number">6</span><span>console.log('Fin del ciclo');</span></div>
					</div>

					<div class="step-copy" id="step-copy">
						<strong>Paso 1:</strong> Arranca el programa y crea la variable <code>i</code>.
					</div>

					<div class="progress-track" aria-hidden="true">
						<div class="progress-fill" id="progress-fill"></div>
					</div>

					<div class="controls">
						<button class="btn" id="prev-btn" type="button">⬅ Retroceder</button>
						<button class="btn" id="next-btn" type="button">Avanzar ➡</button>
						<span class="badge" id="step-badge">Paso 1 / 12</span>
					</div>
				</article>

				<article class="card data-card">
					<div class="panel-header">
						<strong>2) Estado interno</strong>
					</div>
					<div class="state-item">
						<span>Valor de <code>i</code></span>
						<span class="state-value" id="state-i">1</span>
					</div>
					<div class="state-item">
						<span>Iteraciones ejecutadas</span>
						<span class="state-value" id="state-iterations">0</span>
					</div>
					<div class="state-item">
						<span>Resultado de <code>i &lt;= 4</code></span>
						<span class="state-value" id="state-condition">-</span>
					</div>
				</article>

				<article class="card console-card">
					<div class="panel-header">
						<strong>3) Consola simulada</strong>
					</div>
					<div class="console-window">
						<div class="console-head">
							<span>node while-demo.js</span>
							<span>stdout</span>
						</div>
						<div class="console-body" id="console-body"></div>
					</div>
				</article>
			</section>

			<a class="footer-link" href={getRelativePath('/presentaciones')}>
				← Volver a todas las presentaciones
			</a>
		</main>
	</div>

	<script>
		type Step = {
			line: number;
			message: string;
			iValue: number;
			iterations: number;
			condition: 'true' | 'false' | '-';
			consoleLines: string[];
		};

		const steps: Step[] = [
			{ line: 1, message: 'Paso 1: Arranca el programa y crea la variable i con valor 1.', iValue: 1, iterations: 0, condition: '-', consoleLines: [] },
			{ line: 2, message: 'Paso 2: Evalua while (i <= 4). Como i vale 1, la condicion da true y entra al bloque.', iValue: 1, iterations: 0, condition: 'true', consoleLines: [] },
			{ line: 3, message: 'Paso 3: Ejecuta console.log de la iteracion actual.', iValue: 1, iterations: 1, condition: 'true', consoleLines: ['Iteracion 1'] },
			{ line: 4, message: 'Paso 4: Incrementa i en 1. Ahora i vale 2.', iValue: 2, iterations: 1, condition: 'true', consoleLines: ['Iteracion 1'] },
			{ line: 2, message: 'Paso 5: Vuelve al while. 2 <= 4, asi que true y repite.', iValue: 2, iterations: 1, condition: 'true', consoleLines: ['Iteracion 1'] },
			{ line: 3, message: 'Paso 6: Segunda vuelta: imprime en consola la iteracion 2.', iValue: 2, iterations: 2, condition: 'true', consoleLines: ['Iteracion 1', 'Iteracion 2'] },
			{ line: 4, message: 'Paso 7: Suma 1 otra vez. i pasa a valer 3.', iValue: 3, iterations: 2, condition: 'true', consoleLines: ['Iteracion 1', 'Iteracion 2'] },
			{ line: 3, message: 'Paso 8: Avance rapido al mismo patron: se imprime iteracion 3.', iValue: 3, iterations: 3, condition: 'true', consoleLines: ['Iteracion 1', 'Iteracion 2', 'Iteracion 3'] },
			{ line: 4, message: 'Paso 9: Incrementa de nuevo. i ahora vale 4.', iValue: 4, iterations: 3, condition: 'true', consoleLines: ['Iteracion 1', 'Iteracion 2', 'Iteracion 3'] },
			{ line: 3, message: 'Paso 10: Ultima vez que entra: imprime iteracion 4.', iValue: 4, iterations: 4, condition: 'true', consoleLines: ['Iteracion 1', 'Iteracion 2', 'Iteracion 3', 'Iteracion 4'] },
			{ line: 2, message: 'Paso 11: i se incrementa a 5 y while evalua 5 <= 4. Da false, entonces sale del ciclo.', iValue: 5, iterations: 4, condition: 'false', consoleLines: ['Iteracion 1', 'Iteracion 2', 'Iteracion 3', 'Iteracion 4'] },
			{ line: 6, message: 'Paso 12: Continua con lo que sigue fuera del while y muestra el mensaje final.', iValue: 5, iterations: 4, condition: 'false', consoleLines: ['Iteracion 1', 'Iteracion 2', 'Iteracion 3', 'Iteracion 4', 'Fin del ciclo'] },
		];

		let currentStep = 0;

		const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
		const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
		const lineBadge = document.getElementById('line-badge') as HTMLElement;
		const stepBadge = document.getElementById('step-badge') as HTMLElement;
		const stepCopy = document.getElementById('step-copy') as HTMLElement;
		const stateI = document.getElementById('state-i') as HTMLElement;
		const stateIterations = document.getElementById('state-iterations') as HTMLElement;
		const stateCondition = document.getElementById('state-condition') as HTMLElement;
		const consoleBody = document.getElementById('console-body') as HTMLElement;
		const progressFill = document.getElementById('progress-fill') as HTMLElement;

		function renderStep(): void {
			const step = steps[currentStep];

			document.querySelectorAll<HTMLElement>('.code-row').forEach((row) => {
				row.classList.toggle('active', Number(row.dataset.line) === step.line);
			});

			lineBadge.textContent = `Linea activa: ${step.line}`;
			stepBadge.textContent = `Paso ${currentStep + 1} / ${steps.length}`;
			stepCopy.innerHTML = `<strong>Paso ${currentStep + 1}:</strong> ${step.message}`;

			stateI.textContent = String(step.iValue);
			stateIterations.textContent = String(step.iterations);
			stateCondition.textContent = step.condition;
			stateCondition.classList.remove('condition-true', 'condition-false');
			if (step.condition === 'true') stateCondition.classList.add('condition-true');
			if (step.condition === 'false') stateCondition.classList.add('condition-false');

			consoleBody.innerHTML = '';
			step.consoleLines.forEach((line, index) => {
				const entry = document.createElement('div');
				entry.className = 'console-line';
				entry.style.animationDelay = `${index * 80}ms`;
				entry.textContent = `> ${line}`;
				consoleBody.appendChild(entry);
			});

			progressFill.style.width = `${((currentStep + 1) / steps.length) * 100}%`;
			prevBtn.disabled = currentStep === 0;
			nextBtn.disabled = currentStep === steps.length - 1;
		}

		prevBtn.addEventListener('click', () => {
			if (currentStep > 0) {
				currentStep -= 1;
				renderStep();
			}
		});

		nextBtn.addEventListener('click', () => {
			if (currentStep < steps.length - 1) {
				currentStep += 1;
				renderStep();
			}
		});

		document.addEventListener('keydown', (event: KeyboardEvent) => {
			if (event.key === 'ArrowRight') nextBtn.click();
			if (event.key === 'ArrowLeft') prevBtn.click();
		});

		renderStep();
	</script>
</Layout>
