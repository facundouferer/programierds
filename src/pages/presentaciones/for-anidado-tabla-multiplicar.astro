---
import Layout from '../../layouts/Layout.astro';
import { getRelativePath } from '../../utils/paths';
---

<Layout title="For anidado tabla de multiplicar - Programierds">
	<style is:global>
		@import url('https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@400;500;600;700&family=Fira+Code:wght@400;500;700&display=swap');

		.fn-screen {
			--fn-bg: #0d101f;
			--fn-panel: #191f3a;
			--fn-primary: #a78bfa;
			--fn-cyan: #22d3ee;
			--fn-danger: #fb7185;
			min-height: 100vh;
			font-family: 'Chakra Petch', sans-serif;
			background:
				radial-gradient(circle at 85% 14%, rgba(167, 139, 250, 0.2), transparent 42%),
				radial-gradient(circle at 12% 82%, rgba(34, 211, 238, 0.14), transparent 40%),
				linear-gradient(145deg, #070913 0%, var(--fn-bg) 100%);
			color: #f1ecff;
		}

		.fn-shell { max-width: 1280px; margin: 0 auto; padding: 2.5rem 1rem 3rem; }
		.fn-title { font-size: clamp(2rem, 4vw, 3.1rem); line-height: 1.05; font-weight: 700; }
		.fn-sub { max-width: 72ch; color: rgba(241, 236, 255, 0.84); }

		.fn-grid { display: grid; grid-template-columns: repeat(12, minmax(0, 1fr)); gap: 1rem; }
		.fn-card { border-radius: 1rem; border: 1px solid rgba(167, 139, 250, 0.32); background: linear-gradient(160deg, rgba(25, 31, 58, 0.92), rgba(12, 16, 32, 0.94)); padding: 1rem; }
		.fn-code { grid-column: span 12; }
		.fn-state { grid-column: span 12; }
		.fn-table { grid-column: span 12; }
		@media (min-width: 1200px) {
			.fn-code { grid-column: span 5; }
			.fn-state { grid-column: span 3; }
			.fn-table { grid-column: span 4; }
		}

		.fn-badge { border: 1px solid rgba(34, 211, 238, 0.4); background: rgba(34, 211, 238, 0.12); border-radius: 999px; padding: 0.2rem 0.6rem; font-size: 0.72rem; font-family: 'Fira Code', monospace; }
		.fn-head { display: flex; justify-content: space-between; align-items: center; gap: 0.7rem; margin-bottom: 0.75rem; }

		.fn-code-panel { background: rgba(8, 10, 21, 0.9); border: 1px solid rgba(167, 139, 250, 0.28); border-radius: 0.8rem; padding: 0.75rem; }
		.fn-row { display: grid; grid-template-columns: 2rem 1fr; gap: 0.8rem; border-radius: 0.55rem; padding: 0.42rem 0.5rem; font-family: 'Fira Code', monospace; font-size: 0.88rem; transition: all 0.2s ease; color: rgba(241, 236, 255, 0.88); }
		.fn-row.active { background: linear-gradient(90deg, rgba(167, 139, 250, 0.28), rgba(167, 139, 250, 0.08)); outline: 1px solid rgba(167, 139, 250, 0.45); transform: translateX(3px); }
		.fn-ln { color: rgba(241, 236, 255, 0.45); text-align: right; }

		.fn-state-item { display: flex; justify-content: space-between; align-items: center; border: 1px solid rgba(34, 211, 238, 0.3); background: rgba(34, 211, 238, 0.08); border-radius: 0.65rem; padding: 0.62rem 0.7rem; font-family: 'Fira Code', monospace; margin-bottom: 0.5rem; font-size: 0.84rem; }
		.fn-value { color: var(--fn-primary); font-weight: 700; font-size: 1.02rem; }
		.fn-true { color: #86efac; }
		.fn-false { color: var(--fn-danger); }

		.fn-copy { margin-top: 0.85rem; border: 1px solid rgba(167, 139, 250, 0.36); background: rgba(167, 139, 250, 0.11); border-radius: 0.7rem; padding: 0.75rem; }
		.fn-controls { margin-top: 0.9rem; display: flex; gap: 0.7rem; flex-wrap: wrap; align-items: center; }
		.fn-btn { border: 1px solid rgba(167, 139, 250, 0.46); background: rgba(167, 139, 250, 0.14); color: #f1ecff; padding: 0.58rem 1rem; border-radius: 0.7rem; font-weight: 600; transition: all 0.2s ease; }
		.fn-btn:hover:not(:disabled) { background: rgba(167, 139, 250, 0.3); transform: translateY(-1px); box-shadow: 0 0 18px rgba(167, 139, 250, 0.26); }
		.fn-btn:disabled { opacity: 0.4; cursor: not-allowed; }

		.fn-track { margin-top: 0.8rem; height: 0.55rem; border-radius: 999px; background: rgba(241, 236, 255, 0.14); overflow: hidden; }
		.fn-fill { height: 100%; width: 0%; background: linear-gradient(90deg, var(--fn-primary), var(--fn-cyan)); transition: width 0.25s ease; }

		.fn-console { margin-top: 0.85rem; border: 1px solid rgba(34, 211, 238, 0.35); border-radius: 0.8rem; overflow: hidden; background: rgba(8, 10, 21, 0.9); }
		.fn-console-head { display: flex; justify-content: space-between; padding: 0.5rem 0.75rem; font-family: 'Fira Code', monospace; font-size: 0.72rem; background: rgba(34, 211, 238, 0.13); border-bottom: 1px solid rgba(34, 211, 238, 0.3); }
		.fn-console-body { min-height: 140px; max-height: 220px; overflow: auto; padding: 0.75rem; font-family: 'Fira Code', monospace; font-size: 0.82rem; }
		.fn-log { opacity: 0; transform: translateY(8px); animation: fn-log-in 0.35s ease forwards; color: #d5efff; }
		@keyframes fn-log-in { to { opacity: 1; transform: translateY(0); } }

		.mult-table-wrap { overflow: auto; border: 1px solid rgba(167, 139, 250, 0.28); border-radius: 0.75rem; }
		.mult-table { width: 100%; border-collapse: collapse; font-family: 'Fira Code', monospace; font-size: 0.8rem; }
		.mult-table th, .mult-table td { border: 1px solid rgba(167, 139, 250, 0.2); padding: 0.35rem; text-align: center; min-width: 44px; }
		.mult-table th { background: rgba(167, 139, 250, 0.18); position: sticky; top: 0; z-index: 1; }
		.mult-cell-active { background: rgba(34, 211, 238, 0.3); box-shadow: inset 0 0 0 1px rgba(34, 211, 238, 0.85); }

		.fn-back { display: inline-block; margin-top: 1.5rem; color: var(--fn-cyan); text-decoration: none; border-bottom: 1px dashed rgba(34, 211, 238, 0.5); }
	</style>

	<div class="fn-screen">
		<main class="fn-shell">
			<header class="mb-6">
				<p class="fn-badge">for anidado / tabla de multiplicar</p>
				<h1 class="fn-title mt-3"><code>for</code> anidado + tabla de multiplicar</h1>
				<p class="fn-sub mt-3">Aca ves dos bucles trabajando en equipo: <strong>fila</strong> maneja la tabla (1, 2, 3) y <strong>col</strong> recorre del 1 al 10. Con Avanzar/Retroceder controlas como se llena la tabla.</p>
			</header>

			<section class="fn-grid" aria-live="polite">
				<article class="fn-card fn-code">
					<div class="fn-head">
						<strong>1) Codigo y linea activa</strong>
						<span class="fn-badge" id="fn-line">Linea activa: 1</span>
					</div>
					<div class="fn-code-panel">
						<div class="fn-row" data-line="1"><span class="fn-ln">1</span><span>for (let fila = 1; fila &lt;= 3; fila++) &#123;</span></div>
						<div class="fn-row" data-line="2"><span class="fn-ln">2</span><span>&nbsp;&nbsp;for (let col = 1; col &lt;= 10; col++) &#123;</span></div>
						<div class="fn-row" data-line="3"><span class="fn-ln">3</span><span>&nbsp;&nbsp;&nbsp;&nbsp;const valor = fila * col;</span></div>
						<div class="fn-row" data-line="4"><span class="fn-ln">4</span><span>&nbsp;&nbsp;&nbsp;&nbsp;console.log(`${'{'}fila{'}'} x ${'{'}col{'}'} = ${'{'}valor{'}'}`);</span></div>
						<div class="fn-row" data-line="5"><span class="fn-ln">5</span><span>&nbsp;&nbsp;&#125;</span></div>
						<div class="fn-row" data-line="6"><span class="fn-ln">6</span><span>&#125;</span></div>
					</div>

					<div class="fn-copy" id="fn-copy"><strong>Paso 1:</strong> Arranca el for externo con fila = 1.</div>
					<div class="fn-track"><div class="fn-fill" id="fn-fill"></div></div>
					<div class="fn-controls">
						<button id="fn-prev" class="fn-btn" type="button">⬅ Retroceder</button>
						<button id="fn-next" class="fn-btn" type="button">Avanzar ➡</button>
						<span class="fn-badge" id="fn-step">Paso 1 / 13</span>
					</div>

					<div class="fn-console">
						<div class="fn-console-head"><span>node for-anidado.js</span><span>stdout</span></div>
						<div class="fn-console-body" id="fn-console"></div>
					</div>
				</article>

				<article class="fn-card fn-state">
					<div class="fn-head"><strong>2) Estado interno</strong></div>
					<div class="fn-state-item"><span>fila</span><span id="fn-fila" class="fn-value">1</span></div>
					<div class="fn-state-item"><span>col</span><span id="fn-col" class="fn-value">1</span></div>
					<div class="fn-state-item"><span>valor (fila * col)</span><span id="fn-valor" class="fn-value">1</span></div>
					<div class="fn-state-item"><span>Condicion externa</span><span id="fn-outer" class="fn-value">true</span></div>
					<div class="fn-state-item"><span>Condicion interna</span><span id="fn-inner" class="fn-value">true</span></div>
				</article>

				<article class="fn-card fn-table">
					<div class="fn-head"><strong>3) Tabla de multiplicar en vivo</strong></div>
					<div class="mult-table-wrap">
						<table class="mult-table" id="mult-table">
							<thead>
								<tr>
									<th>x</th>
									<th>1</th><th>2</th><th>3</th><th>4</th><th>5</th><th>6</th><th>7</th><th>8</th><th>9</th><th>10</th>
								</tr>
							</thead>
							<tbody>
								<tr><th>1</th><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td></tr>
								<tr><th>2</th><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td></tr>
								<tr><th>3</th><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td></tr>
							</tbody>
						</table>
					</div>
				</article>
			</section>

			<a class="fn-back" href={getRelativePath('/presentaciones')}>← Volver a presentaciones</a>
		</main>
	</div>

	<script>
		type Step = {
			line: number;
			message: string;
			fila: number;
			col: number;
			valor: number;
			outer: 'true' | 'false';
			inner: 'true' | 'false';
			consoleLines: string[];
			table: string[][];
			activeCell?: { row: number; col: number };
		};

		function createTable(): string[][] {
			return Array.from({ length: 3 }, () => Array.from({ length: 10 }, () => ''));
		}

		function tableUntil(row: number, col: number): string[][] {
			const table = createTable();
			for (let r = 1; r <= 3; r += 1) {
				for (let c = 1; c <= 10; c += 1) {
					if (r < row || (r === row && c <= col)) {
						table[r - 1][c - 1] = String(r * c);
					}
				}
			}
			return table;
		}

		const logsRow1 = Array.from({ length: 10 }, (_, i) => `1 x ${i + 1} = ${i + 1}`);
		const logsRow2 = Array.from({ length: 10 }, (_, i) => `2 x ${i + 1} = ${(i + 1) * 2}`);
		const logsRow3 = Array.from({ length: 10 }, (_, i) => `3 x ${i + 1} = ${(i + 1) * 3}`);

		const steps: Step[] = [
			{ line: 1, message: 'Inicia el for externo con fila = 1.', fila: 1, col: 1, valor: 1, outer: 'true', inner: 'true', consoleLines: [], table: createTable(), activeCell: { row: 1, col: 1 } },
			{ line: 2, message: 'Entra al for interno para la fila 1 con col = 1.', fila: 1, col: 1, valor: 1, outer: 'true', inner: 'true', consoleLines: [], table: createTable(), activeCell: { row: 1, col: 1 } },
			{ line: 4, message: 'Calcula y muestra 1 x 1 = 1.', fila: 1, col: 1, valor: 1, outer: 'true', inner: 'true', consoleLines: ['1 x 1 = 1'], table: tableUntil(1, 1), activeCell: { row: 1, col: 1 } },
			{ line: 4, message: 'Siguiente columna: 1 x 2 = 2.', fila: 1, col: 2, valor: 2, outer: 'true', inner: 'true', consoleLines: ['1 x 1 = 1', '1 x 2 = 2'], table: tableUntil(1, 2), activeCell: { row: 1, col: 2 } },
			{ line: 4, message: 'Siguiente columna: 1 x 3 = 3.', fila: 1, col: 3, valor: 3, outer: 'true', inner: 'true', consoleLines: ['1 x 1 = 1', '1 x 2 = 2', '1 x 3 = 3'], table: tableUntil(1, 3), activeCell: { row: 1, col: 3 } },
			{ line: 5, message: 'Se repite el mismo patron hasta col = 10 y cierra la fila 1.', fila: 1, col: 10, valor: 10, outer: 'true', inner: 'false', consoleLines: logsRow1, table: tableUntil(1, 10), activeCell: { row: 1, col: 10 } },
			{ line: 1, message: 'Incrementa fila a 2 y vuelve a entrar al for interno.', fila: 2, col: 1, valor: 2, outer: 'true', inner: 'true', consoleLines: logsRow1, table: tableUntil(1, 10), activeCell: { row: 2, col: 1 } },
			{ line: 4, message: 'Primera multiplicacion de la fila 2: 2 x 1 = 2.', fila: 2, col: 1, valor: 2, outer: 'true', inner: 'true', consoleLines: [...logsRow1, '2 x 1 = 2'], table: tableUntil(2, 1), activeCell: { row: 2, col: 1 } },
			{ line: 5, message: 'Se completa la fila 2 hasta 2 x 10 = 20.', fila: 2, col: 10, valor: 20, outer: 'true', inner: 'false', consoleLines: [...logsRow1, ...logsRow2], table: tableUntil(2, 10), activeCell: { row: 2, col: 10 } },
			{ line: 1, message: 'Incrementa fila a 3 y arranca la ultima pasada.', fila: 3, col: 1, valor: 3, outer: 'true', inner: 'true', consoleLines: [...logsRow1, ...logsRow2], table: tableUntil(2, 10), activeCell: { row: 3, col: 1 } },
			{ line: 4, message: 'Primera multiplicacion de fila 3: 3 x 1 = 3.', fila: 3, col: 1, valor: 3, outer: 'true', inner: 'true', consoleLines: [...logsRow1, ...logsRow2, '3 x 1 = 3'], table: tableUntil(3, 1), activeCell: { row: 3, col: 1 } },
			{ line: 5, message: 'Se completa la fila 3 y se termina toda la tabla del 1 al 3 por 10.', fila: 3, col: 10, valor: 30, outer: 'true', inner: 'false', consoleLines: [...logsRow1, ...logsRow2, ...logsRow3], table: tableUntil(3, 10), activeCell: { row: 3, col: 10 } },
			{ line: 1, message: 'fila se incrementa a 4 y la condicion externa 4 <= 3 da false. Fin del for anidado.', fila: 4, col: 10, valor: 30, outer: 'false', inner: 'false', consoleLines: [...logsRow1, ...logsRow2, ...logsRow3], table: tableUntil(3, 10) },
		];

		let currentStep = 0;

		const prevBtn = document.getElementById('fn-prev') as HTMLButtonElement;
		const nextBtn = document.getElementById('fn-next') as HTMLButtonElement;
		const lineBadge = document.getElementById('fn-line') as HTMLElement;
		const stepBadge = document.getElementById('fn-step') as HTMLElement;
		const copyEl = document.getElementById('fn-copy') as HTMLElement;
		const filaEl = document.getElementById('fn-fila') as HTMLElement;
		const colEl = document.getElementById('fn-col') as HTMLElement;
		const valorEl = document.getElementById('fn-valor') as HTMLElement;
		const outerEl = document.getElementById('fn-outer') as HTMLElement;
		const innerEl = document.getElementById('fn-inner') as HTMLElement;
		const consoleEl = document.getElementById('fn-console') as HTMLElement;
		const fillEl = document.getElementById('fn-fill') as HTMLElement;
		const tableEl = document.getElementById('mult-table') as HTMLTableElement;

		function renderTable(step: Step): void {
			const bodyRows = tableEl.querySelectorAll('tbody tr');
			bodyRows.forEach((tr, rowIndex) => {
				const cells = tr.querySelectorAll('td');
				cells.forEach((cell, colIndex) => {
					cell.textContent = step.table[rowIndex][colIndex];
					cell.classList.remove('mult-cell-active');
				});
			});

			if (step.activeCell) {
				const row = bodyRows[step.activeCell.row - 1];
				const cell = row?.querySelectorAll('td')[step.activeCell.col - 1];
				cell?.classList.add('mult-cell-active');
			}
		}

		function renderStep(): void {
			const step = steps[currentStep];

			document.querySelectorAll<HTMLElement>('.fn-row').forEach((row) => {
				row.classList.toggle('active', Number(row.dataset.line) === step.line);
			});

			lineBadge.textContent = `Linea activa: ${step.line}`;
			stepBadge.textContent = `Paso ${currentStep + 1} / ${steps.length}`;
			copyEl.innerHTML = `<strong>Paso ${currentStep + 1}:</strong> ${step.message}`;
			filaEl.textContent = String(step.fila);
			colEl.textContent = String(step.col);
			valorEl.textContent = String(step.valor);
			outerEl.textContent = step.outer;
			innerEl.textContent = step.inner;
			outerEl.classList.toggle('fn-true', step.outer === 'true');
			outerEl.classList.toggle('fn-false', step.outer === 'false');
			innerEl.classList.toggle('fn-true', step.inner === 'true');
			innerEl.classList.toggle('fn-false', step.inner === 'false');

			consoleEl.innerHTML = '';
			step.consoleLines.forEach((line, index) => {
				const entry = document.createElement('div');
				entry.className = 'fn-log';
				entry.style.animationDelay = `${Math.min(index, 6) * 70}ms`;
				entry.textContent = `> ${line}`;
				consoleEl.appendChild(entry);
			});

			renderTable(step);
			fillEl.style.width = `${((currentStep + 1) / steps.length) * 100}%`;
			prevBtn.disabled = currentStep === 0;
			nextBtn.disabled = currentStep === steps.length - 1;
		}

		prevBtn.addEventListener('click', () => {
			if (currentStep > 0) {
				currentStep -= 1;
				renderStep();
			}
		});

		nextBtn.addEventListener('click', () => {
			if (currentStep < steps.length - 1) {
				currentStep += 1;
				renderStep();
			}
		});

		document.addEventListener('keydown', (event: KeyboardEvent) => {
			if (event.key === 'ArrowRight') nextBtn.click();
			if (event.key === 'ArrowLeft') prevBtn.click();
		});

		renderStep();
	</script>
</Layout>
