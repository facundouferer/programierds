---
import Layout from '../../layouts/Layout.astro';
import { getRelativePath } from '../../utils/paths';
---

<Layout title="Tipos de Datos en JavaScript - Programierds Retro View">
	<style is:global>
		@import url('https://fonts.googleapis.com/css2?family=VT323&family=Space+Mono:wght@400;700&display=swap');

		:root {
			--primary: #0df259;
			--crt-black: #050a05;
			--crt-dark: #0a140a;
		}

		html {
			scroll-behavior: smooth;
		}

		.crt-wrapper {
			background: radial-gradient(circle, #0a1a0a 0%, #050a05 100%);
			position: relative;
		}

		.crt-main {
			font-family: 'Space Mono', monospace;
			color: var(--primary);
			position: relative;
		}

		.font-retro {
			font-family: 'VT323', monospace;
		}

		/* Progress bar */
		#progress-bar {
			position: fixed;
			top: 0;
			left: 0;
			height: 3px;
			width: 0%;
			background: var(--primary);
			box-shadow: 0 0 10px var(--primary), 0 0 20px var(--primary);
			z-index: 200;
			transition: width 0.1s linear;
		}

		/* Sections */
		.section {
			min-height: 100vh;
			display: flex;
			align-items: center;
			justify-content: center;
			padding: 80px 24px 40px;
			position: relative;
			z-index: 10;
		}

		.section-inner {
			width: 100%;
			max-width: 1100px;
		}

		/* Reveal animations */
		.section-hidden {
			opacity: 0;
			transform: translateY(60px);
			transition: opacity 0.8s ease, transform 0.8s ease;
		}

		.section-visible {
			opacity: 1;
			transform: translateY(0);
		}

		.anim-item {
			opacity: 0;
			transform: translateY(30px);
			transition: opacity 0.6s ease, transform 0.6s ease;
			transition-delay: var(--delay, 0ms);
		}

		.section-visible .anim-item {
			opacity: 1;
			transform: translateY(0);
		}

		/* Divider */
		.section-divider {
			border: none;
			border-top: 1px solid rgba(13, 242, 89, 0.15);
			margin: 0 24px;
		}

		/* Code block */
		.code-block {
			background: rgba(0, 0, 0, 0.5);
			border: 1px solid rgba(13, 242, 89, 0.2);
			border-radius: 4px;
			padding: 16px 20px;
			font-family: 'Space Mono', monospace;
			font-size: 0.85rem;
			line-height: 1.7;
		}

		.code-comment { color: rgba(13, 242, 89, 0.4); font-style: italic; }
		.code-keyword { color: #61afef; }
		.code-string { color: #e5c07b; }
		.code-number { color: #d19a66; }
		.code-result { color: var(--primary); }

		/* Type cards */
		.type-card {
			border: 1px solid rgba(13, 242, 89, 0.25);
			background: rgba(13, 242, 89, 0.04);
			border-radius: 6px;
			padding: 12px 16px;
			transition: border-color 0.3s, box-shadow 0.3s;
		}

		.type-card:hover {
			border-color: var(--primary);
			box-shadow: 0 0 12px rgba(13, 242, 89, 0.2);
		}

		/* ==================== KEYFRAMES ==================== */

		@keyframes float {
			0%, 100% { transform: translateY(0px); }
			50% { transform: translateY(-12px); }
		}

		@keyframes float-slow {
			0%, 100% { transform: translateY(0px) rotate(0deg); }
			50% { transform: translateY(-18px) rotate(3deg); }
		}

		@keyframes blink-cursor {
			0%, 100% { opacity: 1; }
			50% { opacity: 0; }
		}

		@keyframes glow-pulse {
			0%, 100% { box-shadow: 0 0 10px var(--glow-color), 0 0 20px var(--glow-color); }
			50% { box-shadow: 0 0 25px var(--glow-color), 0 0 50px var(--glow-color); }
		}

		@keyframes spin-slow {
			from { transform: rotate(0deg); }
			to { transform: rotate(360deg); }
		}

		@keyframes orbit {
			from { transform: rotate(var(--orbit-start, 0deg)) translateX(var(--orbit-r, 80px)) rotate(calc(-1 * var(--orbit-start, 0deg))); }
			to { transform: rotate(calc(var(--orbit-start, 0deg) + 360deg)) translateX(var(--orbit-r, 80px)) rotate(calc(-1 * (var(--orbit-start, 0deg) + 360deg))); }
		}

		@keyframes true-pulse {
			0%, 100% { box-shadow: 0 0 15px #0df259, 0 0 30px #0df259; border-color: #0df259; }
			50% { box-shadow: 0 0 40px #0df259, 0 0 80px #0df259; border-color: #0df259; }
		}

		@keyframes false-pulse {
			0%, 100% { box-shadow: 0 0 15px #ef4444, 0 0 30px #ef4444; border-color: #ef4444; }
			50% { box-shadow: 0 0 40px #ef4444, 0 0 80px #ef4444; border-color: #ef4444; }
		}

		@keyframes binary-fall {
			0% { transform: translateY(-100%); opacity: 1; }
			100% { transform: translateY(100vh); opacity: 0; }
		}

		@keyframes typewriter-char {
			from { opacity: 0; transform: scale(1.5); }
			to { opacity: 1; transform: scale(1); }
		}

		@keyframes coercion-bad {
			0% { transform: scale(1); }
			30% { transform: scale(1.1) rotate(-2deg); color: #ef4444; }
			60% { transform: scale(1.15) rotate(2deg); }
			100% { transform: scale(1); color: #ef4444; }
		}

		@keyframes coercion-ok {
			0% { transform: scale(1); }
			50% { transform: scale(1.05); }
			100% { transform: scale(1); color: #0df259; }
		}

		@keyframes grow-number {
			from { letter-spacing: 0; }
			to { letter-spacing: 4px; }
		}

		/* ==================== SECTION 1: INTRO ==================== */

		.intro-title {
			font-family: 'VT323', monospace;
			font-size: clamp(2.5rem, 7vw, 6rem);
			text-shadow: 0 0 15px rgba(13, 242, 89, 0.7);
			line-height: 1;
		}

		.intro-subtitle {
			font-size: clamp(0.9rem, 2vw, 1.2rem);
			opacity: 0;
			overflow: hidden;
			white-space: nowrap;
			border-right: 2px solid var(--primary);
		}

		.intro-subtitle.typing-active {
			animation: typing-sub 2s steps(44) 0.5s forwards, blink-cursor 0.7s step-end infinite;
			width: 0;
		}

		@keyframes typing-sub {
			from { width: 0; opacity: 1; }
			to { width: 100%; opacity: 1; }
		}

		.js-logo {
			font-family: 'VT323', monospace;
			font-size: 8rem;
			color: var(--primary);
			text-shadow: 0 0 30px rgba(13, 242, 89, 0.8);
			animation: float-slow 4s ease-in-out infinite;
			line-height: 1;
		}

		.js-brackets {
			font-size: 6rem;
			opacity: 0.2;
			position: absolute;
			font-family: 'VT323', monospace;
		}

		/* ==================== SECTION 2: PRIMITIVOS vs OBJETOS ==================== */

		.split-col {
			border: 1px solid rgba(13, 242, 89, 0.2);
			border-radius: 8px;
			padding: 24px;
			background: rgba(13, 242, 89, 0.03);
		}

		.prim-badge {
			display: inline-block;
			border: 1px solid rgba(13, 242, 89, 0.4);
			background: rgba(13, 242, 89, 0.08);
			border-radius: 4px;
			padding: 4px 10px;
			font-size: 0.75rem;
			font-family: 'Space Mono', monospace;
			margin: 4px;
		}

		.obj-badge {
			display: inline-block;
			border: 1px solid rgba(59, 130, 246, 0.5);
			background: rgba(59, 130, 246, 0.08);
			border-radius: 4px;
			padding: 4px 10px;
			font-size: 0.75rem;
			font-family: 'Space Mono', monospace;
			margin: 4px;
			color: #93c5fd;
		}

		/* ==================== SECTION 3: STRING ==================== */

		.quote-anim {
			font-family: 'VT323', monospace;
			font-size: 8rem;
			color: var(--primary);
			opacity: 0;
			transform: scale(0.5);
			transition: opacity 0.4s ease, transform 0.4s ease;
		}

		.section-visible .quote-anim {
			opacity: 1;
			transform: scale(1);
		}

		.quote-left { transition-delay: 0.2s; }
		.quote-right { transition-delay: 1.6s; }

		.typed-word span {
			display: inline-block;
			opacity: 0;
			animation-fill-mode: forwards;
			animation-name: typewriter-char;
			animation-duration: 0.08s;
		}

		/* ==================== SECTION 4: NUMBER ==================== */

		.orbit-container {
			position: relative;
			width: 240px;
			height: 240px;
			margin: 0 auto;
		}

		.orbit-ring {
			position: absolute;
			top: 50%;
			left: 50%;
			border-radius: 50%;
			border: 1px dashed rgba(13, 242, 89, 0.2);
			transform: translate(-50%, -50%);
		}

		.orbit-planet {
			position: absolute;
			top: 50%;
			left: 50%;
			transform-origin: 0 0;
			animation: orbit linear infinite;
			animation-play-state: paused;
		}

		.section-visible .orbit-planet {
			animation-play-state: running;
		}

		.planet-label {
			font-family: 'VT323', monospace;
			font-size: 1.1rem;
			color: var(--primary);
			background: #050a05;
			border: 1px solid rgba(13, 242, 89, 0.3);
			padding: 2px 8px;
			border-radius: 3px;
			white-space: nowrap;
			transform: translateY(-50%);
			margin-left: 8px;
		}

		.orbit-center {
			position: absolute;
			top: 50%;
			left: 50%;
			transform: translate(-50%, -50%);
			font-family: 'VT323', monospace;
			font-size: 1.5rem;
			color: var(--primary);
			text-align: center;
			text-shadow: 0 0 20px var(--primary);
		}

		/* ==================== SECTION 5: BOOLEAN ==================== */

		.bool-box {
			border: 2px solid;
			border-radius: 8px;
			padding: 32px 24px;
			text-align: center;
			transition: all 0.3s;
		}

		.bool-true {
			border-color: #0df259;
			--glow-color: #0df259;
			animation: true-pulse 2s ease-in-out infinite;
		}

		.bool-false {
			border-color: #ef4444;
			--glow-color: #ef4444;
			animation: false-pulse 2s ease-in-out infinite;
			animation-delay: 1s;
		}

		.bool-label {
			font-family: 'VT323', monospace;
			font-size: 3.5rem;
			line-height: 1;
		}

		.binary-rain-wrapper {
			position: relative;
			height: 120px;
			overflow: hidden;
			border-radius: 4px;
			background: rgba(0, 0, 0, 0.3);
		}

		.binary-col {
			position: absolute;
			top: -100%;
			font-family: 'VT323', monospace;
			font-size: 1rem;
			color: var(--primary);
			opacity: 0.5;
			animation: binary-fall linear infinite;
			animation-play-state: paused;
			white-space: nowrap;
		}

		.section-visible .binary-col {
			animation-play-state: running;
		}

		/* ==================== SECTION 6: UNDEFINED vs NULL ==================== */

		.undef-box {
			border: 2px dashed rgba(13, 242, 89, 0.3);
			border-radius: 8px;
			padding: 32px;
			text-align: center;
			position: relative;
			background: rgba(13, 242, 89, 0.02);
		}

		.null-box {
			border: 2px solid rgba(239, 68, 68, 0.5);
			border-radius: 8px;
			padding: 32px;
			text-align: center;
			position: relative;
			background: rgba(239, 68, 68, 0.04);
		}

		.big-symbol {
			font-family: 'VT323', monospace;
			font-size: 5rem;
			line-height: 1;
		}

		/* ==================== SECTION 7: SYMBOL & BIGINT ==================== */

		.fingerprint {
			font-size: 5rem;
			animation: float 3s ease-in-out infinite;
			display: inline-block;
		}

		.bigint-num {
			font-family: 'VT323', monospace;
			font-size: 1.8rem;
			color: var(--primary);
			word-break: break-all;
			animation: grow-number 3s ease-in-out infinite alternate;
		}

		/* ==================== SECTION 8: TYPEOF ==================== */

		.terminal-window {
			background: rgba(0, 0, 0, 0.6);
			border: 1px solid rgba(13, 242, 89, 0.3);
			border-radius: 6px;
			overflow: hidden;
		}

		.terminal-titlebar {
			background: rgba(13, 242, 89, 0.1);
			padding: 8px 16px;
			border-bottom: 1px solid rgba(13, 242, 89, 0.2);
			font-size: 0.7rem;
			letter-spacing: 0.1em;
			display: flex;
			align-items: center;
			gap: 8px;
		}

		.terminal-dot {
			width: 10px;
			height: 10px;
			border-radius: 50%;
			background: rgba(13, 242, 89, 0.4);
		}

		.terminal-body {
			padding: 20px 24px;
			font-family: 'Space Mono', monospace;
			font-size: 0.85rem;
			line-height: 2;
		}

		.terminal-line {
			opacity: 0;
			transition: opacity 0.4s ease;
			transition-delay: var(--delay, 0ms);
		}

		.section-visible .terminal-line {
			opacity: 1;
		}

		.cursor-blink {
			display: inline-block;
			width: 8px;
			height: 1em;
			background: var(--primary);
			vertical-align: text-bottom;
			animation: blink-cursor 0.7s step-end infinite;
		}

		/* ==================== SECTION 9: COERCION ==================== */

		.coercion-row {
			display: flex;
			align-items: center;
			gap: 12px;
			padding: 14px 20px;
			border-radius: 6px;
			font-family: 'VT323', monospace;
			font-size: 1.6rem;
		}

		.coercion-bad-row {
			border: 1px solid rgba(239, 68, 68, 0.3);
			background: rgba(239, 68, 68, 0.05);
			color: #ef4444;
		}

		.coercion-ok-row {
			border: 1px solid rgba(13, 242, 89, 0.3);
			background: rgba(13, 242, 89, 0.05);
			color: var(--primary);
		}

		.eq-box {
			border: 2px solid;
			border-radius: 6px;
			padding: 16px 20px;
			text-align: center;
			font-family: 'VT323', monospace;
		}

		.eq-loose {
			border-color: rgba(239, 68, 68, 0.5);
			background: rgba(239, 68, 68, 0.05);
		}

		.eq-strict {
			border-color: rgba(13, 242, 89, 0.5);
			background: rgba(13, 242, 89, 0.05);
		}

		/* ==================== SECTION 10: RESUMEN ==================== */

		.summary-table {
			width: 100%;
			border-collapse: separate;
			border-spacing: 0 4px;
			font-size: 0.85rem;
		}

		.summary-table th {
			text-align: left;
			padding: 8px 12px;
			font-size: 0.7rem;
			letter-spacing: 0.1em;
			color: rgba(13, 242, 89, 0.5);
			border-bottom: 1px solid rgba(13, 242, 89, 0.15);
		}

		.summary-table td {
			padding: 10px 12px;
			border-bottom: 1px solid rgba(13, 242, 89, 0.07);
		}

		.summary-table tr:hover td {
			background: rgba(13, 242, 89, 0.04);
		}

		.badge-prim {
			display: inline-block;
			font-size: 0.65rem;
			padding: 1px 6px;
			border-radius: 3px;
			background: rgba(13, 242, 89, 0.15);
			border: 1px solid rgba(13, 242, 89, 0.3);
			color: var(--primary);
		}

		.badge-obj {
			display: inline-block;
			font-size: 0.65rem;
			padding: 1px 6px;
			border-radius: 3px;
			background: rgba(59, 130, 246, 0.15);
			border: 1px solid rgba(59, 130, 246, 0.4);
			color: #93c5fd;
		}

		.terminal-btn {
			border: 1px solid var(--primary);
			padding: 8px 24px;
			text-transform: uppercase;
			font-size: 0.875rem;
			font-weight: 700;
			transition: all 0.3s;
			background-color: rgba(13, 242, 89, 0.05);
			color: var(--primary);
			text-decoration: none;
			display: inline-block;
			font-family: 'Space Mono', monospace;
			letter-spacing: 0.05em;
		}

		.terminal-btn:hover {
			background-color: var(--primary);
			color: black;
			box-shadow: 0 0 20px rgba(13, 242, 89, 0.5);
		}

		/* Responsive helpers */
		@media (max-width: 768px) {
			.split-grid { flex-direction: column; }
			.orbit-container { width: 180px; height: 180px; }
			.js-logo { font-size: 5rem; }
		}
	</style>

	<div class="relative min-h-screen flex flex-col crt-wrapper">
		<!-- Progress bar -->
		<div id="progress-bar"></div>

		<div class="relative z-[200]">
		</div>

		<main class="flex-1 relative crt-main">

			<!-- ======================== SECTION 1: INTRO ======================== -->
			<section class="section section-hidden" id="sec-intro">
				<div class="section-inner text-center">
					<div class="anim-item" style="--delay: 0ms">
						<div class="text-xs tracking-widest opacity-40 mb-6 font-retro text-lg">PROGRAMIERDS_OS v1.0.4 // TOPIC: JS_TYPES</div>
					</div>

					<div class="relative inline-block mb-4 anim-item" style="--delay: 100ms">
						<span class="js-brackets" style="top:-20px; left:-60px; transform:rotate(-10deg)">{</span>
						<span class="js-brackets" style="top:-20px; right:-60px; transform:rotate(10deg)">}</span>
						<div class="js-logo">JS</div>
					</div>

					<div class="anim-item" style="--delay: 200ms">
						<h1 class="intro-title uppercase tracking-tight mb-4">
							&gt; Tipos de Datos
						</h1>
						<h1 class="intro-title uppercase tracking-tight mb-8" style="color: rgba(13,242,89,0.6)">
							en JavaScript
						</h1>
					</div>

					<div class="anim-item flex justify-center" style="--delay: 400ms">
						<p class="intro-subtitle text-lg md:text-xl" id="intro-subtitle">
							Cada valor tiene una identidad. Conocelas.
						</p>
					</div>

					<div class="anim-item mt-12 opacity-50" style="--delay: 600ms">
						<p class="text-sm animate-bounce" style="animation: float 2s ease-in-out infinite">&#8595; scroll para continuar</p>
					</div>
				</div>
			</section>

			<hr class="section-divider" />

			<!-- ======================== SECTION 2: PRIMITIVOS vs OBJETOS ======================== -->
			<section class="section section-hidden" id="sec-prims">
				<div class="section-inner">
					<div class="anim-item text-center mb-10" style="--delay: 0ms">
						<h2 class="font-retro text-4xl md:text-6xl uppercase tracking-tight">
							Primitivos <span class="opacity-30">vs</span> Objetos
						</h2>
						<p class="text-sm opacity-50 mt-2">El universo de los datos tiene DOS categorías fundamentales</p>
					</div>

					<div class="flex gap-8 split-grid">
						<!-- Primitivos -->
						<div class="split-col flex-1 anim-item" style="--delay: 150ms">
							<h3 class="font-retro text-3xl mb-2 text-center">Primitivos</h3>
							<p class="text-xs text-center opacity-50 mb-6">Valores simples, inmutables, copiados por valor</p>
							<div class="flex flex-wrap justify-center gap-1 mb-6">
								<span class="prim-badge anim-item" style="--delay: 250ms">string</span>
								<span class="prim-badge anim-item" style="--delay: 320ms">number</span>
								<span class="prim-badge anim-item" style="--delay: 390ms">boolean</span>
								<span class="prim-badge anim-item" style="--delay: 460ms">undefined</span>
								<span class="prim-badge anim-item" style="--delay: 530ms">null</span>
								<span class="prim-badge anim-item" style="--delay: 600ms">symbol</span>
								<span class="prim-badge anim-item" style="--delay: 670ms">bigint</span>
							</div>
							<div class="code-block text-xs">
								<span class="code-keyword">let</span> x = <span class="code-number">42</span>;<br>
								<span class="code-keyword">let</span> y = x; <span class="code-comment">// copia del valor</span><br>
								y = <span class="code-number">99</span>;<br>
								<span class="code-comment">// x sigue siendo 42</span>
							</div>
						</div>

						<!-- Objetos -->
						<div class="split-col flex-1 anim-item" style="--delay: 300ms">
							<h3 class="font-retro text-3xl mb-2 text-center" style="color: #93c5fd">Objetos</h3>
							<p class="text-xs text-center opacity-50 mb-6">Estructuras complejas, copiados por referencia</p>
							<div class="flex flex-wrap justify-center gap-1 mb-6">
								<span class="obj-badge anim-item" style="--delay: 400ms">Object</span>
								<span class="obj-badge anim-item" style="--delay: 470ms">Array</span>
								<span class="obj-badge anim-item" style="--delay: 540ms">Function</span>
								<span class="obj-badge anim-item" style="--delay: 610ms">Date</span>
								<span class="obj-badge anim-item" style="--delay: 680ms">RegExp</span>
								<span class="obj-badge anim-item" style="--delay: 750ms">Map / Set</span>
							</div>
							<div class="code-block text-xs">
								<span class="code-keyword">let</span> a = &lbrace; score: <span class="code-number">42</span> &rbrace;;<br>
								<span class="code-keyword">let</span> b = a; <span class="code-comment">// referencia!</span><br>
								b.score = <span class="code-number">99</span>;<br>
								<span class="code-comment">// a.score también es 99</span>
							</div>
						</div>
					</div>
				</div>
			</section>

			<hr class="section-divider" />

			<!-- ======================== SECTION 3: STRING ======================== -->
			<section class="section section-hidden" id="sec-string">
				<div class="section-inner">
