---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import { getRelativePath } from '../../utils/paths';
---

<Layout title="Introducción a la Algoritmia y C - Programierds Retro View">

	<style is:global>
		@import url('https://fonts.googleapis.com/css2?family=VT323&family=Space+Mono:wght@400;700&display=swap');
		:root { --primary: #0df259; }
		html { scroll-behavior: smooth; }
		.crt-wrapper { background: radial-gradient(circle, #0a1a0a 0%, #050a05 100%); }
		.crt-main { font-family: 'Space Mono', monospace; color: var(--primary); }
		.font-retro { font-family: 'VT323', monospace; }
		.section { min-height: 90vh; display:flex; align-items:center; justify-content:center; padding:96px 24px 48px; }
		.section-inner { width:100%; max-width:1100px; }
		.card { border:1px solid rgba(13,242,89,.25); background: rgba(13,242,89,.04); border-radius:8px; padding:20px; }
		.code { background: rgba(0,0,0,.45); border:1px solid rgba(13,242,89,.2); border-radius:8px; padding:16px; font-size:.82rem; line-height:1.7; overflow:auto; }
		.divider { border: none; border-top: 1px solid rgba(13,242,89,.15); margin: 0 24px; }
		.terminal-btn { border:1px solid var(--primary); padding:8px 22px; text-decoration:none; color:var(--primary); text-transform:uppercase; font-size:.85rem; }
		.terminal-btn:hover { background:var(--primary); color:#031103; }
	</style>

	<div class="crt-wrapper min-h-screen flex flex-col">
		<div class="relative z-[200]"><Header /></div>
		<main class="flex-1 crt-main">
			<section class="section">
				<div class="section-inner text-center">
					<p class="text-xs opacity-50 mb-2">PROGRAMIERDS // CONTENIDO CURRICULAR 2025</p>
					<h1 class="font-retro text-5xl md:text-7xl uppercase">Introducción a la Algoritmia y C</h1>
					<p class="mt-4 opacity-70">Unidad 1 · proceso, algoritmo, programa y estructura base en C</p>
				</div>
			</section>
			<hr class="divider" />
			<section class="section">
				<div class="section-inner grid md:grid-cols-2 gap-6">
					<div class="card">
						<h2 class="font-retro text-3xl mb-4">Foco de la unidad</h2>
						<ul class="space-y-2 text-sm opacity-90">
						<li>Proceso, acciones y estados</li>
						<li>Variables, constantes y representación de estado</li>
						<li>Algoritmo vs programa</li>
						<li>Paradigmas y buenas prácticas</li>
						</ul>
					</div>
					<div class="card">
						<h2 class="font-retro text-3xl mb-4">Ejemplo en C</h2>
						<pre class="code"><code>{`>#include <stdio.h>

int main(void) {
    const float IVA = 0.21f;
    float precio = 1000.0f;
    float total = precio + (precio * IVA);

    printf("Precio final: %.2f\n", total);
    return 0;
}`}</code></pre>
					</div>
				</div>
			</section>
			<hr class="divider" />
			<section class="section">
				<div class="section-inner">
					<h2 class="font-retro text-4xl mb-6 text-center">Claves didácticas</h2>
					<div class="grid md:grid-cols-3 gap-4">
					<div class="card"><p class="text-sm">Pensar en estados antes de codear evita errores de lógica.</p></div>
					<div class="card"><p class="text-sm">Un programa en C es algoritmo + sintaxis + validación.</p></div>
					<div class="card"><p class="text-sm">Buenas prácticas desde día 1: nombres claros, funciones cortas, comentarios útiles.</p></div>
					</div>
					<div class="mt-10 text-center">
						<a href={getRelativePath('/presentaciones')} class="terminal-btn">← Volver a presentaciones</a>
					</div>
				</div>
			</section>
		</main>
	</div>
</Layout>
