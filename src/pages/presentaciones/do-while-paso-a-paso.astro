---
import Layout from '../../layouts/Layout.astro';
import { getRelativePath } from '../../utils/paths';
---

<Layout title="Do-while paso a paso - Programierds">
	<style is:global>
		@import url('https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@400;500;600;700&family=Fira+Code:wght@400;500;700&display=swap');

		.dw-screen {
			--dw-bg: #0f0b1c;
			--dw-panel: #1a1330;
			--dw-primary: #f97316;
			--dw-cyan: #22d3ee;
			--dw-danger: #fb7185;
			min-height: 100vh;
			font-family: 'Chakra Petch', sans-serif;
			background:
				radial-gradient(circle at 85% 15%, rgba(34, 211, 238, 0.18), transparent 40%),
				radial-gradient(circle at 10% 80%, rgba(249, 115, 22, 0.16), transparent 42%),
				linear-gradient(150deg, #080611 0%, var(--dw-bg) 100%);
			color: #ffeedd;
		}

		.dw-shell { max-width: 1200px; margin: 0 auto; padding: 2.5rem 1rem 3rem; }
		.dw-title { font-size: clamp(2rem, 4vw, 3.2rem); line-height: 1.05; font-weight: 700; }
		.dw-sub { max-width: 65ch; color: rgba(255, 238, 221, 0.84); }

		.dw-grid { display: grid; grid-template-columns: repeat(12, minmax(0, 1fr)); gap: 1rem; }
		.dw-card { border-radius: 1rem; border: 1px solid rgba(249, 115, 22, 0.3); background: linear-gradient(155deg, rgba(26, 19, 48, 0.9), rgba(13, 10, 24, 0.95)); padding: 1rem; }
		.dw-code { grid-column: span 12; }
		.dw-state { grid-column: span 12; }
		.dw-console { grid-column: span 12; }
		@media (min-width: 1100px) {
			.dw-code { grid-column: span 6; }
			.dw-state { grid-column: span 3; }
			.dw-console { grid-column: span 3; }
		}

		.dw-badge { border: 1px solid rgba(34, 211, 238, 0.4); background: rgba(34, 211, 238, 0.12); border-radius: 999px; padding: 0.2rem 0.6rem; font-size: 0.72rem; font-family: 'Fira Code', monospace; }
		.dw-head { display: flex; justify-content: space-between; align-items: center; gap: 0.7rem; margin-bottom: 0.75rem; }

		.dw-code-panel { background: rgba(6, 5, 14, 0.88); border: 1px solid rgba(249, 115, 22, 0.24); border-radius: 0.8rem; padding: 0.75rem; }
		.dw-row { display: grid; grid-template-columns: 2rem 1fr; gap: 0.8rem; border-radius: 0.55rem; padding: 0.42rem 0.5rem; font-family: 'Fira Code', monospace; font-size: 0.9rem; transition: all 0.2s ease; color: rgba(255, 238, 221, 0.86); }
		.dw-row.active { background: linear-gradient(90deg, rgba(249, 115, 22, 0.26), rgba(249, 115, 22, 0.06)); outline: 1px solid rgba(249, 115, 22, 0.4); transform: translateX(3px); }
		.dw-ln { color: rgba(255, 238, 221, 0.45); text-align: right; }

		.dw-state-item { display: flex; justify-content: space-between; align-items: center; border: 1px solid rgba(34, 211, 238, 0.24); background: rgba(34, 211, 238, 0.07); border-radius: 0.65rem; padding: 0.62rem 0.7rem; font-family: 'Fira Code', monospace; margin-bottom: 0.5rem; font-size: 0.84rem; }
		.dw-value { color: var(--dw-primary); font-weight: 700; font-size: 1.02rem; }
		.dw-true { color: #86efac; }
		.dw-false { color: var(--dw-danger); }

		.dw-console-win { border: 1px solid rgba(34, 211, 238, 0.36); border-radius: 0.8rem; overflow: hidden; background: rgba(6, 5, 14, 0.88); }
		.dw-console-head { display: flex; justify-content: space-between; padding: 0.5rem 0.75rem; font-family: 'Fira Code', monospace; font-size: 0.72rem; background: rgba(34, 211, 238, 0.12); border-bottom: 1px solid rgba(34, 211, 238, 0.3); }
		.dw-console-body { min-height: 165px; padding: 0.75rem; font-family: 'Fira Code', monospace; font-size: 0.83rem; }
		.dw-log { opacity: 0; transform: translateY(8px); animation: dw-log-in 0.4s ease forwards; color: #cdeaff; }
		@keyframes dw-log-in { to { opacity: 1; transform: translateY(0); } }

		.dw-copy { margin-top: 0.85rem; border: 1px solid rgba(249, 115, 22, 0.32); background: rgba(249, 115, 22, 0.11); border-radius: 0.7rem; padding: 0.75rem; }
		.dw-controls { margin-top: 0.9rem; display: flex; gap: 0.7rem; flex-wrap: wrap; align-items: center; }
		.dw-btn { border: 1px solid rgba(249, 115, 22, 0.45); background: rgba(249, 115, 22, 0.13); color: #ffeedd; padding: 0.58rem 1rem; border-radius: 0.7rem; font-weight: 600; transition: all 0.2s ease; }
		.dw-btn:hover:not(:disabled) { background: rgba(249, 115, 22, 0.26); transform: translateY(-1px); box-shadow: 0 0 18px rgba(249, 115, 22, 0.24); }
		.dw-btn:disabled { opacity: 0.4; cursor: not-allowed; }

		.dw-track { margin-top: 0.8rem; height: 0.55rem; border-radius: 999px; background: rgba(255, 238, 221, 0.14); overflow: hidden; }
		.dw-fill { height: 100%; width: 0%; background: linear-gradient(90deg, var(--dw-primary), var(--dw-cyan)); transition: width 0.25s ease; }

		.dw-back { display: inline-block; margin-top: 1.5rem; color: var(--dw-cyan); text-decoration: none; border-bottom: 1px dashed rgba(34, 211, 238, 0.5); }
	</style>

	<div class="dw-screen">
		<main class="dw-shell">
			<header class="mb-6">
				<p class="dw-badge">do-while / simulacion guiada</p>
				<h1 class="dw-title mt-3">Ciclo <code>do-while</code> paso a paso</h1>
				<p class="dw-sub mt-3">Aca se ve clarito lo que hace especial al <code>do-while</code>: ejecuta el bloque al menos una vez y recien despues evalua la condicion.</p>
			</header>

			<section class="dw-grid" aria-live="polite">
				<article class="dw-card dw-code">
					<div class="dw-head">
						<strong>1) Codigo y linea activa</strong>
						<span class="dw-badge" id="dw-line">Linea activa: 1</span>
					</div>
					<div class="dw-code-panel">
						<div class="dw-row" data-line="1"><span class="dw-ln">1</span><span>let i = 1;</span></div>
						<div class="dw-row" data-line="2"><span class="dw-ln">2</span><span>do &#123;</span></div>
						<div class="dw-row" data-line="3"><span class="dw-ln">3</span><span>&nbsp;&nbsp;console.log(`Vuelta ${'{'}i{'}'}`);</span></div>
						<div class="dw-row" data-line="4"><span class="dw-ln">4</span><span>&nbsp;&nbsp;i = i + 1;</span></div>
						<div class="dw-row" data-line="5"><span class="dw-ln">5</span><span>&#125; while (i &lt;= 4);</span></div>
						<div class="dw-row" data-line="6"><span class="dw-ln">6</span><span>console.log('Fin do-while');</span></div>
					</div>

					<div class="dw-copy" id="dw-copy"><strong>Paso 1:</strong> Se declara <code>i</code> con valor 1.</div>
					<div class="dw-track"><div class="dw-fill" id="dw-fill"></div></div>

					<div class="dw-controls">
						<button id="dw-prev" class="dw-btn" type="button">⬅ Retroceder</button>
						<button id="dw-next" class="dw-btn" type="button">Avanzar ➡</button>
						<span class="dw-badge" id="dw-step">Paso 1 / 11</span>
					</div>
				</article>

				<article class="dw-card dw-state">
					<div class="dw-head"><strong>2) Estado interno</strong></div>
					<div class="dw-state-item"><span>i actual</span><span id="dw-i" class="dw-value">1</span></div>
					<div class="dw-state-item"><span>Vueltas ejecutadas</span><span id="dw-iterations" class="dw-value">0</span></div>
					<div class="dw-state-item"><span>Condicion i &lt;= 4</span><span id="dw-condition" class="dw-value">-</span></div>
				</article>

				<article class="dw-card dw-console">
					<div class="dw-head"><strong>3) Consola simulada</strong></div>
					<div class="dw-console-win">
						<div class="dw-console-head"><span>node do-while-demo.js</span><span>stdout</span></div>
						<div class="dw-console-body" id="dw-console"></div>
					</div>
				</article>
			</section>

			<a class="dw-back" href={getRelativePath('/presentaciones')}>← Volver a presentaciones</a>
		</main>
	</div>

	<script>
		type Step = {
			line: number;
			message: string;
			iValue: number;
			iterations: number;
			condition: 'true' | 'false' | '-';
			consoleLines: string[];
		};

		const steps: Step[] = [
			{ line: 1, message: 'Se declara i en 1.', iValue: 1, iterations: 0, condition: '-', consoleLines: [] },
			{ line: 2, message: 'Entra al bloque do. Este bloque SIEMPRE corre al menos una vez.', iValue: 1, iterations: 0, condition: '-', consoleLines: [] },
			{ line: 3, message: 'Imprime la primera vuelta en consola.', iValue: 1, iterations: 1, condition: '-', consoleLines: ['Vuelta 1'] },
			{ line: 4, message: 'Incrementa i. Ahora i vale 2.', iValue: 2, iterations: 1, condition: '-', consoleLines: ['Vuelta 1'] },
			{ line: 5, message: 'Recien ahora evalua la condicion. 2 <= 4 da true.', iValue: 2, iterations: 1, condition: 'true', consoleLines: ['Vuelta 1'] },
			{ line: 3, message: 'Segunda vuelta: vuelve al bloque y loguea Vuelta 2.', iValue: 2, iterations: 2, condition: 'true', consoleLines: ['Vuelta 1', 'Vuelta 2'] },
			{ line: 4, message: 'Incrementa a i = 3.', iValue: 3, iterations: 2, condition: 'true', consoleLines: ['Vuelta 1', 'Vuelta 2'] },
			{ line: 3, message: 'Tercera vuelta: imprime Vuelta 3.', iValue: 3, iterations: 3, condition: 'true', consoleLines: ['Vuelta 1', 'Vuelta 2', 'Vuelta 3'] },
			{ line: 3, message: 'Cuarta vuelta: imprime Vuelta 4.', iValue: 4, iterations: 4, condition: 'true', consoleLines: ['Vuelta 1', 'Vuelta 2', 'Vuelta 3', 'Vuelta 4'] },
			{ line: 5, message: 'Despues de incrementar a 5, 5 <= 4 da false. Sale del ciclo.', iValue: 5, iterations: 4, condition: 'false', consoleLines: ['Vuelta 1', 'Vuelta 2', 'Vuelta 3', 'Vuelta 4'] },
			{ line: 6, message: 'Ejecuta lo que sigue fuera del do-while.', iValue: 5, iterations: 4, condition: 'false', consoleLines: ['Vuelta 1', 'Vuelta 2', 'Vuelta 3', 'Vuelta 4', 'Fin do-while'] },
		];

		let currentStep = 0;

		const prevBtn = document.getElementById('dw-prev') as HTMLButtonElement;
		const nextBtn = document.getElementById('dw-next') as HTMLButtonElement;
		const lineBadge = document.getElementById('dw-line') as HTMLElement;
		const stepBadge = document.getElementById('dw-step') as HTMLElement;
		const copyEl = document.getElementById('dw-copy') as HTMLElement;
		const iEl = document.getElementById('dw-i') as HTMLElement;
		const iterEl = document.getElementById('dw-iterations') as HTMLElement;
		const condEl = document.getElementById('dw-condition') as HTMLElement;
		const consoleEl = document.getElementById('dw-console') as HTMLElement;
		const fillEl = document.getElementById('dw-fill') as HTMLElement;

		function renderStep(): void {
			const step = steps[currentStep];

			document.querySelectorAll<HTMLElement>('.dw-row').forEach((row) => {
				row.classList.toggle('active', Number(row.dataset.line) === step.line);
			});

			lineBadge.textContent = `Linea activa: ${step.line}`;
			stepBadge.textContent = `Paso ${currentStep + 1} / ${steps.length}`;
			copyEl.innerHTML = `<strong>Paso ${currentStep + 1}:</strong> ${step.message}`;
			iEl.textContent = String(step.iValue);
			iterEl.textContent = String(step.iterations);
			condEl.textContent = step.condition;
			condEl.classList.remove('dw-true', 'dw-false');
			if (step.condition === 'true') condEl.classList.add('dw-true');
			if (step.condition === 'false') condEl.classList.add('dw-false');

			consoleEl.innerHTML = '';
			step.consoleLines.forEach((line, index) => {
				const entry = document.createElement('div');
				entry.className = 'dw-log';
				entry.style.animationDelay = `${index * 80}ms`;
				entry.textContent = `> ${line}`;
				consoleEl.appendChild(entry);
			});

			fillEl.style.width = `${((currentStep + 1) / steps.length) * 100}%`;
			prevBtn.disabled = currentStep === 0;
			nextBtn.disabled = currentStep === steps.length - 1;
		}

		prevBtn.addEventListener('click', () => {
			if (currentStep > 0) {
				currentStep -= 1;
				renderStep();
			}
		});

		nextBtn.addEventListener('click', () => {
			if (currentStep < steps.length - 1) {
				currentStep += 1;
				renderStep();
			}
		});

		document.addEventListener('keydown', (event: KeyboardEvent) => {
			if (event.key === 'ArrowRight') nextBtn.click();
			if (event.key === 'ArrowLeft') prevBtn.click();
		});

		renderStep();
	</script>
</Layout>
