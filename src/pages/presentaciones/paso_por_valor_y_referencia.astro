						<p class="text-sm opacity-80">
							Los primitivos (<code style="color: #f59e0b">int</code>, <code style="color: #f59e0b">double</code>, <code style="color: #f59e0b">boolean</code>, <code style="color: #f59e0b">char</code>, <code style="color: #f59e0b">long</code>, <code style="color: #f59e0b">float</code>, <code style="color: #f59e0b">short</code>, <code style="color: #f59e0b">byte</code>)
							son los &Uacute;NICOS que viven directamente en el Stack. Todo lo dem&aacute;s &mdash; incluyendo <code style="color: #f59e0b">String</code>, arrays y cualquier clase custom &mdash; vive en el Heap.
						</p>
					</div>
				</div>
			</section>

			<hr class="section-divider" />

			<!-- ======================== SECTION 9: REGLAS DE ORO ======================== -->
			<section class="section section-hidden" id="sec-reglas">
				<div class="section-inner">
					<div class="anim-item text-center mb-10" style="--delay: 0ms">
						<span class="text-xs tracking-widest opacity-40 font-retro text-lg">S&Iacute;NTESIS</span>
						<h2 class="font-retro text-5xl uppercase tracking-tight">Reglas de Oro</h2>
						<p class="text-sm opacity-50 mt-2">Grab&aacute;telas. Son inamovibles.</p>
					</div>

					<div class="space-y-4" id="rules-container">
						<!-- Regla 1 - gold -->
						<div class="rule-card gold" id="rule-1">
							<div class="flex items-center gap-4">
								<div class="rule-num" style="color: #f59e0b">01</div>
								<div>
									<p class="font-bold text-lg" style="color: #f59e0b">Java SIEMPRE pasa por valor</p>
									<p class="text-sm opacity-70 mt-1">Sin excepciones. No existe "paso por referencia" en Java.</p>
								</div>
							</div>
						</div>

						<!-- Regla 2 -->
						<div class="rule-card green" id="rule-2">
							<div class="flex items-center gap-4">
								<div class="rule-num" style="color: var(--primary)">02</div>
								<div>
									<p class="font-bold" style="color: var(--primary)">Para primitivos: se copia el VALOR</p>
									<p class="text-sm opacity-70 mt-1">El m&eacute;todo recibe una copia. Cambiarla no afecta al original.</p>
								</div>
							</div>
						</div>

						<!-- Regla 3 -->
						<div class="rule-card cyan" id="rule-3">
							<div class="flex items-center gap-4">
								<div class="rule-num" style="color: #22d3ee">03</div>
								<div>
									<p class="font-bold" style="color: #22d3ee">Para objetos: se copia la REFERENCIA</p>
									<p class="text-sm opacity-70 mt-1">La copia contiene la misma direcci&oacute;n de memoria. Ambas apuntan al mismo objeto.</p>
								</div>
							</div>
						</div>

						<!-- Regla 4 -->
						<div class="rule-card green" id="rule-4">
							<div class="flex items-center gap-4">
								<div class="rule-num" style="color: var(--primary)">04</div>
								<div>
									<p class="font-bold" style="color: var(--primary)">Modificar el objeto a trav&eacute;s de la copia: S&Iacute; afecta al original</p>
									<p class="text-sm opacity-70 mt-1"><code>arr[0] = 99</code>, <code>p.nombre = "X"</code> &mdash; ambas referencias ven el cambio.</p>
								</div>
							</div>
						</div>

						<!-- Regla 5 -->
						<div class="rule-card red" id="rule-5">
							<div class="flex items-center gap-4">
								<div class="rule-num" style="color: #ef4444">05</div>
								<div>
									<p class="font-bold" style="color: #ef4444">Reasignar la referencia copiada: NO afecta al original</p>
									<p class="text-sm opacity-70 mt-1"><code>arr = new int[]...</code>, <code>p = new Persona()</code> &mdash; solo mueve la copia local.</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<hr class="section-divider" />

			<!-- ======================== SECTION 10: FIN ======================== -->
			<section class="section section-hidden" id="sec-fin">
				<div class="section-inner text-center">
					<div class="anim-item mb-6" style="--delay: 0ms">
						<div class="text-xs tracking-widest opacity-40 font-retro text-xl">ESTADO: SESION_COMPLETADA</div>
					</div>

					<div class="anim-item mb-4" style="--delay: 150ms">
						<h2 class="font-retro text-6xl uppercase tracking-tight" style="text-shadow: 0 0 30px rgba(13,242,89,0.7)">
							SESION FINALIZADA
						</h2>
					</div>

					<div class="anim-item mb-10" style="--delay: 300ms">
						<p class="text-sm opacity-50">
							Ahora sab&eacute;s la diferencia entre paso por valor y referencia en Java.<br>
							No la vayas a confundir con "paso por referencia" de otros lenguajes.
						</p>
					</div>

					<div class="anim-item flex justify-center gap-6 mb-10 flex-wrap" style="--delay: 450ms">
						<div class="type-card text-left" style="min-width: 200px">
							<p class="text-xs opacity-50 mb-1" style="color: #f59e0b">PRIMITIVOS</p>
							<p class="text-sm opacity-80">int, double, boolean, char, long, float, short, byte</p>
							<p class="text-xs opacity-50 mt-1">&#x2192; copia del valor</p>
						</div>
						<div class="type-card text-left" style="min-width: 200px; border-color: rgba(34,211,238,0.3); background: rgba(34,211,238,0.04)">
							<p class="text-xs opacity-50 mb-1" style="color: #22d3ee">OBJETOS</p>
							<p class="text-sm opacity-80">String, arrays, cualquier clase</p>
							<p class="text-xs opacity-50 mt-1">&#x2192; copia de la referencia</p>
						</div>
					</div>

					<div class="anim-item" style="--delay: 600ms">
						<p class="text-xs opacity-30 mb-6 tracking-widest">FIN DE SESION // DATOS PROCESADOS CORRECTAMENTE</p>
						<a href={getRelativePath('/presentaciones')} class="terminal-btn">
							&#8592; VOLVER A PRESENTACIONES
						</a>
					</div>
				</div>
			</section>

		</main>
	</div>

	<script>
		// ——— Progress bar ———
		const progressBar = document.getElementById('progress-bar') as HTMLElement;

		function updateProgress(): void {
			const scrollTop = window.scrollY;
			const docHeight = document.documentElement.scrollHeight - window.innerHeight;
			const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
			if (progressBar) progressBar.style.width = `${progress}%`;
		}

		window.addEventListener('scroll', updateProgress, { passive: true });
		updateProgress();

		// ——— IntersectionObserver for section reveals ———
		const sections = document.querySelectorAll('.section-hidden');

		const sectionObserver = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						const el = entry.target as HTMLElement;
						el.classList.add('section-visible');
						triggerSectionAnimations(el.id);
						sectionObserver.unobserve(el);
					}
				});
			},
			{ threshold: 0.2 }
		);

		sections.forEach((section) => sectionObserver.observe(section));

		// ——— Section-specific animations ———
		function triggerSectionAnimations(sectionId: string): void {
			switch (sectionId) {
				case 'sec-intro':
					triggerIntroTyping();
					break;
				case 'sec-primitivos':
					triggerPrimAnim();
					break;
				case 'sec-objetos':
					triggerObjAnim();
					break;
				case 'sec-trampa':
					triggerTrampaAnim();
					break;
				case 'sec-reglas':
					triggerRulesAnim();
					break;
			}
		}

		// INTRO: typing animation
		function triggerIntroTyping(): void {
			const el = document.getElementById('intro-subtitle') as HTMLElement | null;
			if (el) {
				setTimeout(() => {
					el.classList.add('typing-active');
				}, 600);
			}
		}

		// PRIMITIVOS: step by step animation
		function triggerPrimAnim(): void {
			const boxX = document.getElementById('prim-box-x') as HTMLElement | null;
			const arrow = document.getElementById('prim-arrow') as HTMLElement | null;
			const valX = document.getElementById('prim-val-x') as HTMLElement | null;
			const step2 = document.getElementById('prim-step2') as HTMLElement | null;

			setTimeout(() => {
				if (arrow) arrow.classList.add('visible');
			}, 600);

			setTimeout(() => {
				if (boxX) {
					boxX.style.opacity = '1';
					boxX.style.transition = 'opacity 0.5s ease';
				}
			}, 1000);

			setTimeout(() => {
				if (valX) {
					valX.textContent = '99';
					valX.classList.add('changed');
				}
			}, 2000);

			setTimeout(() => {
				if (step2) step2.classList.add('visible');
			}, 2800);
		}

		// OBJETOS: mostrar que arr se copia y ambas apuntan al mismo heap
		function triggerObjAnim(): void {
			const arrFrame = document.getElementById('obj-arr-frame') as HTMLElement | null;
			const heapContent = document.getElementById('obj-heap-content') as HTMLElement | null;
			const stepResult = document.getElementById('obj-step-result') as HTMLElement | null;

			setTimeout(() => {
				if (arrFrame) {
					arrFrame.style.opacity = '1';
					arrFrame.style.transition = 'opacity 0.5s ease';
				}
			}, 600);

			setTimeout(() => {
				if (heapContent) {
					heapContent.textContent = '[ 99, 2, 3 ]';
					heapContent.style.color = '#ef4444';
				}
			}, 1600);

			setTimeout(() => {
				if (stepResult) stepResult.classList.add('visible');
			}, 2400);
		}

		// TRAMPA: mostrar que arr se reasigna y nums no cambia
		function triggerTrampaAnim(): void {
			const arrFrame = document.getElementById('trap-arr-frame') as HTMLElement | null;
			const newObj = document.getElementById('trap-new-obj') as HTMLElement | null;
			const arrAddr = document.getElementById('trap-arr-addr') as HTMLElement | null;
			const stepResult = document.getElementById('trap-step-result') as HTMLElement | null;

			setTimeout(() => {
				if (arrFrame) {
					arrFrame.style.opacity = '1';
					arrFrame.style.transition = 'opacity 0.5s ease';
				}
			}, 600);

			setTimeout(() => {
				if (newObj) {
					newObj.style.opacity = '1';
					newObj.style.transition = 'opacity 0.5s ease';
				}
			}, 1400);

			setTimeout(() => {
				if (arrAddr) {
					arrAddr.textContent = '\u2192 0x9E3C (new)';
					arrAddr.style.color = '#ef4444';
				}
			}, 2200);

			setTimeout(() => {
				if (stepResult) stepResult.classList.add('visible');
			}, 3000);
		}

		// REGLAS: aparecen las cards una por una
		function triggerRulesAnim(): void {
			['rule-1', 'rule-2', 'rule-3', 'rule-4', 'rule-5'].forEach((id, i) => {
				setTimeout(() => {
					const el = document.getElementById(id) as HTMLElement | null;
					if (el) el.classList.add('pop-simple');
				}, i * 250);
			});
		}

		// Initial check for sections already visible on load
		sections.forEach((section) => {
			const rect = section.getBoundingClientRect();
			if (rect.top < window.innerHeight * 0.8) {
				const el = section as HTMLElement;
				el.classList.add('section-visible');
				triggerSectionAnimations(el.id);
				sectionObserver.unobserve(el);
			}
		});
	</script>
</Layout>
