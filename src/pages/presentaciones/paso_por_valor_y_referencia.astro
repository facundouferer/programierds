---
import Layout from '../../layouts/Layout.astro';
import { getRelativePath } from '../../utils/paths';
---

<Layout title="Paso por Valor y Referencia en Java - Programierds">
	<style is:global>
		@import url('https://fonts.googleapis.com/css2?family=VT323&family=Space+Mono:wght@400;700&display=swap');

		:root {
			--primary: #0df259;
			--crt-black: #050a05;
			--crt-dark: #0a140a;
			--cyan: #22d3ee;
			--amber: #f59e0b;
			--orange: #fb923c;
		}

		html {
			scroll-behavior: smooth;
		}

		.crt-wrapper {
			background: radial-gradient(circle, #0a1a0a 0%, #050a05 100%);
			position: relative;
		}

		.crt-main {
			font-family: 'Space Mono', monospace;
			color: var(--primary);
			position: relative;
		}

		.font-retro {
			font-family: 'VT323', monospace;
		}

		/* Progress bar */
		#progress-bar {
			position: fixed;
			top: 0;
			left: 0;
			height: 3px;
			width: 0%;
			background: var(--primary);
			box-shadow: 0 0 10px var(--primary), 0 0 20px var(--primary);
			z-index: 200;
			transition: width 0.1s linear;
		}

		/* Sections */
		.section {
			min-height: 100vh;
			display: flex;
			align-items: center;
			justify-content: center;
			padding: 80px 24px 40px;
			position: relative;
			z-index: 10;
		}

		.section-inner {
			width: 100%;
			max-width: 1100px;
		}

		/* Reveal animations */
		.section-hidden {
			opacity: 0;
			transform: translateY(60px);
			transition: opacity 0.8s ease, transform 0.8s ease;
		}

		.section-visible {
			opacity: 1;
			transform: translateY(0);
		}

		.anim-item {
			opacity: 0;
			transform: translateY(30px);
			transition: opacity 0.6s ease, transform 0.6s ease;
			transition-delay: var(--delay, 0ms);
		}

		.section-visible .anim-item {
			opacity: 1;
			transform: translateY(0);
		}

		/* Divider */
		.section-divider {
			border: none;
			border-top: 1px solid rgba(13, 242, 89, 0.15);
			margin: 0 24px;
		}

		/* Code block */
		.code-block {
			background: rgba(0, 0, 0, 0.5);
			border: 1px solid rgba(13, 242, 89, 0.2);
			border-radius: 4px;
			padding: 16px 20px;
			font-family: 'Space Mono', monospace;
			font-size: 0.85rem;
			line-height: 1.7;
		}

		.code-comment { color: rgba(13, 242, 89, 0.4); font-style: italic; }
		.code-keyword { color: #61afef; }
		.code-string { color: #e5c07b; }
		.code-number { color: #d19a66; }
		.code-result { color: var(--primary); }
		.code-type { color: #f59e0b; }
		.code-class { color: #c678dd; }

		/* ==================== KEYFRAMES ==================== */

		@keyframes float {
			0%, 100% { transform: translateY(0px); }
			50% { transform: translateY(-12px); }
		}

		@keyframes float-slow {
			0%, 100% { transform: translateY(0px) rotate(0deg); }
			50% { transform: translateY(-18px) rotate(3deg); }
		}

		@keyframes blink-cursor {
			0%, 100% { opacity: 1; }
			50% { opacity: 0; }
		}

		@keyframes typing-sub {
			from { width: 0; opacity: 1; }
			to { width: 100%; opacity: 1; }
		}

		@keyframes glow-amber {
			0%, 100% { box-shadow: 0 0 8px rgba(245,158,11,0.4); }
			50% { box-shadow: 0 0 25px rgba(245,158,11,0.9), 0 0 50px rgba(245,158,11,0.5); }
		}

		@keyframes glow-cyan {
			0%, 100% { box-shadow: 0 0 8px rgba(34,211,238,0.4); }
			50% { box-shadow: 0 0 25px rgba(34,211,238,0.9), 0 0 50px rgba(34,211,238,0.5); }
		}

		@keyframes gold-pulse {
			0%, 100% {
				box-shadow: 0 0 15px rgba(245,158,11,0.6), 0 0 30px rgba(245,158,11,0.3);
				border-color: rgba(245,158,11,0.8);
			}
			50% {
				box-shadow: 0 0 40px rgba(245,158,11,1), 0 0 80px rgba(245,158,11,0.6);
				border-color: #f59e0b;
			}
		}

		@keyframes card-pop {
			from { opacity: 0; transform: translateY(40px) scale(0.9); }
			to { opacity: 1; transform: translateY(0) scale(1); }
		}

		/* ==================== SECTION 1: INTRO ==================== */

		.intro-title {
			font-family: 'VT323', monospace;
			font-size: clamp(2.5rem, 7vw, 6rem);
			text-shadow: 0 0 15px rgba(13, 242, 89, 0.7);
			line-height: 1;
		}

		.intro-subtitle {
			font-size: clamp(0.9rem, 2vw, 1.1rem);
			opacity: 0;
			overflow: hidden;
			white-space: nowrap;
			border-right: 2px solid var(--primary);
		}

		.intro-subtitle.typing-active {
			animation: typing-sub 3s steps(52) 0.5s forwards, blink-cursor 0.7s step-end infinite;
			width: 0;
		}

		.java-logo {
			font-family: 'VT323', monospace;
			font-size: 7rem;
			color: #f59e0b;
			text-shadow: 0 0 30px rgba(245,158,11,0.8);
			animation: float-slow 4s ease-in-out infinite;
			line-height: 1;
		}

		.intro-box {
			border: 2px solid;
			border-radius: 8px;
			padding: 20px 24px;
			text-align: center;
			min-width: 140px;
		}

		.intro-box-valor {
			border-color: rgba(245,158,11,0.6);
			background: rgba(245,158,11,0.06);
			animation: glow-amber 2.5s ease-in-out infinite;
		}

		.intro-box-ref {
			border-color: rgba(34,211,238,0.6);
			background: rgba(34,211,238,0.06);
			animation: glow-cyan 2.5s ease-in-out infinite;
			animation-delay: 1.2s;
		}

		/* ==================== MEMORY LAYOUTS ==================== */

		.memory-col {
			border: 2px solid;
			border-radius: 8px;
			padding: 20px;
			min-height: 300px;
			position: relative;
		}

		.stack-col {
			border-color: rgba(13,242,89,0.4);
			background: rgba(13,242,89,0.03);
		}

		.heap-col {
			border-color: rgba(34,211,238,0.4);
			background: rgba(34,211,238,0.03);
		}

		.memory-label {
			font-family: 'VT323', monospace;
			font-size: 1.5rem;
			letter-spacing: 0.1em;
			text-align: center;
			margin-bottom: 16px;
		}

		.stack-frame {
			border: 1px solid rgba(13,242,89,0.3);
			background: rgba(13,242,89,0.05);
			border-radius: 4px;
			padding: 8px 12px;
			margin-bottom: 8px;
			font-size: 0.8rem;
			display: flex;
			justify-content: space-between;
			align-items: center;
		}

		.stack-frame.prim-frame {
			border-color: rgba(245,158,11,0.4);
			background: rgba(245,158,11,0.05);
		}

		.stack-frame.ref-frame {
			border-color: rgba(34,211,238,0.4);
			background: rgba(34,211,238,0.05);
		}

		.heap-object {
			border: 2px solid rgba(13,242,89,0.4);
			border-radius: 6px;
			padding: 10px 14px;
			margin: 8px;
			font-size: 0.78rem;
			display: inline-block;
		}

		.heap-addr {
			font-size: 0.65rem;
			opacity: 0.4;
			font-family: 'Space Mono', monospace;
		}

		/* ==================== STEP ANIMATIONS ==================== */

		.anim-box {
			border: 2px solid;
			border-radius: 8px;
			padding: 20px 24px;
			text-align: center;
			min-width: 110px;
			transition: all 0.5s ease;
		}

		.anim-box-prim {
			border-color: rgba(245,158,11,0.5);
			background: rgba(245,158,11,0.05);
		}

		.anim-box-ref {
			border-color: rgba(34,211,238,0.5);
			background: rgba(34,211,238,0.05);
		}

		.anim-box-var {
			font-family: 'VT323', monospace;
			font-size: 0.9rem;
			opacity: 0.5;
			margin-bottom: 4px;
		}

		.anim-box-val {
			font-family: 'VT323', monospace;
			font-size: 2.5rem;
			line-height: 1;
			transition: color 0.5s ease;
		}

		.anim-box-val.changed {
			color: #ef4444;
		}

		.anim-arrow {
			display: flex;
			flex-direction: column;
			align-items: center;
			padding: 0 8px;
			opacity: 0;
			transition: opacity 0.5s ease;
		}

		.anim-arrow.visible {
			opacity: 1;
		}

		.step-result {
			opacity: 0;
			transition: opacity 0.6s ease;
		}

		.step-result.visible {
			opacity: 1;
		}

		.step-badge {
			display: inline-block;
			font-family: 'Space Mono', monospace;
			font-size: 0.7rem;
			padding: 2px 8px;
			border-radius: 3px;
		}

		.step-badge-ok {
			background: rgba(13,242,89,0.15);
			border: 1px solid rgba(13,242,89,0.4);
			color: var(--primary);
		}

		.step-badge-warn {
			background: rgba(245,158,11,0.15);
			border: 1px solid rgba(245,158,11,0.4);
			color: #f59e0b;
		}

		/* ==================== SECTION 9: REGLAS ==================== */

		.rule-card {
			border: 1px solid;
			border-radius: 8px;
			padding: 16px 20px;
			opacity: 0;
		}

		.rule-card.gold {
			border-color: rgba(245,158,11,0.7);
			background: rgba(245,158,11,0.06);
		}

		.rule-card.green {
			border-color: rgba(13,242,89,0.35);
			background: rgba(13,242,89,0.04);
		}

		.rule-card.cyan {
			border-color: rgba(34,211,238,0.35);
			background: rgba(34,211,238,0.04);
		}

		.rule-card.red {
			border-color: rgba(239,68,68,0.35);
			background: rgba(239,68,68,0.04);
		}

		.rule-card.pop-simple {
			animation: card-pop 0.5s ease forwards;
			animation-delay: var(--pop-delay, 0ms);
		}

		.rule-card.gold.pop-simple {
			animation: card-pop 0.5s ease forwards, gold-pulse 2s ease-in-out 0.5s infinite;
		}

		.rule-num {
			font-family: 'VT323', monospace;
			font-size: 3rem;
			line-height: 1;
			flex-shrink: 0;
		}

		/* ==================== TERMINAL STYLES ==================== */

		.terminal-btn {
			border: 1px solid var(--primary);
			padding: 8px 24px;
			text-transform: uppercase;
			font-size: 0.875rem;
			font-weight: 700;
			transition: all 0.3s;
			background-color: rgba(13, 242, 89, 0.05);
			color: var(--primary);
			text-decoration: none;
			display: inline-block;
			font-family: 'Space Mono', monospace;
			letter-spacing: 0.05em;
		}

		.terminal-btn:hover {
			background-color: var(--primary);
			color: black;
			box-shadow: 0 0 20px rgba(13, 242, 89, 0.5);
		}

		.split-col {
			border: 1px solid rgba(13, 242, 89, 0.2);
			border-radius: 8px;
			padding: 24px;
			background: rgba(13, 242, 89, 0.03);
		}

		.type-card {
			border: 1px solid rgba(13, 242, 89, 0.25);
			background: rgba(13, 242, 89, 0.04);
			border-radius: 6px;
			padding: 12px 16px;
			transition: border-color 0.3s, box-shadow 0.3s;
		}

		.type-card:hover {
			border-color: var(--primary);
			box-shadow: 0 0 12px rgba(13, 242, 89, 0.2);
		}

		/* Responsive */
		@media (max-width: 768px) {
			.split-grid { flex-direction: column; }
			.java-logo { font-size: 5rem; }
			.step-visual { flex-direction: column; align-items: center; }
		}
	</style>

	<div class="relative min-h-screen flex flex-col crt-wrapper">
		<!-- Progress bar -->
		<div id="progress-bar"></div>

		<div class="relative z-[200]">
		</div>

		<main class="flex-1 relative crt-main">

			<!-- ======================== SECTION 1: INTRO ======================== -->
			<section class="section section-hidden" id="sec-intro">
				<div class="section-inner text-center">
					<div class="anim-item" style="--delay: 0ms">
						<div class="text-xs tracking-widest opacity-40 mb-6 font-retro text-lg">PROGRAMIERDS_OS v1.0.4 // TOPIC: JAVA_MEMORY</div>
					</div>

					<div class="anim-item mb-4" style="--delay: 100ms">
						<div class="java-logo">JAVA</div>
					</div>

					<div class="anim-item" style="--delay: 200ms">
						<h1 class="intro-title uppercase tracking-tight mb-2">
							&gt; Paso por Valor
						</h1>
						<h1 class="intro-title uppercase tracking-tight mb-8" style="color: rgba(13,242,89,0.6)">
							y Referencia
						</h1>
					</div>

					<div class="anim-item flex justify-center mb-8" style="--delay: 400ms">
						<p class="intro-subtitle" id="intro-subtitle">
							En Java, todo se pasa por valor. Pero no es tan simple como suena.
						</p>
					</div>

					<!-- Dos cajas intro -->
					<div class="anim-item flex justify-center gap-6 flex-wrap items-center" style="--delay: 550ms">
						<div class="intro-box intro-box-valor">
							<div class="font-retro text-3xl" style="color: #f59e0b">&#x2750;</div>
							<div class="font-retro text-xl mt-1" style="color: #f59e0b">VALOR</div>
							<div class="text-xs opacity-50 mt-1">copia directa</div>
						</div>
						<div class="font-retro text-3xl opacity-30">&#8596;</div>
						<div class="intro-box intro-box-ref">
							<div class="font-retro text-3xl" style="color: #22d3ee">&#x2794;</div>
							<div class="font-retro text-xl mt-1" style="color: #22d3ee">REFERENCIA</div>
							<div class="text-xs opacity-50 mt-1">direcci&oacute;n de memoria</div>
						</div>
					</div>

					<div class="anim-item mt-12 opacity-50" style="--delay: 700ms">
						<p class="text-sm" style="animation: float 2s ease-in-out infinite">&#8595; scroll para continuar</p>
					</div>
				</div>
			</section>

			<hr class="section-divider" />

			<!-- ======================== SECTION 2: STACK vs HEAP ======================== -->
			<section class="section section-hidden" id="sec-memoria">
				<div class="section-inner">
					<div class="anim-item text-center mb-10" style="--delay: 0ms">
						<span class="text-xs tracking-widest opacity-40 font-retro text-lg">FUNDAMENTO</span>
						<h2 class="font-retro text-5xl uppercase tracking-tight">Stack vs Heap</h2>
						<p class="text-sm opacity-50 mt-2">Primero entend&eacute; c&oacute;mo Java organiza la memoria. Sin esto, nada de lo que viene tiene sentido.</p>
					</div>

					<div class="flex gap-6 split-grid">
						<!-- STACK -->
						<div class="flex-1 anim-item memory-col stack-col" style="--delay: 150ms">
							<div class="memory-label" style="color: var(--primary)">STACK</div>
							<p class="text-xs opacity-50 text-center mb-4">Variables locales y referencias. LIFO.</p>

							<div class="stack-frame prim-frame anim-item" style="--delay: 300ms">
								<span style="color: #f59e0b">int x</span>
								<span style="color: #f59e0b">42</span>
							</div>
							<div class="stack-frame prim-frame anim-item" style="--delay: 400ms">
								<span style="color: #f59e0b">boolean b</span>
								<span style="color: #f59e0b">true</span>
							</div>
							<div class="stack-frame ref-frame anim-item" style="--delay: 500ms">
								<span style="color: #22d3ee">int[] nums</span>
								<span style="color: #22d3ee" class="text-xs">&#x2192; 0x4A2F</span>
							</div>
							<div class="stack-frame ref-frame anim-item" style="--delay: 600ms">
								<span style="color: #22d3ee">Persona p</span>
								<span style="color: #22d3ee" class="text-xs">&#x2192; 0x8C1D</span>
							</div>

							<p class="text-xs opacity-40 mt-4 text-center">
								Primitivos: el valor vive ac&aacute;.<br>
								Objetos: solo la direcci&oacute;n (referencia).
							</p>
						</div>

						<!-- HEAP -->
						<div class="flex-1 anim-item memory-col heap-col" style="--delay: 300ms">
							<div class="memory-label" style="color: #22d3ee">HEAP</div>
							<p class="text-xs opacity-50 text-center mb-4">Objetos reales. Gestionado por el GC.</p>

							<div class="flex flex-wrap justify-around">
								<div class="heap-object anim-item" style="--delay: 500ms">
									<div class="heap-addr">0x4A2F</div>
									<div class="font-retro text-xl" style="color: var(--primary)">int[ ]</div>
									<div class="text-xs mt-1 opacity-70">[ 1, 2, 3 ]</div>
								</div>
								<div class="heap-object anim-item" style="--delay: 650ms">
									<div class="heap-addr">0x8C1D</div>
									<div class="font-retro text-xl" style="color: #c678dd">Persona</div>
									<div class="text-xs mt-1 opacity-70">nombre: "Ana"</div>
								</div>
								<div class="heap-object anim-item" style="--delay: 800ms">
									<div class="heap-addr">0x3F0B</div>
									<div class="font-retro text-xl" style="color: #f59e0b">String</div>
									<div class="text-xs mt-1 opacity-70">"Hola"</div>
								</div>
							</div>

							<p class="text-xs opacity-40 mt-4 text-center">
								Los objetos reales viven ac&aacute;.<br>
								El Stack guarda la direcci&oacute;n para llegar.
							</p>
						</div>
					</div>

					<div class="anim-item mt-6 type-card" style="--delay: 700ms">
						<p class="text-xs opacity-50 mb-2">LA REGLA FUNDAMENTAL</p>
						<p class="text-sm">
							Cuando Java "pasa" algo a un m&eacute;todo, lo que viaja es el contenido de la casilla del Stack.
							Para primitivos eso es el <strong style="color: #f59e0b">valor directo</strong>.
							Para objetos eso es la <strong style="color: #22d3ee">direcci&oacute;n de memoria</strong> (la referencia).
							En AMBOS casos: se copia.
						</p>
					</div>
				</div>
			</section>

			<hr class="section-divider" />

			<!-- ======================== SECTION 3: PASO POR VALOR (primitivos) ======================== -->
			<section class="section section-hidden" id="sec-primitivos">
				<div class="section-inner">
					<div class="anim-item text-center mb-10" style="--delay: 0ms">
						<span class="text-xs tracking-widest opacity-40 font-retro text-lg">CASO 01</span>
						<h2 class="font-retro text-5xl uppercase tracking-tight">Paso por Valor</h2>
						<p class="text-sm opacity-50 mt-2">Con primitivos (int, double, boolean, char...)</p>
					</div>

					<div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-start">
						<!-- C&oacute;digo -->
						<div>
							<div class="anim-item code-block text-xs mb-4" style="--delay: 150ms">
								<span class="code-keyword">void</span> <span class="code-result">cambiar</span>(<span class="code-type">int</span> x) &lbrace;<br>
								&nbsp;&nbsp;x = <span class="code-number">99</span>;<br>
								&nbsp;&nbsp;<span class="code-comment">// x es una COPIA local</span><br>
								&rbrace;<br>
								<br>
								<span class="code-type">int</span> a = <span class="code-number">5</span>;<br>
								<span class="code-result">cambiar</span>(a);<br>
								System.out.println(a); <span class="code-comment">// 5 &larr; no cambi&oacute;</span>
							</div>

							<div class="anim-item type-card" style="--delay: 300ms">
								<p class="text-xs opacity-50 mb-1">POR QU&Eacute;</p>
								<p class="text-sm opacity-80">
									Java copia el valor <span style="color: #f59e0b">5</span> en una nueva variable <span style="color: #f59e0b">x</span>.
									Cualquier cambio a <code style="color: #f59e0b">x</code> es local al m&eacute;todo.
									<code style="color: var(--primary)">a</code> nunca se toca.
								</p>
							</div>
						</div>

						<!-- Animaci&oacute;n paso a paso -->
						<div class="anim-item" style="--delay: 200ms">
							<p class="text-xs opacity-40 mb-4 tracking-widest text-center">VISUALIZACI&Oacute;N</p>

							<div class="flex justify-center gap-4 items-center step-visual" id="prim-visual">
								<!-- Caja a -->
								<div class="anim-box anim-box-prim" id="prim-box-a">
									<div class="anim-box-var">a</div>
									<div class="anim-box-val" id="prim-val-a" style="color: #f59e0b">5</div>
								</div>

								<!-- Flecha -->
								<div class="anim-arrow" id="prim-arrow">
									<span style="color: #f59e0b; font-family: 'VT323', monospace; font-size: 2rem">&#x2500;&#x2500;&#x2500;&gt;</span>
									<span style="color: #f59e0b; font-size: 0.6rem; margin-top: -8px">copia</span>
								</div>

								<!-- Caja x -->
								<div class="anim-box anim-box-prim" id="prim-box-x" style="opacity: 0">
									<div class="anim-box-var">x (copia)</div>
