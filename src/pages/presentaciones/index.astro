---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import Icon from '../../components/Icon.astro';
import { getRelativePath } from '../../utils/paths';

const presentations = [
	{
		file: 'lesson_01.sh',
		tag: 'Algoritmos',
		tagClass: 'text-primary bg-primary/10 border-primary/20',
		title: 'Variables y Constantes',
		description: 'Constante: valor fijo. Variable: valor que cambia durante la ejecución.',
		url: getRelativePath('/presentaciones/variables_y_constantes'),
	},
	{
		file: 'paso_por_valor_y_referencia.java',
		tag: 'JAVA',
		tagClass: 'text-accent-blue bg-accent-blue/10 border-accent-blue/20',
		title: 'Paso por valor y paso por referencia',
		description: 'Descubre cómo Java maneja la memoria: primitivas copian su valor, objetros comparten su dirección.',
		url: getRelativePath('/presentaciones/paso_por_valor_y_referencia'),
	},
	{
		file: 'tipos_de_datos.js',
		tag: 'Javascript',
		tagClass: 'text-yellow-500 bg-yellow-500/10 border-yellow-500/20',
		title: 'Tipos de Datos',
		description: 'Descubre los tipos primitivos y objetos que conforman el lenguaje.',
		url: getRelativePath('/presentaciones/tipos_de_datos_en_javascript'),
	},
	{
		file: 'modularidad.c',
		tag: 'C',
		tagClass: 'text-purple-500 bg-purple-500/10 border-purple-500/20',
		title: 'Modularidad',
		description: 'Subprogramas, Funciones y Procedimientos',
		url: getRelativePath('/presentaciones/modularidad_en_c'),
	},
];

const categories = [
	{ label: '~/todos', filter: 'all' },
	{ label: '~/algoritmos', filter: 'Algoritmos' },
	{ label: '~/java', filter: 'JAVA' },
	{ label: '~/javascript', filter: 'Javascript' },
	{ label: '~/c', filter: 'C' },
];
---

<Layout title="Presentaciones - Programierds | Terminal Edition">
	<style>
		.glow-card {
			box-shadow: 0 0 20px rgba(13, 242, 89, 0.05), inset 0 0 10px rgba(13, 242, 89, 0.05);
			transition: all 0.3s ease;
		}
		.glow-card:hover {
			box-shadow: 0 0 30px rgba(13, 242, 89, 0.25), inset 0 0 15px rgba(13, 242, 89, 0.1);
			transform: translateY(-2px);
		}
		.terminal-cursor {
			display: inline-block;
			width: 8px;
			height: 1.2em;
			background-color: #0df259;
			vertical-align: middle;
			margin-left: 4px;
			animation: blink 1s step-end infinite;
		}
		@keyframes blink {
			50% { opacity: 0; }
		}
	</style>

	<div class="relative flex min-h-screen flex-col overflow-x-hidden">

		<main class="flex-1 flex flex-col lg:flex-row mx-auto w-full relative z-10">
			<!-- Sidebar -->
			<aside class="hidden lg:block w-72 shrink-0 border-r border-primary/10 p-8 custom-scrollbar overflow-y-auto bg-background-dark/50">
				<div class="sticky top-24 space-y-12">
					<div>
						<h3 class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-primary/60 mb-6 flex items-center gap-2">
							<Icon name="description" class="w-4 h-4" />
							DIRECTORIOS
						</h3>
						<ul class="space-y-2 font-mono text-sm" id="filter-list">
							{categories.map((cat) => (
								<li>
									<button
										data-filter={cat.filter}
										class:list={[
											'filter-btn flex items-center gap-3 px-3 py-2 rounded-md w-full text-left transition-all',
											cat.filter === 'all'
												? 'bg-primary/10 text-primary border border-primary/20'
												: 'text-slate-400 hover:text-primary hover:bg-primary/5',
										]}
									>
										<Icon name="description" class="w-5 h-5" />
										{cat.label}
									</button>
								</li>
							))}
						</ul>
					</div>
					<div class="pt-6 border-t border-primary/10">
						<div class="bg-black/30 p-5 rounded border border-primary/10 font-mono backdrop-blur-sm">
							<p class="text-[10px] text-primary/40 leading-tight mb-3"># STATUS_REPORT</p>
							<p class="text-xs text-slate-300 italic leading-relaxed">
								"Si el código funciona a la primera, sospecha de tu realidad."
							</p>
							<div class="mt-4 flex items-center gap-2">
								<div class="h-1 w-full bg-primary/10 rounded-full overflow-hidden">
									<div class="h-full bg-primary/40 w-[65%] shadow-[0_0_5px_rgba(13,242,89,0.5)]"></div>
								</div>
								<span class="text-[9px] text-primary/40">65%</span>
							</div>
						</div>
					</div>
				</div>
			</aside>

			<!-- Content -->
			<section class="flex-1 p-8 lg:p-12">
				<header class="mb-12">
					<div class="flex items-center gap-3 text-primary font-mono text-sm mb-4">
						<span class="bg-primary/20 px-2 py-0.5 rounded">./ls lessons --all</span>
					</div>
				</header>

				<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6" id="cards-grid">
					{presentations.map((pres) => (
						<div class="group flex flex-col bg-background-dark border border-primary/30 rounded-lg overflow-hidden glow-card" data-tag={pres.tag}>
							<div class="bg-background-dark/80 px-4 py-2 flex items-center justify-between border-b border-primary/20">
								<div class="flex items-center gap-1.5">
									<div class="size-2.5 rounded-full bg-red-500/50 shadow-[0_0_5px_rgba(239,68,68,0.5)]"></div>
									<div class="size-2.5 rounded-full bg-yellow-500/50 shadow-[0_0_5px_rgba(234,179,8,0.5)]"></div>
									<div class="size-2.5 rounded-full bg-green-500/50 shadow-[0_0_5px_rgba(34,197,94,0.5)]"></div>
								</div>
								<span class="font-mono text-[10px] text-primary/60 tracking-wider">{pres.file}</span>
							</div>
							<div class="p-6 flex flex-col h-full">
								<div class="mb-4">
									<span class={`font-mono text-[10px] uppercase px-2 py-0.5 rounded border ${pres.tagClass}`}>{pres.tag}</span>
								</div>
								<h3 class="font-mono text-lg font-bold text-white mb-4 group-hover:text-primary transition-colors">{pres.title}</h3>
								<p class="text-sm text-slate-300 font-mono leading-relaxed flex-1">{pres.description}</p>
								<div class="mt-6 flex items-center justify-end border-t border-primary/10 pt-4">
									<a class="font-mono text-xs font-bold text-primary flex items-center gap-1 hover:translate-x-1 transition-transform" href={pres.url || '#'}>
										[ EXECUTE ]
									</a>
								</div>
							</div>
						</div>
					))}
				</div>

			</section>
		</main>

		<Footer />
	</div>

	<script>
		const ACTIVE_CLASS = 'bg-primary/10 text-primary border border-primary/20';
		const INACTIVE_CLASS = 'text-slate-400 hover:text-primary hover:bg-primary/5';

		document.querySelectorAll<HTMLButtonElement>('.filter-btn').forEach((btn) => {
			btn.addEventListener('click', () => {
				const filter = btn.dataset.filter!;

				document.querySelectorAll<HTMLButtonElement>('.filter-btn').forEach((b) => {
					b.className = `filter-btn flex items-center gap-3 px-3 py-2 rounded-md w-full text-left transition-all ${INACTIVE_CLASS}`;
				});
				btn.className = `filter-btn flex items-center gap-3 px-3 py-2 rounded-md w-full text-left transition-all ${ACTIVE_CLASS}`;

				document.querySelectorAll<HTMLElement>('#cards-grid > [data-tag]').forEach((card) => {
					card.style.display = filter === 'all' || card.dataset.tag === filter ? '' : 'none';
				});
			});
		});
	</script>
</Layout>
