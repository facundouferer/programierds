---
import { getCollection } from 'astro:content';

import Footer from '../../components/Footer.astro';
import Icon from '../../components/Icon.astro';
import Layout from '../../layouts/Layout.astro';
import { getRelativePath } from '../../utils/paths';
import { assertUniqueTestSlugs, buildTestSummaries, formatDifficultyLabel } from '../../utils/tests';

const tests = await getCollection('tests');
assertUniqueTestSlugs(tests);

const summaries = buildTestSummaries(tests);
---

<Layout title="Tests - Programierds | Multiple choice con olor a gloria">
  <div class="relative flex min-h-screen flex-col overflow-x-hidden">

    <main class="flex-1 px-4 py-12 lg:px-20 lg:py-16">
      <div class="mx-auto max-w-7xl">
        <section class="relative overflow-hidden rounded-[2rem] border border-primary/15 bg-gradient-to-br from-primary/10 via-transparent to-accent-blue/10 px-6 py-10 lg:px-10 lg:py-14">
          <div class="absolute inset-y-0 right-0 hidden w-1/3 bg-[radial-gradient(circle_at_center,rgba(13,242,89,0.16),transparent_60%)] lg:block"></div>
          <div class="relative max-w-3xl space-y-5">
            <div class="inline-flex items-center rounded-full border border-primary/20 bg-primary/10 px-4 py-2 text-xs font-black uppercase tracking-[0.22em] text-primary">
              Tests
            </div>
            <h1 class="text-4xl font-black tracking-tight text-slate-900 dark:text-white lg:text-6xl">
              Medite qué tan fino viene tu cerebro programierd
            </h1>
            <p class="max-w-2xl text-lg leading-relaxed text-slate-600 dark:text-slate-400">
              Cada examen nace desde Markdown, se publica solo y mantiene la misma vibra del sitio. Elegí uno, resolvelo a tu ritmo y revisá el feedback al final.
            </p>
          </div>
        </section>

        <section class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {summaries.map((test) => (
            <a
              class="group flex h-full flex-col rounded-[1.75rem] border border-primary/10 bg-background-light p-6 transition-all hover:-translate-y-1 hover:border-primary/40 hover:shadow-[0_30px_80px_-60px_rgba(13,242,89,0.55)] dark:bg-background-dark"
              href={getRelativePath(`/test/${test.slug}`)}
            >
              <div class="mb-6 flex items-start justify-between gap-4">
                <div class="flex size-14 items-center justify-center rounded-2xl bg-primary/10 text-primary">
                  <Icon name="bug_report" class="h-7 w-7" />
                </div>
                <span class="rounded-full border border-primary/20 bg-primary/10 px-3 py-1 text-[10px] font-black uppercase tracking-[0.24em] text-primary">
                  {formatDifficultyLabel(test.difficulty)}
                </span>
              </div>

              <div class="flex-1 space-y-4">
                <div>
                  <p class="text-xs font-black uppercase tracking-[0.2em] text-accent-blue">{test.category}</p>
                  <h2 class="mt-2 text-2xl font-black tracking-tight text-slate-900 dark:text-white">{test.title}</h2>
                </div>
                <p class="text-base leading-relaxed text-slate-600 dark:text-slate-400">{test.description}</p>
              </div>

              <div class="mt-8 grid grid-cols-2 gap-3 border-t border-primary/10 pt-5 text-sm">
                <div class="rounded-2xl bg-primary/5 px-4 py-3">
                  <p class="text-[11px] font-black uppercase tracking-[0.2em] text-slate-500 dark:text-slate-400">Preguntas</p>
                  <p class="mt-2 text-xl font-black text-slate-900 dark:text-white">{test.questionCount}</p>
                </div>
                <div class="rounded-2xl bg-accent-blue/5 px-4 py-3">
                  <p class="text-[11px] font-black uppercase tracking-[0.2em] text-slate-500 dark:text-slate-400">Tiempo</p>
                  <p class="mt-2 text-xl font-black text-slate-900 dark:text-white">{test.timeEstimate ? `${test.timeEstimate} min` : 'Libre'}</p>
                </div>
              </div>

              <div class="mt-6 flex items-center justify-between">
                <span class="text-sm font-bold text-slate-600 dark:text-slate-400">Abrir test</span>
                <span class="inline-flex h-11 items-center justify-center rounded-xl bg-primary px-5 text-sm font-black text-background-dark transition-transform group-hover:scale-105">
                  Empezar
                </span>
              </div>
            </a>
          ))}
        </section>
      </div>
    </main>

    <Footer />
  </div>
</Layout>
