---
import { getRelativePath } from '../utils/paths';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
// Path relativo al base (ej: '/programierds/presentaciones' → 'presentaciones')
const relativePath = currentPath.replace(base, '').replace(/^\//, '') || '/';

const navLinks = [
	{ label: 'Inicio', href: '/' },
	{ label: 'Cursos', href: '/cursos' },
	{ label: 'Presentaciones', href: '/presentaciones' },
	{ label: 'Playground', href: '/playground' },
];
---

<header class="sticky top-0 z-50 w-full border-b border-primary/10 bg-background-light/80 dark:bg-background-dark/80 backdrop-blur-md px-4 lg:px-20 py-4">
	<div class="mx-auto flex max-w-7xl items-center justify-between">
		<a class="flex items-center gap-2" href={getRelativePath('/')}>
			<span class="text-3xl">💩</span>
			<h2 class="text-slate-900 dark:text-slate-100 text-2xl font-bold tracking-tight">programierds</h2>
		</a>
		<nav class="hidden md:flex items-center gap-8">
			{navLinks.map(({ label, href }) => {
				const isHome = href === '/';
				// Inicio activo solo en path exacto '/', otras páginas si coinciden con el inicio del path
				const isActive = isHome 
					? relativePath === '/'
					: relativePath.startsWith(href.replace(/^\//, ''));
				return (
					<a
						class={isActive
							? 'text-primary transition-colors text-sm font-bold border-b-2 border-primary'
							: 'hover:text-primary transition-colors text-sm font-medium'}
						href={getRelativePath(href)}
					>
						{label}
					</a>
				);
			})}
		</nav>
		<a href={getRelativePath('/playground')} class="flex items-center justify-center rounded-xl bg-primary px-6 py-2 text-sm font-bold text-background-dark hover:brightness-110 transition-all">
			Playground
		</a>
	</div>
</header>
